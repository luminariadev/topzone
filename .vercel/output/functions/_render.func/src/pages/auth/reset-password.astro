---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<Layout>
  <Navbar />
  <section class="min-h-screen flex items-center justify-center bg-neon-green dark:bg-gray-900 py-16 px-4">
    <div class="w-full max-w-md">
      <div class="border-4 border-black bg-white dark:bg-gray-800 p-8 shadow-[8px_8px_0px_0px_#000]">
        <div class="text-center mb-8">
          <div class="w-20 h-20 mx-auto mb-6 bg-yellow-400/10 border-4 border-black rounded-full flex items-center justify-center shadow-[4px_4px_0px_0px_#000]">
            <svg class="w-10 h-10 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m0 0v2m0-2h2m-2 0H10m9.364-7.364A9 9 0 1112 3a9 9 0 017.364 4.636z" />
            </svg>
          </div>
          <h1 class="text-4xl font-black mb-2 text-black dark:text-white">Reset <span style="color:#39FF14; -webkit-text-stroke:1px #000;">Password</span></h1>
          <p class="font-bold text-gray-600 dark:text-gray-300">Buat password baru untuk akun kamu</p>
        </div>
        <div id="invalid-state" class="hidden bg-red-50 dark:bg-red-900/20 border-2 border-red-500 p-6 rounded-lg mb-6">
          <p class="font-bold text-red-700 dark:text-red-300 mb-4" id="invalid-msg">⚠️ Link reset password tidak valid atau sudah kedaluwarsa.</p>
          <a href="/auth/forgot-password" class="block w-full py-3 font-black text-center text-sm bg-black text-white border-2 border-black hover:bg-neon-pink transition-all">Minta Link Baru</a>
        </div>
        <form id="reset-form" class="space-y-5">
          <div>
            <label for="password" class="block text-sm font-black uppercase tracking-wider mb-2 text-black dark:text-white">Password Baru</label>
            <input type="password" id="password" name="password" required minlength="6" placeholder="Min 6 karakter"
              class="w-full px-4 py-3 border-3 border-black font-bold text-lg shadow-[3px_3px_0px_0px_#000] focus:shadow-[1px_1px_0px_0px_#000] focus:translate-x-[2px] focus:translate-y-[2px] outline-none transition-all dark:bg-gray-700 dark:text-white" />
          </div>
          <div>
            <label for="password-confirm" class="block text-sm font-black uppercase tracking-wider mb-2 text-black dark:text-white">Konfirmasi Password Baru</label>
            <input type="password" id="password-confirm" name="password-confirm" required minlength="6" placeholder="Ulangi password"
              class="w-full px-4 py-3 border-3 border-black font-bold text-lg shadow-[3px_3px_0px_0px_#000] focus:shadow-[1px_1px_0px_0px_#000] focus:translate-x-[2px] focus:translate-y-[2px] outline-none transition-all dark:bg-gray-700 dark:text-white" />
          </div>
          <div id="error-msg" class="hidden bg-red-500 text-white font-black px-4 py-3 border-2 border-black text-sm"></div>
          <div id="success-msg" class="hidden bg-neon-green text-black font-black px-4 py-3 border-2 border-black text-sm text-center">✅ Password berhasil direset! Kamu akan diarahkan ke halaman login.</div>
          <button type="submit" id="reset-btn"
            class="w-full py-4 font-black uppercase tracking-wider text-lg bg-black text-neon-green border-4 border-black shadow-[4px_4px_0px_0px_#39FF14] hover:-translate-y-1 hover:shadow-[6px_6px_0px_0px_#39FF14] active:translate-y-0 active:shadow-[2px_2px_0px_0px_#39FF14] transition-all">Reset Password</button>
        </form>
        <div class="mt-6 text-center">
          <p class="font-bold text-gray-600 dark:text-gray-300"><a href="/login" class="font-black underline hover:text-neon-green transition-colors text-black dark:text-white">Kembali ke Login</a></p>
        </div>
      </div>
      <div class="text-center mt-6">
        <a href="/" class="inline-flex items-center gap-2 font-black text-sm hover:underline text-black dark:text-white">← Kembali ke Beranda</a>
      </div>
    </div>
  </section>
  <Footer />
</Layout>

<script>
  import { updatePassword, getSession } from '../../lib/supabase';
  const invalidState = document.getElementById('invalid-state');
  const resetForm = document.getElementById('reset-form') as HTMLFormElement;
  const errorMsg = document.getElementById('error-msg');
  const successMsg = document.getElementById('success-msg');
  const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement;
  (async () => {
    const session = await getSession();
    if (!session && !window.location.hash && !window.location.search.includes('token')) {
      invalidState?.classList.remove('hidden');
      resetForm.classList.add('hidden');
    }
  })();
  resetForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg?.classList.add('hidden');
    successMsg?.classList.add('hidden');
    const password = (document.getElementById('password') as HTMLInputElement).value;
    const passwordConfirm = (document.getElementById('password-confirm') as HTMLInputElement).value;
    if (password !== passwordConfirm) { errorMsg.textContent = 'Password tidak cocok!'; errorMsg?.classList.remove('hidden'); return; }
    if (password.length < 6) { errorMsg.textContent = 'Password minimal 6 karakter!'; errorMsg?.classList.remove('hidden'); return; }
    resetBtn.textContent = 'Mereset...';
    resetBtn.disabled = true;
    const { error } = await updatePassword(password);
    if (error) { errorMsg.textContent = error.message; errorMsg?.classList.remove('hidden'); resetBtn.textContent = 'Reset Password'; resetBtn.disabled = false; return; }
    successMsg?.classList.remove('hidden');
    resetBtn.textContent = 'Berhasil!';
    setTimeout(() => { window.location.href = '/login'; }, 2000);
  });
</script>