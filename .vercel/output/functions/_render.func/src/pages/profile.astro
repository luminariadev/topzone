---
// src/pages/profile.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import AvatarUpload from '../components/AvatarUpload.astro';
---

<Layout>
  <Navbar />

  <!-- Login Gate -->
  <div id="login-gate" class="hidden min-h-screen flex items-center justify-center bg-neon-pink dark:bg-gray-900 py-16 px-4">
    <div class="w-full max-w-md border-4 border-black bg-white dark:bg-gray-800 p-8 shadow-[8px_8px_0px_0px_#000] dark:shadow-[8px_8px_0px_0px_#FF007F] text-center">
      <div class="text-6xl mb-4">🔒</div>
      <h1 class="text-3xl font-black mb-2 text-black dark:text-white">Login Diperlukan</h1>
      <p class="font-bold mb-6 text-gray-600 dark:text-gray-300">Kamu harus login untuk mengakses halaman profil.</p>
      <a href="/login?redirect=/profile" class="inline-block px-8 py-3 font-black uppercase border-2 border-black bg-neon-green shadow-[3px_3px_0px_0px_#000] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">Masuk Sekarang</a>
    </div>
  </div>

  <!-- Profile Content -->
  <div id="profile-content" class="hidden py-16 min-h-screen bg-white dark:bg-gray-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Header -->
      <div class="flex items-center gap-6 mb-10 border-4 border-black p-6 bg-neon-yellow dark:bg-gray-700 shadow-[6px_6px_0px_0px_#000]">
        <div id="avatar-upload-wrap"></div>
        <div class="flex-1">
          <h1 class="text-4xl font-black text-black dark:text-white" id="profile-name">User</h1>
          <p class="font-bold text-lg text-gray-700 dark:text-gray-300" id="profile-email">user@email.com</p>
          <p class="text-sm font-bold text-gray-500 dark:text-gray-400">Member sejak <span id="profile-member-since">-</span></p>
        </div>
      </div>

      <!-- Stats Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
        <div class="border-4 border-black p-5 bg-white dark:bg-gray-800 shadow-[4px_4px_0px_0px_#000] text-center">
          <div class="text-3xl mb-1">💰</div>
          <p class="text-3xl font-black text-neon-pink" id="stats-points">0</p>
          <p class="text-xs font-black uppercase tracking-wider text-black dark:text-white">Poin Belanja</p>
        </div>
        <div class="border-4 border-black p-5 bg-white dark:bg-gray-800 shadow-[4px_4px_0px_0px_#000] text-center">
          <div class="text-3xl mb-1">📦</div>
          <p class="text-3xl font-black text-black dark:text-white" id="stats-orders">0</p>
          <p class="text-xs font-black uppercase tracking-wider text-black dark:text-white">Total Pesanan</p>
        </div>
        <div class="border-4 border-black p-5 bg-white dark:bg-gray-800 shadow-[4px_4px_0px_0px_#000] text-center">
          <div class="text-3xl mb-1">💵</div>
          <p class="text-3xl font-black text-neon-green" id="stats-spent">Rp 0</p>
          <p class="text-xs font-black uppercase tracking-wider text-black dark:text-white">Total Belanja</p>
        </div>
      </div>

      <!-- Tabs -->
      <div class="flex flex-wrap gap-2 mb-6 border-b-4 border-black dark:border-gray-600 pb-2">
        <button class="profile-tab px-6 py-3 font-black tracking-wider border-2 border-black bg-neon-green shadow-[2px_2px_0px_0px_#000]" data-tab="orders">📋 Riwayat Pesanan</button>
        <button class="profile-tab px-6 py-3 font-black tracking-wider border-2 border-black bg-white dark:bg-gray-700 dark:text-white shadow-[2px_2px_0px_0px_#000]" data-tab="settings">⚙️ Pengaturan Akun</button>
        <button class="profile-tab px-6 py-3 font-black tracking-wider border-2 border-black bg-white dark:bg-gray-700 dark:text-white shadow-[2px_2px_0px_0px_#000]" data-tab="vouchers">🎰 Voucher Saya</button>
      </div>

      <!-- Tab: Orders -->
      <div id="panel-orders" class="space-y-4">
        <div id="orders-empty" class="text-center py-16 border-4 border-dashed border-black">
          <div class="text-5xl mb-3">🔍</div>
          <p class="text-xl font-black mb-2">Belum ada pesanan</p>
          <p class="text-gray-500 font-bold">Yuk top up game atau beli gear dulu!</p>
        </div>
        <div id="orders-list" class="hidden flex flex-col gap-4"></div>
      </div>

      <!-- Tab: Settings -->
      <div id="panel-settings" class="hidden space-y-6">
        <div class="border-4 border-black p-6 bg-white dark:bg-gray-800 shadow-[4px_4px_0px_0px_#000]">
          <h2 class="text-2xl font-black mb-6 text-black dark:text-white">⚙️ Pengaturan Akun</h2>
          <form id="settings-form" class="space-y-4">
            <div>
              <label class="block text-sm font-black uppercase tracking-wider mb-2 text-black dark:text-white">Nama Lengkap</label>
              <input type="text" id="settings-name" required class="w-full px-4 py-3 border-3 border-black font-bold text-lg shadow-[3px_3px_0px_0px_#000] focus:shadow-none focus:translate-x-[2px] focus:translate-y-[2px] outline-none transition-all dark:bg-gray-700 dark:text-white" />
            </div>
            <div>
              <label class="block text-sm font-black uppercase tracking-wider mb-2 text-black dark:text-white">Email</label>
              <input type="email" id="settings-email" disabled class="w-full px-4 py-3 border-3 border-black font-bold text-lg bg-gray-100 dark:bg-gray-700 dark:text-gray-300 shadow-[3px_3px_0px_0px_#000]" />
            </div>
            <div id="settings-msg" class="hidden bg-neon-green text-black font-black px-4 py-3 border-2 border-black text-sm"></div>
            <button type="submit" class="px-8 py-3 font-black uppercase border-2 border-black bg-black text-neon-green shadow-[3px_3px_0px_0px_#39FF14] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">Simpan Perubahan</button>
          </form>
        </div>
      </div>

      <!-- Tab: Vouchers -->
      <div id="panel-vouchers" class="hidden space-y-4">
        <div id="vouchers-empty" class="text-center py-16 border-4 border-dashed border-black dark:border-gray-600">
          <div class="text-5xl mb-3">🎰</div>
          <p class="text-xl font-black mb-2 text-black dark:text-white">Belum ada voucher</p>
          <p class="font-bold text-gray-500 dark:text-gray-400">Daftarkan akun baru untuk mendapatkan voucher selamat datang!</p>
        </div>
        <div id="vouchers-list" class="hidden flex flex-col gap-4"></div>
      </div>

    </div>
  </div>

  <Footer />
</Layout>

<script>
  import { user, getOrdersKey, getCurrentEmail } from '../stores/auth';
  import { logoutUser } from '../stores/auth';

  const loginGate = document.getElementById('login-gate');
  const profileContent = document.getElementById('profile-content');

  function formatRp(n) { return 'Rp ' + Number(n).toLocaleString('id-ID'); }

  function statusBadge(status) {
    const m = { pending: 'bg-yellow-400', processing: 'bg-blue-400', completed: 'bg-neon-green', cancelled: 'bg-red-400' };
    const l = { pending: 'Pending', processing: 'Diproses', completed: 'Selesai', cancelled: 'Dibatalkan' };
    return '<span class="inline-block px-3 py-1 text-xs font-black uppercase tracking-wider border-2 border-black ' + (m[status]||'bg-gray-400') + '">' + (l[status]||status) + '</span>';
  }

  function loadProfile() {
    const currentUser = user.get();
    if (!currentUser || !currentUser.isLoggedIn) {
      loginGate?.classList.remove('hidden');
      profileContent?.classList.add('hidden');
      return;
    }

    loginGate?.classList.add('hidden');
    profileContent?.classList.remove('hidden');

    const email = currentUser.email;
    const name = currentUser.full_name || email.split('@')[0];

    // Header
    document.getElementById('avatar-letter').textContent = name.charAt(0).toUpperCase();
    document.getElementById('profile-name').textContent = name;
    document.getElementById('profile-email').textContent = email;

    // Settings form
    document.getElementById('settings-name').value = name;
    document.getElementById('settings-email').value = email;

    // Load orders
    const ordersKey = getOrdersKey();
    const orders = JSON.parse(localStorage.getItem(ordersKey) || '[]');

    // Stats
    document.getElementById('stats-orders').textContent = orders.length;
    const totalSpent = orders.reduce(function(sum, o) { return sum + (o.total || 0); }, 0);
    document.getElementById('stats-spent').textContent = formatRp(totalSpent);
    // Points: 1 point per Rp 1000 spent
    const points = Math.floor(totalSpent / 1000);
    document.getElementById('stats-points').textContent = points.toLocaleString('id-ID');

    // Member since: from first order or today
    if (orders.length > 0) {
      var dates = orders.map(function(o) { return new Date(o.createdAt); }).sort();
      document.getElementById('profile-member-since').textContent = dates[0].toLocaleDateString('id-ID', { year:'numeric', month:'long', day:'numeric' });
    } else {
      document.getElementById('profile-member-since').textContent = new Date().toLocaleDateString('id-ID', { year:'numeric', month:'long', day:'numeric' });
    }

    // Render orders
    var ordersEmpty = document.getElementById('orders-empty');
    var ordersList = document.getElementById('orders-list');

    if (orders.length === 0) {
      ordersEmpty?.classList.remove('hidden');
      ordersList?.classList.add('hidden');
    } else {
      ordersEmpty?.classList.add('hidden');
      ordersList?.classList.remove('hidden');
      ordersList.innerHTML = orders.slice(0, 20).map(function(o) {
        return '<a href="/order-detail?id=' + (o.id||'') + '" class="block border-4 border-black p-5 bg-white dark:bg-gray-800 shadow-[4px_4px_0px_0px_#000] hover:-translate-y-1 hover:shadow-[6px_6px_0px_0px_#000] transition-all">' +
          '<div class="flex justify-between items-start mb-2">' +
            '<div><p class="font-black text-lg text-black dark:text-white">' + (o.name||'') + '</p>' +
            '<p class="text-xs font-bold text-gray-500 dark:text-gray-400">' + (o.id||'') + ' &middot; ' + new Date(o.createdAt).toLocaleDateString('id-ID') + '</p></div>' +
            statusBadge(o.status) +
          '</div>' +
          '<div class="flex justify-between items-center mt-3 pt-3 border-t-2 border-black/10 dark:border-gray-600">' +
            '<span class="text-sm font-bold text-gray-500 dark:text-gray-400">' + (o.items?.length || 0) + ' item</span>' +
            '<span class="text-xl font-black text-neon-pink">' + formatRp(o.total) + '</span>' +
          '</div></a>';
      }).join('');
    }

    // Render vouchers
    renderVouchers();
  }

  function renderVouchers() {
    var vouchersList = document.getElementById('vouchers-list');
    var vouchersEmpty = document.getElementById('vouchers-empty');
    try {
      var v = JSON.parse(localStorage.getItem('topzone_voucher'));
      if (v && !v.used) {
        vouchersEmpty?.classList.add('hidden');
        vouchersList?.classList.remove('hidden');
        vouchersList.innerHTML = '<div class="border-4 border-black p-5 bg-neon-yellow shadow-[4px_4px_0px_0px_#000]">' +
          '<div class="flex justify-between items-center">' +
            '<div><p class="text-xl font-black">' + v.code + '</p>' +
            '<p class="text-sm font-bold">Diskon ' + v.discount + '% untuk pesanan berikutnya!</p></div>' +
            '<span class="px-3 py-1 text-xs font-black border-2 border-black bg-neon-green">Aktif</span>' +
          '</div></div>';
        return;
      }
    } catch(e) {
      console.warn('LocalStorage operation failed:', e);
    }
    vouchersEmpty?.classList.remove('hidden');
    vouchersList?.classList.add('hidden');
  }

  // Tab switching
  document.querySelectorAll('.profile-tab').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.profile-tab').forEach(function(b) {
        b.style.background = '#fff';
        b.style.boxShadow = '2px_2px_0px_0px_#000';
      });
      this.style.background = '#39FF14';
      ['orders','settings','vouchers'].forEach(function(p) {
        document.getElementById('panel-' + p).classList.add('hidden');
      });
      document.getElementById('panel-' + this.dataset.tab).classList.remove('hidden');
    });
  });

  // Settings form
  document.getElementById('settings-form').addEventListener('submit', function(e) {
    e.preventDefault();
    var newName = document.getElementById('settings-name').value.trim();
    if (!newName) return;
    var msg = document.getElementById('settings-msg');
    var currentUser = user.get();
    if (currentUser) {
      currentUser.full_name = newName;
      try {
        localStorage.setItem('topzone_current_user', JSON.stringify(currentUser));
        document.getElementById('profile-name').textContent = newName;
        document.getElementById('avatar-letter').textContent = newName.charAt(0).toUpperCase();
        msg.textContent = 'Nama berhasil diperbarui!';
        msg.className = 'bg-neon-green text-black font-black px-4 py-3 border-2 border-black text-sm';
        msg.classList.remove('hidden');
      } catch(e) {
      console.warn('LocalStorage operation failed:', e);
    }
    }
  });

  // Init
  user.subscribe(loadProfile);
  loadProfile();
</script>
