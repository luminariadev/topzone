---
// src/components/PointsLoyalty.astro
// Points & Loyalty system (Fase 3.3 items 1-4)
---

<script>
  import { user } from '../stores/auth';

  function initPoints() {
    var el = document.getElementById('points-loyalty-wrap');
    if (!el || el.children.length > 0) return;

    var currentUser = user.get();
    if (!currentUser || !currentUser.isLoggedIn) return;

    var email = currentUser.email.replace(/[^a-zA-Z0-9]/g, '_');
    var ordersKey = 'topzone_orders_' + email;
    var pointsKey = 'topzone_points_' + email;
    var tierKey = 'topzone_tier_' + email;

    var totalSpent = 0;
    try {
      var orders = JSON.parse(localStorage.getItem(ordersKey) || '[]');
      totalSpent = orders.reduce(function(sum, o) { return sum + (o.total || 0); }, 0);
    } catch(e) {}

    var points = Math.floor(totalSpent / 1000);
    localStorage.setItem(pointsKey, String(points));

    var tier = { name: 'Bronze', icon: '🥉', next: 'Silver', nextSpent: 500000 };
    if (totalSpent >= 5000000) { tier = { name: 'Platinum', icon: '💎', next: null, nextSpent: null }; }
    else if (totalSpent >= 2000000) { tier = { name: 'Gold', icon: '🥇', next: 'Platinum', nextSpent: 5000000 }; }
    else if (totalSpent >= 500000) { tier = { name: 'Silver', icon: '🥈', next: 'Gold', nextSpent: 2000000 }; }

    var progress = tier.nextSpent ? Math.min(100, Math.round(totalSpent / tier.nextSpent * 100)) : 100;
    localStorage.setItem(tierKey, JSON.stringify(tier));

    el.innerHTML =
      '<div class="border-4 border-black p-6 bg-white dark:bg-gray-800 shadow-[4px_4px_0px_0px_#000]">' +
        '<h3 class="text-xl font-black mb-4 text-black dark:text-white">Points & Loyalty</h3>' +
        '<div class="border-4 border-black p-5 mb-4 bg-gradient-to-r from-neon-yellow to-yellow-200 text-center">' +
          '<div class="text-5xl mb-2">' + tier.icon + '</div>' +
          '<p class="text-2xl font-black text-black">' + tier.name + '</p>' +
          '<p class="text-4xl font-black text-neon-pink mt-2">' + points.toLocaleString('id-ID') + '</p>' +
          '<p class="text-sm font-bold text-gray-600">Poin</p>' +
        '</div>' +
        (tier.next ? (
          '<div class="mb-4">' +
            '<div class="flex justify-between items-center mb-2">' +
              '<span class="text-sm font-black text-black dark:text-white">' + tier.name + ' -> ' + tier.next + '</span>' +
              '<span class="text-xs font-bold text-gray-500">Rp ' + totalSpent.toLocaleString('id-ID') + ' / Rp ' + tier.nextSpent.toLocaleString('id-ID') + '</span>' +
            '</div>' +
            '<div class="w-full h-4 bg-gray-200 dark:bg-gray-600 border-2 border-black overflow-hidden">' +
              '<div class="h-full bg-neon-green transition-all" style="width:' + progress + '%"></div>' +
            '</div>' +
          '</div>'
        ) : '<div class="mb-4 p-3 bg-neon-green border-2 border-black text-center"><span class="font-black text-black">Tier Tertinggi!</span></div>') +
        '<div class="border-4 border-black p-4 bg-gray-50 dark:bg-gray-700 mb-4">' +
          '<h4 class="font-black mb-2 text-black dark:text-white">Benefits</h4>' +
          '<ul class="text-xs font-bold space-y-1 text-gray-600 dark:text-gray-300">' +
            '<li>Bronze: 1 poin/Rp1000</li><li>Silver: 1.5x poin + voucher eksklusif</li>' +
            '<li>Gold: 2x poin + free shipping + early access sale</li><li>Platinum: 3x poin + dedicated support + birthday gift</li>' +
          '</ul>' +
        '</div>' +
        '<div class="border-4 border-black p-4 bg-white dark:bg-gray-800">' +
          '<h4 class="font-black mb-3 text-black dark:text-white">Riwayat Poin</h4>' +
          '<div class="flex justify-between items-center p-2 border-b-2 border-black/10">' +
            '<div><p class="text-sm font-bold text-black dark:text-white">Poin dari total belanja</p><p class="text-xs text-gray-500">Akumulasi</p></div>' +
            '<span class="text-sm font-black text-neon-green">+' + points.toLocaleString('id-ID') + '</span>' +
          '</div>' +
        '</div>' +
      '</div>';
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initPoints);
  else initPoints();
  user.subscribe(function () { setTimeout(initPoints, 50); });
</script>