---
// src/components/EmailTemplates.astro
// Email template preview component - Fase 3.2 items 2-7
---

<script>
  function initEmailTemplates() {
    var el = document.getElementById('email-templates-wrap');
    if (!el || el.children.length > 0) return;

    var templates = [
      { id: 'welcome', name: 'Selamat Datang', icon: '👋', desc: 'Dikirim saat user baru mendaftar' },
      { id: 'order-confirm', name: 'Konfirmasi Pesanan', icon: '📋', desc: 'Dikirim saat pesanan berhasil dibuat' },
      { id: 'payment-success', name: 'Pembayaran Berhasil', icon: '💰', desc: 'Dikirim saat pembayaran dikonfirmasi' },
      { id: 'payment-failed', name: 'Pembayaran Gagal', icon: '❌', desc: 'Dikirim saat pembayaran gagal' },
      { id: 'order-shipped', name: 'Pesanan Dikirim', icon: '🚚', desc: 'Dikirim saat pesanan sudah dikirim' },
      { id: 'password-reset', name: 'Reset Password', icon: '🔑', desc: 'Dikirim saat user minta reset password' },
    ];

    el.innerHTML =
      '<div class="border-4 border-black p-6 bg-white dark:bg-gray-800 shadow-[4px_4px_0px_0px_#000]">' +
        '<h3 class="text-xl font-black mb-4 text-black dark:text-white">Email Templates</h3>' +
        '<div class="space-y-3">' +
          templates.map(function(t) {
            return '<div class="border-2 border-black p-4 bg-gray-50 dark:bg-gray-700 hover:bg-neon-yellow/20 transition-colors">' +
              '<div class="flex items-center gap-3">' +
                '<span class="text-2xl">' + t.icon + '</span>' +
                '<div class="flex-1">' +
                  '<p class="font-black text-sm text-black dark:text-white">' + t.name + '</p>' +
                  '<p class="text-xs font-bold text-gray-500 dark:text-gray-400">' + t.desc + '</p>' +
                '</div>' +
                '<span class="px-2 py-1 text-xs font-black border-2 border-black bg-neon-green text-black">Siap</span>' +
              '</div>' +
            '</div>';
          }).join('') +
        '</div>' +
        '<p class="mt-4 text-xs font-bold text-gray-500 dark:text-gray-400">Templates akan dikirim via Supabase Edge Functions saat integrasi email provider.</p>' +
      '</div>';
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initEmailTemplates);
  else initEmailTemplates();
</script>