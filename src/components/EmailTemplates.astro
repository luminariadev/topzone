---
// src/components/EmailTemplates.astro
// Email template preview component - Fase 3.2 items 2-7
// Fetches template previews from the email API endpoint
---

<script>
  function initEmailTemplates() {
    var el = document.getElementById('email-templates-wrap');
    if (!el || el.children.length > 0) return;

    var templates = [
      { id: 'welcome', name: 'Selamat Datang', icon: '👋', desc: 'Dikirim saat user baru mendaftar', built: true },
      { id: 'order-confirmation', name: 'Konfirmasi Pesanan', icon: '📋', desc: 'Dikirim saat pesanan berhasil dibuat', built: true },
      { id: 'payment-success', name: 'Pembayaran Berhasil', icon: '💰', desc: 'Dikirim saat pembayaran dikonfirmasi', built: true },
      { id: 'payment-failed', name: 'Pembayaran Gagal', icon: '❌', desc: 'Dikirim saat pembayaran gagal', built: true },
      { id: 'order-shipped', name: 'Pesanan Dikirim', icon: '🚚', desc: 'Dikirim saat pesanan sudah dikirim', built: true },
    ];

    el.innerHTML =
      '<div class="border-4 border-black p-6 bg-white dark:bg-gray-800 shadow-[4px_4px_0px_0px_#000]">' +
        '<h3 class="text-xl font-black mb-4 text-black dark:text-white">📧 Email Templates</h3>' +
        '<p class="text-sm font-bold text-gray-500 mb-4">Template HTML siap pakai — integrasi dengan SendGrid, Resend, atau SMTP.</p>' +
        '<div class="space-y-3">' +
          templates.map(function(t) {
            return '<div class="border-2 border-black p-4 bg-gray-50 dark:bg-gray-700 hover:bg-neon-yellow/20 transition-colors cursor-pointer preview-template" data-template="' + t.id + '">' +
              '<div class="flex items-center gap-3">' +
                '<span class="text-2xl">' + t.icon + '</span>' +
                '<div class="flex-1">' +
                  '<p class="font-black text-sm text-black dark:text-white">' + t.name + '</p>' +
                  '<p class="text-xs font-bold text-gray-500 dark:text-gray-400">' + t.desc + '</p>' +
                '</div>' +
                '<span class="px-2 py-1 text-xs font-black border-2 border-black ' + (t.built ? 'bg-neon-green text-black' : 'bg-gray-300') + '">' + (t.built ? 'Siap' : 'Akan Datang') + '</span>' +
              '</div>' +
            '</div>';
          }).join('') +
        '</div>' +
        '<div id="template-preview" class="hidden mt-4 border-2 border-black p-4 bg-white max-h-96 overflow-auto">' +
          '<div id="template-preview-content"></div>' +
        '</div>' +
        '<p class="mt-4 text-xs font-bold text-gray-500 dark:text-gray-400">Klik template untuk melihat preview HTML. Integrasi email provider via Supabase Edge Functions.</p>' +
      '</div>';

    // Preview template on click
    document.querySelectorAll('.preview-template').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var templateId = this.dataset.template;
        var previewEl = document.getElementById('template-preview');
        var contentEl = document.getElementById('template-preview-content');

        fetch('/api/email/send', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            to: 'preview@topzone.id',
            template: templateId,
            data: {
              customer_name: 'Budi Gamer',
              id: 'ORD-PREVIEW-001',
              total: 150000,
              discount: 10,
              payment_method: 'bank',
              created_at: new Date().toISOString(),
              items: JSON.stringify([{ name: '86 Diamond MLBB', price: 19000, qty: 1 }]),
              full_name: 'Budi Gamer'
            }
          })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.htmlPreview) {
            contentEl.innerHTML = data.htmlPreview;
            previewEl.classList.remove('hidden');
          }
        })
        .catch(function() {
          contentEl.innerHTML = '<p class="text-red-500 font-bold">Gagal memuat preview template.</p>';
          previewEl.classList.remove('hidden');
        });
      });
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initEmailTemplates);
  else initEmailTemplates();
</script>
