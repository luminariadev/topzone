<!-- src/components/FeaturedGames.astro -->
---
import { fetchGames } from '../lib/products';
import Skeleton from './Skeleton.astro';
const games = await fetchGames();
---
<section id="games" class="py-20 bg-white text-black border-t-4 border-black dark:bg-[#111] dark:text-gray-200 dark:border-[#27272a]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <h2 class="text-5xl font-black uppercase tracking-tighter mb-3">
        Featured <span style="color:#39FF14; -webkit-text-stroke:1px #000;">Games</span>
      </h2>
      <p class="text-gray-600 dark:text-gray-400 font-bold text-lg">Top up instantly - safe, fast, and trusted.</p>
    </div>
    <div class="flex flex-wrap justify-center gap-3 mb-10" id="filter-tabs">
      {['all','mobile','pc','console'].map((cat) => (
        <button class="filter-tab px-5 py-2 font-black uppercase tracking-wider text-sm border-2 border-black dark:border-gray-600 shadow-[2px_2px_0px_0px_#000] dark:shadow-[2px_2px_0px_0px_#333] hover:-translate-y-[1px] hover:shadow-[3px_3px_0px_0px_#000] transition-all" data-cat={cat}>
          {cat === 'all' ? '🎮 All' : cat === 'mobile' ? '📱 Mobile' : cat === 'pc' ? '💻 PC' : '🎮 Console'}
        </button>
      ))}
    </div>
    {games.length === 0 ? (
      <Loading text="Memuat game..." />
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8" id="games-grid">
        {games.map((game) => (
          <article class="game-card group border-4 border-black dark:border-gray-600 bg-white dark:bg-[#1a1a1a] shadow-[6px_6px_0px_0px_#000] dark:shadow-[6px_6px_0px_0px_#333] hover:-translate-y-1 hover:shadow-[8px_8px_0px_0px_#000] transition-all duration-150" data-category={game.category}>
            <a href={`/games/${game.slug}`} class="block">
              <div class="relative">
                <img src={game.img} alt={`${game.name} - Top Up ${game.currency || 'Game'} di TopZone`} loading="lazy" decoding="async" class="w-full h-52 object-cover border-b-4 border-black aspect-[4/3]" width="400" height="300" />
                <span class="absolute top-3 left-3 px-3 py-1 text-xs font-black uppercase tracking-wider border-2 border-black dark:border-gray-600 shadow-[2px_2px_0px_0px_#000] dark:shadow-[2px_2px_0px_0px_#333]" style={`background:${game.color};`}>
                  {game.badge}
                </span>
              </div>
              <div class="p-5">
                <h3 class="text-2xl font-black mb-1">{game.name}</h3>
                <p class="text-gray-500 dark:text-gray-400 font-bold mb-4">Top up {game.currency}</p>
                <div class="w-full py-3 font-black uppercase tracking-wider text-center border-2 border-black dark:border-gray-600 shadow-[3px_3px_0px_0px_#000] dark:shadow-[3px_3px_0px_0px_#333] group-hover:translate-x-[2px] group-hover:translate-y-[2px] group-hover:shadow-[1px_1px_0px_0px_#000] transition-all" style={`background:${game.color};`}>
                  Top Up Sekarang &rarr;
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    )}
  </div>
</section>
<script>
  const tabs = document.querySelectorAll('.filter-tab');
  const cards = document.querySelectorAll('.game-card');

  function setActive(cat) {
    tabs.forEach((t) => {
      if (t.dataset.cat === cat) {
        t.style.background = '#39FF14';
        t.style.transform = 'translateX(2px) translateY(2px)';
        t.style.boxShadow = '1px 1px 0px 0px #000';
      } else {
        t.style.background = '';
        t.style.transform = '';
        t.style.boxShadow = '';
      }
    });
    cards.forEach((card) => {
      if (cat === 'all' || card.dataset.category === cat) {
        card.style.display = '';
      } else {
        card.style.display = 'none';
      }
    });
  }
  setActive('all');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => setActive(tab.dataset.cat ?? 'all'));
  });
</script>