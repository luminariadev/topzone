---
interface Props {
  text?: string;
}

const { text = "Memuat..." } = Astro.props;
---

<div class="flex flex-col items-center justify-center py-12">
  <div class="w-12 h-12 border-4 border-black border-t-neon-green rounded-full mb-4" style="animation: spin 0.8s linear infinite"></div>
  <p class="font-black text-sm uppercase tracking-wider">{text}</p>
</div>

<style>
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>
