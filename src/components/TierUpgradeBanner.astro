<!-- src/components/TierUpgradeBanner.astro -->
<!-- Shows tier upgrade promotion when user is close to next tier -->
<div id="tier-upgrade-banner" class="hidden border-4 border-neon-pink bg-neon-pink p-5 shadow-[4px_4px_0px_0px_#000] mb-4" role="alert" aria-live="polite">
  <div class="flex items-center justify-between flex-wrap gap-3">
    <div class="flex items-center gap-3">
      <span class="text-3xl" id="upgrade-tier-icon">🥈</span>
      <div>
        <p class="font-black text-lg" id="upgrade-tier-title">🎉 Naik Tier Silver!</p>
        <p class="font-bold text-sm" id="upgrade-tier-desc">Kumpulkan 500 point lagi untuk naik tier Silver — dapat diskon 3%!</p>
      </div>
    </div>
    <button id="tier-upgrade-close" class="px-3 py-1 font-black text-xs border-2 border-black bg-white hover:bg-gray-200 transition-all" aria-label="Tutup notifikasi">
      ✕
    </button>
  </div>
  <!-- Progress bar -->
  <div class="mt-3">
    <div class="flex justify-between text-xs font-bold mb-1">
      <span id="current-tier-label">🥉 Bronze</span>
      <span id="next-tier-label">🥈 Silver (5.000 pts)</span>
    </div>
    <div class="w-full h-3 border-2 border-black bg-white overflow-hidden">
      <div id="tier-progress-bar" class="h-full bg-neon-pink transition-all duration-500" style="width: 0%"></div>
    </div>
    <p class="text-xs font-bold text-center mt-1 text-gray-700" id="tier-progress-text">0 / 5.000 pts</p>
  </div>
</div>

<script>
  async function checkTierUpgrade() {
    // Don't show if dismissed
    if (sessionStorage.getItem('tier_banner_dismissed')) return;

    try {
      const resp = await fetch('/api/user/tier-status');
      if (!resp.ok) return;

      const data = await resp.json();
      const lifetime = data.lifetime_points || 0;
      const currentTier = data.tier_level || 'bronze';

      const tiers = [
        { name: 'bronze', min: 0, icon: '🥉', discount: 0 },
        { name: 'silver', min: 5000, icon: '🥈', discount: 3 },
        { name: 'gold', min: 20000, icon: '🥇', discount: 5 },
        { name: 'platinum', min: 50000, icon: '💎', discount: 10 },
      ];

      // Find current tier index and next tier
      const currentIdx = tiers.findIndex(t => t.name === currentTier);
      const nextTier = tiers[currentIdx + 1];

      if (!nextTier) return; // Already platinum

      const nextMin = nextTier.min;
      const currentMin = tiers[currentIdx].min;

      // Show banner if within 25% of next tier
      const distance = nextMin - lifetime;
      const range = nextMin - currentMin;
      const progress = ((lifetime - currentMin) / range) * 100;

      if (progress < 100) {
        const banner = document.getElementById('tier-upgrade-banner');
        const iconEl = document.getElementById('upgrade-tier-icon');
        const titleEl = document.getElementById('upgrade-tier-title');
        const descEl = document.getElementById('upgrade-tier-desc');
        const barEl = document.getElementById('tier-progress-bar');
        const textEl = document.getElementById('tier-progress-text');
        const currentLabelEl = document.getElementById('current-tier-label');
        const nextLabelEl = document.getElementById('next-tier-label');

        if (banner) {
          iconEl.textContent = nextTier.icon;
          titleEl.textContent = `🎉 Naik Tier ${nextTier.name.charAt(0).toUpperCase() + nextTier.name.slice(1)}!`;
          descEl.textContent = `Kumpulkan ${distance.toLocaleString('id-ID')} pt lagi untuk naik tier — dapat diskon ${nextTier.discount}%!`;
          barEl.style.width = Math.min(progress, 100) + '%';
          textEl.textContent = `${lifetime.toLocaleString('id-ID')} / ${nextMin.toLocaleString('id-ID')} pts`;
          currentLabelEl.textContent = tiers[currentIdx].icon + ' ' + tiers[currentIdx].name.charAt(0).toUpperCase() + tiers[currentIdx].name.slice(1);
          nextLabelEl.textContent = nextTier.icon + ' ' + nextTier.name.charAt(0).toUpperCase() + nextTier.name.slice(1) + ' (' + nextMin.toLocaleString('id-ID') + ' pts)';
          banner.classList.remove('hidden');
        }
      }
    } catch (_) {}

    // Dismiss handler
    document.getElementById('tier-upgrade-close')?.addEventListener('click', function() {
      document.getElementById('tier-upgrade-banner')?.classList.add('hidden');
      sessionStorage.setItem('tier_banner_dismissed', '1');
    });
  }

  checkTierUpgrade();
</script>