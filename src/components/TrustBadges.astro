---
/**
 * Trust/Payment Badges Component
 * A row of trust badges as neubrutalism cards with icons.
 */
interface Badge {
  icon: string;
  title: string;
  description: string;
  color: string;
}

const badges: Badge[] = [
  {
    icon: 'M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4',
    title: 'Free Shipping',
    description: 'Gratis ongkir untuk pembelian gear gaming',
    color: '#39FF14',
  },
  {
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
    title: 'Secure Payment',
    description: 'Transaksi aman dengan enkripsi SSL',
    color: '#FF007F',
  },
  {
    icon: 'M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z',
    title: '24/7 Support',
    description: 'Tim support siap membantu kapan saja',
    color: '#FFFF00',
  },
  {
    icon: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z',
    title: '100% Original',
    description: 'Semua produk dijamin original & bergaransi',
    color: '#39FF14',
  },
];
---

<section class="py-12 bg-black border-y-4 border-white dark:bg-[#050505] dark:border-[#27272a]" aria-labelledby="trust-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 id="trust-heading" class="sr-only">Trust Badges</h2>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      {badges.map((badge) => (
        <div
          class="trust-badge flex flex-col items-center text-center p-6 border-4 border-white dark:border-[#27272a] bg-gray-900 dark:bg-[#1a1a1a] shadow-[4px_4px_0px_0px_#333] dark:shadow-[4px_4px_0px_0px_#000] hover:-translate-y-1 hover:shadow-[6px_6px_0px_0px_#39FF14] transition-all duration-150"
        >
          <div
            class="w-14 h-14 flex items-center justify-center border-3 border-white mb-4 shadow-[2px_2px_0px_0px_#000]"
            style={`background:${badge.color};`}
          >
            <svg class="w-7 h-7 text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d={badge.icon} />
            </svg>
          </div>
          <h3 class="font-black uppercase text-white text-sm tracking-wider mb-1">{badge.title}</h3>
          <p class="text-gray-400 text-xs font-bold">{badge.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
