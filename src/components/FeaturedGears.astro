<!-- src/components/FeaturedGears.astro -->
---
interface Gear {
  name: string;
  img: string;
  price: string;
  tag: string;
}
const gears: Gear[] = [
  { name: "Mechanical Keyboard", img: "/assets/keyboard.png", price: "Rp 350.000", tag: "RGB Ready" },
  { name: "Gaming Mouse", img: "/assets/mouse.png", price: "Rp 250.000", tag: "12000 DPI" },
  { name: "RGB Headset", img: "/assets/headset.png", price: "Rp 300.000", tag: "Surround Sound" },
];
---

<section id="gear" class="py-20 bg-neon-yellow text-black border-t-4 border-black">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-5xl font-black uppercase tracking-tighter mb-3">Featured <span class="bg-black text-neon-yellow px-2">Gear</span></h2>
      <p class="text-black/70 font-bold text-lg">Premium peripherals for your setup.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {gears.map((gear) => (
        <article class="group border-4 border-black bg-white shadow-[6px_6px_0px_0px_#000] hover:-translate-y-1 hover:shadow-[8px_8px_0px_0px_#000] transition-all duration-150 cursor-pointer">
          <div class="relative">
            <img src={gear.img} alt={gear.name} class="w-full h-52 object-cover border-b-4 border-black" />
            <span class="absolute top-3 right-3 px-3 py-1 text-xs font-black uppercase tracking-wider border-2 border-black bg-black text-neon-yellow shadow-[2px_2px_0px_0px_#FFE600]">
              {gear.tag}
            </span>
          </div>
          <div class="p-5">
            <h3 class="text-2xl font-black mb-1">{gear.name}</h3>
            <p class="text-gray-500 font-bold text-lg mb-4">{gear.price}</p>
            <button class="w-full py-3 font-black uppercase tracking-wider bg-neon-pink text-white border-2 border-black shadow-[3px_3px_0px_0px_#000] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[1px_1px_0px_0px_#000] transition-all">
              Add to Cart
            </button>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
