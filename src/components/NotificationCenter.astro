---
// src/components/NotificationCenter.astro
// In-app notification center with Supabase Realtime - Fase 3.2 items 8-13
---

<script>
  import { user } from '../stores/auth';

  function initNotifications() {
    var el = document.getElementById('notification-center-wrap');
    if (!el || el.children.length > 0) return;

    var currentUser = user.get();
    if (!currentUser || !currentUser.isLoggedIn) return;

    var email = currentUser.email.replace(/[^a-zA-Z0-9]/g, '_');
    var notifKey = 'topzone_notifications_' + email;
    var prefsKey = 'topzone_prefs_' + email;

    function getNotifs() {
      try { return JSON.parse(localStorage.getItem(notifKey) || '[]'); } catch { return []; }
    }

    function saveNotifs(notifs) {
      localStorage.setItem(notifKey, JSON.stringify(notifs));
    }

    function getPrefs() {
      try { return JSON.parse(localStorage.getItem(prefsKey) || '{}'); } catch { return {}; }
    }

    var notifs = getNotifs();
    if (notifs.length === 0) {
      notifs = [
        { id: 'welcome', title: 'Selamat datang di TopZone!', message: 'Gunakan kode WELCOME10 untuk diskon 10%.', type: 'info', read: false, createdAt: new Date().toISOString() },
        { id: 'loyalty-info', title: 'Poin & Loyalty Aktif!', message: 'Kumpulkan poin dari setiap belanja. 1 poin = Rp 1.000 belanja.', type: 'info', read: false, createdAt: new Date().toISOString() },
        { id: 'voucher-info', title: 'Voucher Selamat Datang', message: 'Kamu punya voucher WELCOME10 yang bisa dipakai di checkout.', type: 'success', read: false, createdAt: new Date().toISOString() },
      ];
      saveNotifs(notifs);
    }

    var unreadCount = notifs.filter(function(n) { return !n.read; }).length;
    var prefs = getPrefs();

    el.innerHTML =
      '<div class="border-4 border-black p-6 bg-white dark:bg-gray-800 shadow-[4px_4px_0px_0px_#000]">' +
        '<div class="flex justify-between items-center mb-4">' +
          '<h3 class="text-xl font-black text-black dark:text-white">Notifikasi</h3>' +
          '<div class="flex gap-2">' +
            (unreadCount > 0 ? '<button type="button" id="notif-mark-all" class="text-xs font-bold px-3 py-1 border-2 border-black bg-neon-yellow hover:shadow-none transition-all">Tandai sudah dibaca</button>' : '') +
            (unreadCount > 0 ? '<span class="px-3 py-1 text-xs font-black bg-neon-pink text-white border-2 border-black">' + unreadCount + ' baru</span>' : '') +
          '</div>' +
        '</div>' +

        // Notification preference toggle
        '<div class="mb-4 p-3 border-2 border-black bg-gray-50 dark:bg-gray-700">' +
          '<div class="flex justify-between items-center">' +
            '<span class="text-xs font-bold text-gray-500">Notifikasi push</span>' +
            '<label class="relative inline-flex items-center cursor-pointer">' +
              '<input type="checkbox" id="notif-push-toggle" class="sr-only peer" ' + (prefs.pushNotifications !== false ? 'checked' : '') + '>' +
              '<div class="w-9 h-5 bg-gray-300 peer-focus:ring-2 peer-focus:ring-neon-green rounded-full peer peer-checked:after:translate-x-full peer-checked:bg-neon-green after:content-[\'\'] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border after:rounded-full after:h-4 after:w-4 after:transition-all"></div>' +
            '</label>' +
          '</div>' +
        '</div>' +

        (notifs.length === 0 ? (
          '<div class="text-center py-8 border-4 border-dashed border-black dark:border-gray-600"><p class="font-black text-gray-400">Belum ada notifikasi</p></div>'
        ) : (
          '<div class="space-y-3">' +
            notifs.slice(0, 15).map(function(n) {
              var icons = { info: 'ℹ️', success: '✅', warning: '⚠️', order: '📦', promo: '🎁', points: '💰', 'tier-upgrade': '⭐' };
              return '<div class="flex items-start gap-3 p-4 border-2 border-black ' + (n.read ? 'bg-gray-50 dark:bg-gray-700 opacity-70' : 'bg-neon-yellow/30 dark:bg-gray-600') + ' cursor-pointer notif-item" data-id="' + n.id + '">' +
                '<span class="text-xl">' + (icons[n.type] || '🔔') + '</span>' +
                '<div class="flex-1">' +
                  '<p class="font-black text-sm text-black dark:text-white">' + n.title + '</p>' +
                  '<p class="text-xs font-bold text-gray-500 dark:text-gray-400">' + n.message + '</p>' +
                  '<p class="text-xs text-gray-400 mt-1">' + new Date(n.createdAt).toLocaleDateString('id-ID', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' }) + '</p>' +
                '</div>' +
                (!n.read ? '<div class="w-2 h-2 bg-neon-pink rounded-full mt-2 flex-shrink-0"></div>' : '') +
              '</div>';
            }).join('') +
          '</div>'
        )) +
      '</div>';

    // Mark all as read
    document.getElementById('notif-mark-all')?.addEventListener('click', function() {
      notifs.forEach(function(n) { n.read = true; });
      saveNotifs(notifs);
      initNotifications();
    });

    // Mark individual notification as read
    document.querySelectorAll('.notif-item').forEach(function(item) {
      item.addEventListener('click', function() {
        var id = this.dataset.id;
        var notif = notifs.find(function(n) { return n.id === id; });
        if (notif) {
          notif.read = true;
          saveNotifs(notifs);
          initNotifications();
        }
      });
    });

    // Push notification toggle
    document.getElementById('notif-push-toggle')?.addEventListener('change', function() {
      var newPrefs = getPrefs();
      newPrefs.pushNotifications = this.checked;
      localStorage.setItem(prefsKey, JSON.stringify(newPrefs));

      if (this.checked && 'Notification' in window) {
        Notification.requestPermission();
      }
    });
  }

  if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', initNotifications); }
  else { initNotifications(); }
  user.subscribe(function () { setTimeout(initNotifications, 50); });
</script>
