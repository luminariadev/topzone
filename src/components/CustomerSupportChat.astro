---
// src/components/CustomerSupportChat.astro
// Floating AI Customer Support Chat Widget - Responsive
---

<!-- CS Chat Widget - Fixed Bottom Right -->
<div id="cs-chat-root">
  <button
    id="cs-toggle-btn"
    class="cs-fab"
    aria-label="Buka Customer Support"
    aria-expanded="false"
  >
    <i class="bi bi-headset"></i>
  </button>

  <div
    id="cs-chat-window"
    class="cs-window"
    aria-hidden="true"
  >
    <!-- Header -->
    <div class="cs-header">
      <div class="cs-header-left">
        <div class="cs-avatar"><i class="bi bi-robot"></i></div>
        <div>
          <p class="cs-name">TopZone Support</p>
          <p class="cs-status">AI + Admin</p>
        </div>
      </div>
      <button id="cs-close-btn" class="cs-close" aria-label="Tutup">
        <i class="bi bi-x-lg"></i>
      </button>
    </div>

    <!-- Messages -->
    <div id="cs-messages" class="cs-body" role="log">
      <div class="cs-msg cs-msg-bot">
        <div class="cs-avatar-sm"><i class="bi bi-robot"></i></div>
        <div class="cs-bubble">
          <p class="cs-text">Halo! 👋 Ada yang bisa saya bantu?</p>
          <p class="cs-sub">Saya asisten AI TopZone. Pilih topik di bawah atau ketik pertanyaan.</p>
        </div>
      </div>
      <div class="cs-quick-replies">
        <button class="cs-qr" data-topic="topup"><i class="bi bi-joystick"></i> Top Up</button>
        <button class="cs-qr" data-topic="gear"><i class="bi bi-pc-display"></i> Gear</button>
        <button class="cs-qr" data-topic="voucher"><i class="bi bi-ticket"></i> Voucher</button>
        <button class="cs-qr" data-topic="order"><i class="bi bi-box"></i> Pesanan</button>
        <button class="cs-qr cs-qr-admin" data-topic="human"><i class="bi bi-person-badge"></i> Admin</button>
      </div>
    </div>

    <!-- Input -->
    <div class="cs-footer">
      <div class="cs-input-row">
        <input type="text" id="cs-input" placeholder="Ketik pesan..." autocomplete="off" />
        <button id="cs-send-btn" aria-label="Kirim"><i class="bi bi-send-fill"></i></button>
      </div>
    </div>
  </div>
</div>

<!-- Typing indicator template -->
<template id="cs-typing-tpl">
  <div class="cs-msg cs-msg-bot">
    <div class="cs-avatar-sm"><i class="bi bi-robot"></i></div>
    <div class="cs-bubble cs-typing-bubble">
      <span class="cs-dot"></span><span class="cs-dot"></span><span class="cs-dot"></span>
    </div>
  </div>
</template>

<style>
/* ── Root container, mobile-first ── */
#cs-chat-root {
  position: fixed;
  bottom: 0; right: 0;
  z-index: 9999;
  font-family: 'Space Grotesk', system-ui, sans-serif;
}

/* ── FAB ── */
.cs-fab {
  position: absolute;
  bottom: 24px; right: 24px;
  width: 60px; height: 60px;
  border-radius: 50%;
  background: #39FF14;
  border: 3px solid #000;
  box-shadow: 4px 4px 0 #000;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all .15s ease;
  z-index: 2;
}
.cs-fab:hover { transform: translateY(-2px); box-shadow: 6px 6px 0 #000; }
.cs-fab i { font-size: 28px; color: #000; }
.cs-fab[aria-expanded="true"] + .cs-window { display: flex; }

/* ── Window ── */
.cs-window {
  display: none;
  position: absolute;
  bottom: 96px; right: 16px;
  width: 360px; max-width: calc(100vw - 32px);
  height: 540px; max-height: calc(100vh - 128px);
  flex-direction: column;
  background: #fff;
  border: 3px solid #000;
  box-shadow: 8px 8px 0 #000;
  border-radius: 12px;
  overflow: hidden;
  animation: cs-slideUp .25s ease-out;
}

@keyframes cs-slideUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

/* ── Mobile responsive ── */
@media (max-width: 480px) {
  .cs-fab { bottom: 16px; right: 16px; width: 54px; height: 54px; }
  .cs-fab i { font-size: 24px; }
  .cs-window {
    bottom: 84px; right: 8px;
    width: calc(100vw - 16px);
    height: calc(100vh - 160px);
    max-height: none;
    border-radius: 8px;
  }
}

/* ── Header ── */
.cs-header {
  background: #000;
  color: #fff;
  padding: 14px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
}
.cs-header-left { display: flex; align-items: center; gap: 10px; }
.cs-avatar, .cs-avatar-sm {
  width: 36px; height: 36px; border-radius: 50%;
  background: #39FF14; display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.cs-avatar i, .cs-avatar-sm i { font-size: 18px; color: #000; }
.cs-avatar-sm { width: 28px; height: 28px; }
.cs-avatar-sm i { font-size: 14px; }
.cs-name { font-weight: 900; font-size: 14px; }
.cs-status { font-size: 11px; color: #aaa; }
.cs-close {
  width: 32px; height: 32px; border-radius: 6px;
  background: rgba(255,255,255,.1); border: none;
  color: #fff; font-size: 16px; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
}
.cs-close:hover { background: rgba(255,255,255,.2); }

/* ── Body ── */
.cs-body {
  flex: 1; overflow-y: auto; padding: 14px;
  display: flex; flex-direction: column; gap: 12px;
  background: #f5f5f5;
}
.dark .cs-body { background: #1f2937; }

/* ── Message row ── */
.cs-msg { display: flex; gap: 8px; animation: cs-fadeIn .2s ease-out; }
.cs-msg.cs-msg-user { flex-direction: row-reverse; }
@keyframes cs-fadeIn { from { opacity:0; transform:translateY(6px); } to { opacity:1; transform:translateY(0); } }

.cs-bubble {
  padding: 10px 14px; border-radius: 12px;
  max-width: 80%; word-wrap: break-word;
  border: 2px solid #000;
}
.cs-msg-bot .cs-bubble {
  background: #fff; border-top-left-radius: 2px;
}
.dark .cs-msg-bot .cs-bubble { background: #374151; }
.cs-msg-user .cs-bubble {
  background: #000; color: #fff; border-top-right-radius: 2px;
}
.cs-text { font-size: 14px; font-weight: 500; line-height: 1.4; }
.cs-sub { font-size: 12px; color: #666; margin-top: 4px; }
.dark .cs-sub { color: #aaa; }

/* ── Typing ── */
.cs-typing-bubble { display: flex; gap: 4px; align-items: center; padding: 12px 16px; }
.cs-dot {
  width: 8px; height: 8px; border-radius: 50%; background: #999;
  animation: cs-bounce 1.4s ease-in-out infinite;
}
.cs-dot:nth-child(2) { animation-delay: .16s; }
.cs-dot:nth-child(3) { animation-delay: .32s; }
@keyframes cs-bounce { 0%,80%,100% { transform: scale(0); } 40% { transform: scale(1); } }

/* ── Quick replies ── */
.cs-quick-replies {
  display: flex; flex-wrap: wrap; gap: 6px;
  padding: 4px 0;
}
.cs-qr {
  padding: 6px 14px; font-size: 12px; font-weight: 900;
  background: #FFE600; border: 2px solid #000; border-radius: 20px;
  cursor: pointer; transition: all .12s;
  display: inline-flex; align-items: center; gap: 4px;
}
.cs-qr:hover { background: #e6d000; transform: translateY(-1px); }
.cs-qr-admin { background: #FF007F; color: #fff; }
.cs-qr-admin:hover { background: #d4006a; }

/* ── Followup buttons (injected) ── */
.cs-fup {
  display: inline-block; padding: 4px 10px; margin: 2px;
  font-size: 11px; font-weight: 700;
  background: rgba(0,0,0,.06); border: 1px solid #999; border-radius: 12px;
  cursor: pointer; transition: background .12s;
}
.cs-fup:hover { background: rgba(0,0,0,.14); }

/* ── Footer ── */
.cs-footer {
  border-top: 2px solid #000; padding: 10px 14px;
  background: #fafafa; flex-shrink: 0;
}
.dark .cs-footer { background: #374151; }
.cs-input-row { display: flex; gap: 8px; }
.cs-input-row input {
  flex: 1; padding: 10px 14px; font-size: 14px; font-weight: 500;
  border: 2px solid #000; border-radius: 8px;
  outline: none; background: #fff;
}
.dark .cs-input-row input { background: #4b5563; color: #fff; }
.cs-input-row input:focus { box-shadow: 0 0 0 2px #39FF14; }
.cs-input-row button {
  width: 44px; height: 44px; border-radius: 8px;
  background: #000; color: #39FF14; border: 2px solid #000;
  font-size: 18px; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: background .12s;
}
.cs-input-row button:hover { background: #222; }

/* ── Scrollbar ── */
.cs-body::-webkit-scrollbar { width: 4px; }
.cs-body::-webkit-scrollbar-thumb { background: #bbb; border-radius: 2px; }
.dark .cs-body::-webkit-scrollbar-thumb { background: #555; }
</style>

<script>
(function(){
  var root = document.getElementById('cs-chat-root');
  var fab = document.getElementById('cs-toggle-btn');
  var win = document.getElementById('cs-chat-window');
  var close = document.getElementById('cs-close-btn');
  var msgs = document.getElementById('cs-messages');
  var input = document.getElementById('cs-input');
  var send = document.getElementById('cs-send-btn');
  var qrs = root.querySelectorAll('.cs-qr');
  var tpl = document.getElementById('cs-typing-tpl');

  var opened = false, mid = 0;

  var KB = {
    topup: { t:'🎮 Top Up Game', r:'Pilih game di halaman utama → pilih paket diamond/UC → klik tambah ke keranjang → checkout dan bayar. Saldo masuk dalam hitungan menit!' },
    gear: { t:'💻 Beli Gear', r:'Browse di halaman Gear → filter kategori (keyboard, mouse, headset) → pilih produk → tambah ke keranjang → checkout. Gratis ongkir > Rp 500.000!' },
    voucher: { t:'🎟 Voucher & Promo', r:'User baru: WELCOME10 (diskon 10%, min Rp 50.000). Masukkan kode di halaman checkout lalu klik "Pakai". Cek Promo untuk flash sale!' },
    order: { t:'📦 Cek Pesanan', r:'Login → Profil → tab "Riwayat Pesanan". Top up selesai < 1 jam. Gear dikirim 1-3 hari. Notifikasi via email.' },
    human: { t:'👤 Admin', r:'Menghubungkan dengan admin...<br><br><strong>⏱ 5-15 menit (09:00-21:00 WIB)</strong>' }
  };

  function addMsg(html, user){
    var d = document.createElement('div');
    d.className = 'cs-msg ' + (user ? 'cs-msg-user' : 'cs-msg-bot');
    var a = user
      ? '<div class="cs-avatar-sm" style="background:#FF007F"><i class="bi bi-person-fill" style="color:#fff"></i></div>'
      : '<div class="cs-avatar-sm"><i class="bi bi-robot"></i></div>';
    d.innerHTML = a + '<div class="cs-bubble">' + html + '</div>';
    msgs.appendChild(d);
    msgs.scrollTop = msgs.scrollHeight;
  }

  function showTyping(){
    var c = tpl.content.cloneNode(true);
    c.firstElementChild.id = 'cs-typing';
    msgs.appendChild(c);
    msgs.scrollTop = msgs.scrollHeight;
  }

  function hideTyping(){
    var e = document.getElementById('cs-typing');
    if(e) e.remove();
  }

  function botReply(topic){
    var k = KB[topic]; if(!k) return;
    hideTyping();
    if(topic === 'human'){
      addMsg(k.r, false);
      setTimeout(function(){
        addMsg('<div style="display:flex;align-items:center;gap:6px;margin-bottom:6px"><i class="bi bi-person-badge-fill" style="color:#39FF14"></i> <strong style="color:#39FF14">Admin TopZone</strong></div><p style="margin:0;font-size:14px">Halo! Ada yang bisa saya bantu terkait pesanan atau kendala Anda?</p>', false);
      },1500);
    } else {
      var fups = '<div style="margin-top:8px;display:flex;flex-wrap:wrap;gap:4px">'
        + '<button class="cs-fup" data-t="topup">Top Up</button>'
        + '<button class="cs-fup" data-t="order">Pesanan</button>'
        + '<button class="cs-fup" data-t="human">Admin</button></div>';
      addMsg('<strong style="font-size:14px">' + k.t + '</strong><p style="margin:6px 0 0;font-size:14px">' + k.r + '</p>' + fups, false);
    }
  }

  function userSaid(text){
    var l = text.toLowerCase();
    var t = 'topup';
    if(l.includes('gear')||l.includes('keyboard')||l.includes('mouse')||l.includes('headset')) t='gear';
    else if(l.includes('voucher')||l.includes('promo')||l.includes('diskon')||l.includes('kode')) t='voucher';
    else if(l.includes('pesanan')||l.includes('order')||l.includes('status')||l.includes('tracking')) t='order';
    else if(l.includes('admin')||l.includes('operator')||l.includes('manusia')) t='human';
    addMsg(text, true);
    showTyping();
    setTimeout(function(){ botReply(t); }, 700 + Math.random()*1000);
  }

  // ── Event listeners ──
  fab.addEventListener('click', function(){
    opened = !opened;
    win.setAttribute('aria-hidden', String(!opened));
    if(opened){ win.style.display = 'flex'; input.focus(); }
    else win.style.display = 'none';
  });

  close.addEventListener('click', function(){ opened = false; win.style.display = 'none'; win.setAttribute('aria-hidden','true'); });

  send.addEventListener('click', function(){
    var v = input.value.trim(); if(!v) return;
    input.value = ''; userSaid(v);
  });
  input.addEventListener('keydown', function(e){ if(e.key==='Enter' && !e.shiftKey){ e.preventDefault(); send.click(); } });

  qrs.forEach(function(b){ b.addEventListener('click', function(){ userSaid(b.textContent.trim()); }); });

  msgs.addEventListener('click', function(e){
    var t = e.target.closest('.cs-fup');
    if(t) userSaid(t.textContent.trim());
  });
})();
</script>
