---
interface Props {
  variant?: 'white' | 'green' | 'pink' | 'yellow' | 'transparent';
  class?: string;
  interactive?: boolean;
  [key: string]: any;
}

const {
  variant = 'white',
  class: className = '',
  interactive = false,
  ...rest
} = Astro.props;

const bgColors = {
  white: 'bg-white text-black',
  green: 'bg-neon-green text-black',
  pink: 'bg-neon-pink text-white',
  yellow: 'bg-neon-yellow text-black',
  transparent: 'bg-transparent text-black',
};
---

<div
  class:list={[
    'p-6 border-4 border-black rounded-none shadow-[6px_6px_0px_0px_#000000] transition-all duration-200',
    bgColors[variant],
    interactive && 'hover:-translate-x-[2px] hover:-translate-y-[2px] hover:shadow-[8px_8px_0px_0px_#000000] active:translate-x-[1px] active:translate-y-[1px] active:shadow-[4px_4px_0px_0px_#000000] cursor-pointer',
    className
  ]}
  {...rest}
>
  <slot />
</div>
