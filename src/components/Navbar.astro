<!-- src/components/Navbar.astro -->
---
import Button from './Button.astro';
import CartIcon from './CartIcon.astro';
import ThemeToggle from './ThemeToggle.astro';
import SearchBar from './SearchBar.astro';
---

<header class="border-b border-gray-200 bg-white sticky top-0 z-50 dark:bg-[#111] dark:border-[#27272a]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="text-2xl md:text-3xl font-black tracking-tight hover:skew-x-2 transition-transform inline-block">
      &#x1F3AE; TOP<span class="bg-neon-yellow px-2 border-2 border-black shadow-[2px_2px_0px_0px_#000000]">ZONE</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-6" aria-label="Navigasi utama">
      <a href="/#hero" class="font-bold text-black dark:text-gray-200 hover:text-neon-pink transition-colors">Home</a>
      <a href="/#games" class="font-bold text-black dark:text-gray-200 hover:text-neon-pink transition-colors">Games</a>
      <a href="/#gear" class="font-bold text-black dark:text-gray-200 hover:text-neon-pink transition-colors">Gear</a>
      <a href="/#promo" class="font-bold text-black dark:text-gray-200 hover:text-neon-pink transition-colors">Promo</a>
      <a href="/guide" class="font-bold text-black dark:text-gray-200 hover:text-neon-pink transition-colors"><i class="bi bi-book me-1"></i>Panduan</a>
    </nav>
    <SearchBar />

    <!-- Right: Auth + Cart + Theme + Hamburger -->
    <div class="flex items-center gap-3">
      <div id="auth-desktop" class="hidden md:flex items-center gap-2"></div>
      <CartIcon />
      <ThemeToggle />
      <button
        id="hamburger-btn"
        class="md:hidden flex flex-col gap-[5px] p-2 border-2 border-black dark:border-gray-600 bg-white dark:bg-gray-800 shadow-[2px_2px_0px_0px_#000] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="block w-5 h-0.5 bg-black dark:bg-white transition-all duration-200" id="ham-line-1"></span>
        <span class="block w-5 h-0.5 bg-black dark:bg-white transition-all duration-200" id="ham-line-2"></span>
        <span class="block w-5 h-0.5 bg-black dark:bg-white transition-all duration-200" id="ham-line-3"></span>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-200 bg-white dark:bg-[#111] dark:border-[#27272a] text-black dark:text-gray-200" role="navigation" aria-label="Menu mobile">
    <nav class="flex flex-col p-4 gap-3">
      <a href="/#hero" class="font-bold py-2 border-b-2 border-black/10 dark:border-gray-600 text-black dark:text-gray-200 hover:text-neon-pink transition-colors">Home</a>
      <a href="/#games" class="font-bold py-2 border-b-2 border-black/10 dark:border-gray-600 text-black dark:text-gray-200 hover:text-neon-pink transition-colors">Games</a>
      <a href="/#gear" class="font-bold py-2 border-b-2 border-black/10 dark:border-gray-600 text-black dark:text-gray-200 hover:text-neon-pink transition-colors">Gear</a>
      <a href="/#promo" class="font-bold py-2 border-b-2 border-black/10 dark:border-gray-600 text-black dark:text-gray-200 hover:text-neon-pink transition-colors">Promo</a>
      <a href="/guide" class="font-bold py-2 border-b-2 border-black/10 dark:border-gray-600 text-black dark:text-gray-200 hover:text-neon-pink transition-colors"><i class="bi bi-book me-1"></i>Panduan</a>

      <div id="auth-mobile" class="flex flex-col gap-2 mt-2"></div>
    </nav>
  </div>
</header>

<script>
  import { user, logoutUser } from '../stores/auth';

  function renderAuth(currentUser) {
    const desktop = document.getElementById('auth-desktop');
    const mobile = document.getElementById('auth-mobile');
    if (!desktop || !mobile) return;

    let notifBadge = '';
    if (currentUser) {
      try {
        const email = currentUser.email.replace(/[^a-zA-Z0-9]/g, '_');
        const notifs = JSON.parse(localStorage.getItem('topzone_notifications_' + email) || '[]');
        const unread = notifs.filter(function(n) { return !n.read; }).length;
        if (unread > 0) {
          notifBadge = '<a href="/profile#notifications" class="relative px-2 py-1 font-black text-sm border-2 border-black bg-neon-pink text-white hover:bg-black hover:text-white transition-all">Notif<span class="absolute -top-1 -right-1 w-4 h-4 text-[10px] font-black bg-white text-neon-pink border-2 border-black rounded-full flex items-center justify-center">' + unread + '</span></a>';
        }
      } catch(e) {}
    }

    if (currentUser) {
      const displayName = currentUser.full_name || currentUser.email || 'User';
      desktop.innerHTML = notifBadge +
        '<span class="text-sm font-bold text-gray-500 mr-1">' + displayName + '</span>' +
        '<a href="/profile" class="px-3 py-1 font-black text-sm border-2 border-black hover:bg-black hover:text-white transition-all">Profil</a>' +
        '<button id="logout-btn-desk" class="px-3 py-1 font-black text-sm border-2 border-black bg-neon-yellow hover:bg-black hover:text-white transition-all">Logout</button>';
      mobile.innerHTML = notifBadge + '<span class="font-bold text-sm text-gray-500 px-1">' + displayName + '</span>' +
        '<a href="/profile" class="w-full text-center px-3 py-2 font-black text-sm border-2 border-black hover:bg-black hover:text-white transition-all">Profil</a>' +
        '<button id="logout-btn-mobile" class="w-full px-3 py-2 font-black text-sm border-2 border-black bg-neon-yellow hover:bg-black hover:text-white transition-all">Logout</button>';
      document.getElementById('logout-btn-desk')?.addEventListener('click', logout);
      document.getElementById('logout-btn-mobile')?.addEventListener('click', logout);
    } else {
      desktop.innerHTML = '<a href="/login" class="px-3 py-1 font-black text-sm border-2 border-black hover:bg-black hover:text-white transition-all">Masuk</a>' +
        '<a href="/register" class="px-3 py-1 font-black text-sm bg-neon-yellow border-2 border-black shadow-[2px_2px_0px_0px_#000] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">Daftar</a>';
      mobile.innerHTML = '<a href="/login" class="w-full text-center px-3 py-2 font-black text-sm border-2 border-black hover:bg-black hover:text-white transition-all">Masuk</a>' +
        '<a href="/register" class="w-full text-center px-3 py-2 font-black text-sm bg-neon-yellow border-2 border-black shadow-[2px_2px_0px_0px_#000] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">Daftar</a>';
    }
  }

  function logout() {
    logoutUser();
    window.location.href = '/';
  }

  // Mobile hamburger menu toggle
  function initMobileMenu() {
    const btn = document.getElementById('hamburger-btn');
    const menu = document.getElementById('mobile-menu');
    const line1 = document.getElementById('ham-line-1');
    const line2 = document.getElementById('ham-line-2');
    const line3 = document.getElementById('ham-line-3');
    if (!btn || !menu) return;

    btn.addEventListener('click', () => {
      const open = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!open));
      menu.classList.toggle('hidden');

      // Animate hamburger → X
      if (line1 && line2 && line3) {
        if (!open) {
          line1.style.transform = 'rotate(45deg) translate(4px, 4px)';
          line2.style.opacity = '0';
          line3.style.transform = 'rotate(-45deg) translate(4px, -4px)';
        } else {
          line1.style.transform = '';
          line2.style.opacity = '';
          line3.style.transform = '';
        }
      }
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      if (!btn.contains(e.target as Node) && !menu.contains(e.target as Node)) {
        btn.setAttribute('aria-expanded', 'false');
        menu.classList.add('hidden');
        if (line1 && line2 && line3) {
          line1.style.transform = '';
          line2.style.opacity = '';
          line3.style.transform = '';
        }
      }
    });
  }

  // Subscribe ke user atom ? auto re-render setiap kali auth state berubah
  user.subscribe(renderAuth);
  document.addEventListener('astro:page-load', initMobileMenu);
  initMobileMenu();
</script>





