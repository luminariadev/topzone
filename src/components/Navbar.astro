<!-- src/components/Navbar.astro -->
---
import Button from './Button.astro';
import CartIcon from './CartIcon.astro';
---

<header class="border-b-4 border-black bg-white sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="text-2xl md:text-3xl font-black tracking-tight hover:skew-x-2 transition-transform inline-block">
      &#x1F3AE; TOP<span class="bg-neon-yellow px-2 border-2 border-black shadow-[2px_2px_0px_0px_#000000]">ZONE</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-6">
      <a href="/#hero" class="font-bold hover:text-neon-pink transition-colors">Home</a>
      <a href="/#games" class="font-bold hover:text-neon-pink transition-colors">Games</a>
      <a href="/#gear" class="font-bold hover:text-neon-pink transition-colors">Gear</a>
      <a href="/#promo" class="font-bold hover:text-neon-pink transition-colors">Promo</a>
      <a href="/orders" class="font-bold hover:text-neon-pink transition-colors">Pesanan</a>
    </nav>

    <!-- Right: Auth + Cart + Hamburger -->
    <div class="flex items-center gap-3">
      <div id="auth-desktop" class="hidden md:flex items-center gap-2"></div>
      <CartIcon />
      <button
        id="hamburger-btn"
        class="md:hidden flex flex-col gap-[5px] p-2 border-2 border-black bg-white shadow-[2px_2px_0px_0px_#000] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <span class="block w-5 h-0.5 bg-black transition-all duration-200" id="ham-line-1"></span>
        <span class="block w-5 h-0.5 bg-black transition-all duration-200" id="ham-line-2"></span>
        <span class="block w-5 h-0.5 bg-black transition-all duration-200" id="ham-line-3"></span>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t-4 border-black bg-white">
    <nav class="flex flex-col p-4 gap-3">
      <a href="/#hero" class="font-bold py-2 border-b-2 border-black/10 hover:text-neon-pink transition-colors">Home</a>
      <a href="/#games" class="font-bold py-2 border-b-2 border-black/10 hover:text-neon-pink transition-colors">Games</a>
      <a href="/#gear" class="font-bold py-2 border-b-2 border-black/10 hover:text-neon-pink transition-colors">Gear</a>
      <a href="/#promo" class="font-bold py-2 border-b-2 border-black/10 hover:text-neon-pink transition-colors">Promo</a>
      <a href="/orders" class="font-bold hover:text-neon-pink transition-colors">Pesanan</a>
      <div id="auth-mobile" class="flex flex-col gap-2 mt-2"></div>
    </nav>
  </div>
</header>

<script>
  import { supabase } from '../lib/supabase';
  import { user, setLocalUser, logoutUser, setLoading } from '../stores/auth';

  function renderAuth(userData) {
    const desktop = document.getElementById('auth-desktop');
    const mobile = document.getElementById('auth-mobile');
    if (!desktop || !mobile) return;

    if (userData) {
      const displayName = userData.user_metadata?.full_name || userData.email;
      desktop.innerHTML = '<span class="text-sm font-bold text-gray-500 mr-1">' + displayName + '</span>' +
        '<button id="logout-btn-desk" class="px-3 py-1 font-black text-sm border-2 border-black hover:bg-black hover:text-white transition-all">Logout</button>';
      mobile.innerHTML = '<span class="font-bold text-sm text-gray-500 px-1">' + displayName + '</span>' +
        '<button id="logout-btn-mobile" class="w-full px-3 py-2 font-black text-sm border-2 border-black hover:bg-black hover:text-white transition-all">Logout</button>';
      document.getElementById('logout-btn-desk')?.addEventListener('click', logout);
      document.getElementById('logout-btn-mobile')?.addEventListener('click', logout);
    } else {
      desktop.innerHTML = '<a href="/login" class="px-3 py-1 font-black text-sm border-2 border-black hover:bg-black hover:text-white transition-all">Masuk</a>' +
        '<a href="/register" class="px-3 py-1 font-black text-sm bg-neon-yellow border-2 border-black shadow-[2px_2px_0px_0px_#000] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">Daftar</a>';
      mobile.innerHTML = '<a href="/login" class="w-full text-center px-3 py-2 font-black text-sm border-2 border-black hover:bg-black hover:text-white transition-all">Masuk</a>' +
        '<a href="/register" class="w-full text-center px-3 py-2 font-black text-sm bg-neon-yellow border-2 border-black shadow-[2px_2px_0px_0px_#000] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">Daftar</a>';
    }
  }

  async function logout() {
    await supabase.auth.signOut();
    window.location.href = '/';
  }

  (async () => {
    setLoading(true);
    const { data: { session } } = await supabase.auth.getSession();
    const currentUser = session?.user ?? null;
    setUser(currentUser);
    renderAuth(currentUser);
    setLoading(false);
    supabase.auth.onAuthStateChange((event, newSession) => {
      const newUser = newSession?.user ?? null;
      setUser(newUser);
      renderAuth(newUser);
    });
  })();
</script>





