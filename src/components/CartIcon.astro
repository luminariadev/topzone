<!-- src/components/CartIcon.astro -->
---
// Cart icon with reactive badge — uses nanostores via client script
---

<a href="/cart" id="cart-link" class="relative inline-flex items-center justify-center w-10 h-10 border-2 border-black bg-white dark:bg-gray-800 dark:text-white shadow-[2px_2px_0px_0px_#000] hover:-translate-y-[1px] hover:shadow-[3px_3px_0px_0px_#000] transition-all" aria-label="Cart" title="Lihat keranjang belanja">
  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-1.5 6h11"/>
    <circle cx="9" cy="21" r="1" fill="currentColor"/>
    <circle cx="19" cy="21" r="1" fill="currentColor"/>
  </svg>
  <span
    id="cart-badge"
    class="absolute -top-2 -right-2 hidden min-w-[1.2rem] h-5 px-1 bg-neon-pink text-white text-xs font-black border-2 border-black flex items-center justify-center"
    aria-live="polite"
    aria-atomic="true"
  ><span id="cart-badge-text" aria-hidden="true">0</span></span>
</a>

<script>
  import { cartCount } from '../stores/cart';

  const badge = document.getElementById('cart-badge');
  if (badge) {
    const badgeText = document.getElementById('cart-badge-text');
    cartCount.subscribe((count) => {
      if (count > 0) {
        if (badgeText) badgeText.textContent = String(count);
        badge.textContent = String(count); // maintain aria-live region
        badge.classList.remove('hidden');
        badge.classList.add('flex');
      } else {
        badge.classList.add('hidden');
        badge.classList.remove('flex');
      }
    });
  }
</script>
