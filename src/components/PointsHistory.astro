// src/components/PointsHistory.astro
// Points history and loyalty tier display for user profile

---
interface Props {
  userId?: string;
}

const { userId } = Astro.props;
---

<section id="points-history-section" class="p-6 border-4 border-black dark:border-gray-600 bg-white dark:bg-[#111]" aria-labelledby="points-heading">
  <div class="flex items-center justify-between mb-6">
    <h3 id="points-heading" class="text-2xl font-black uppercase tracking-tighter">
      ⭐ <span class="bg-neon-green px-2 border-2 border-black dark:border-gray-600 text-black">Points</span> & Loyalty
    </h3>
    <span id="tier-badge" class="px-3 py-1 text-sm font-black border-2 border-black dark:border-gray-400 bg-black text-white">🥉 BRONZE</span>
  </div>

  <!-- Points Balance Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
    <div class="p-4 border-4 border-black dark:border-gray-600 bg-neon-green dark:bg-gray-800">
      <div class="text-xs font-black uppercase tracking-wider mb-1">Points Tersedia</div>
      <div id="points-balance" class="text-3xl font-black" aria-live="polite">0</div>
    </div>
    <div class="p-4 border-4 border-black dark:border-gray-600 bg-neon-yellow dark:bg-gray-800">
      <div class="text-xs font-black uppercase tracking-wider mb-1">Seumur Hidup</div>
      <div id="lifetime-points" class="text-3xl font-black">0</div>
    </div>
    <div class="p-4 border-4 border-black dark:border-gray-600 bg-neon-pink dark:bg-gray-800 text-white">
      <div class="text-xs font-black uppercase tracking-wider mb-1">Diskon Member</div>
      <div id="member-discount" class="text-3xl font-black">0%</div>
    </div>
  </div>

  <!-- Tier Progress Bar -->
  <div class="mb-6 p-4 border-4 border-black dark:border-gray-600 bg-gray-50 dark:bg-gray-900">
    <div class="flex items-center justify-between mb-2">
      <span class="font-black text-sm uppercase tracking-wider">Progress ke Tier Berikutnya</span>
      <span id="next-tier-name" class="font-black text-sm bg-black text-neon-yellow px-2 py-0.5">🥈 SILVER</span>
    </div>
    <div class="w-full h-6 border-2 border-black dark:border-gray-600 bg-white dark:bg-gray-800 overflow-hidden" role="progressbar" id="tier-progress-bar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
      <div id="tier-progress-fill" class="h-full bg-neon-green transition-all duration-500" style="width: 0%"></div>
    </div>
    <p id="tier-progress-text" class="text-xs font-bold text-gray-500 dark:text-gray-400 mt-1">
      Butuh 5.000 points untuk naik ke Silver
    </p>
  </div>

  <!-- Points History -->
  <div class="mb-4">
    <div class="flex items-center justify-between mb-3">
      <h4 class="font-black text-sm uppercase tracking-wider">Riwayat Points</h4>
      <button id="refresh-points-btn" class="px-3 py-1 text-xs font-black border-2 border-black dark:border-gray-600 hover:bg-black hover:text-white transition-all" aria-label="Refresh points history">
        ↻ Refresh
      </button>
    </div>
    <div id="points-history-list" class="space-y-2" aria-live="polite" aria-atomic="false">
      <!-- Example skeleton items, replaced by client script -->
      <div class="p-3 border-2 border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 animate-pulse">
        <div class="h-4 bg-gray-200 dark:bg-gray-700 w-3/4 rounded mb-2"></div>
        <div class="h-3 bg-gray-200 dark:bg-gray-700 w-1/2 rounded"></div>
      </div>
      <div class="p-3 border-2 border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 animate-pulse">
        <div class="h-4 bg-gray-200 dark:bg-gray-700 w-2/3 rounded mb-2"></div>
        <div class="h-3 bg-gray-200 dark:bg-gray-700 w-1/3 rounded"></div>
      </div>
    </div>
  </div>

  <!-- Birthday Bonus -->
  <div id="birthday-section" class="hidden p-4 border-4 border-neon-pink dark:border-gray-600 bg-neon-pink/10 dark:bg-gray-900">
    <div class="flex items-center gap-3">
      <span class="text-4xl">🎂</span>
      <div>
        <p class="font-black text-sm uppercase tracking-wider">Birthday Bonus!</p>
        <p id="birthday-message" class="text-sm font-bold text-gray-600 dark:text-gray-400">
          Selamat ulang tahun! Kamu mendapatkan bonus points spesial.
        </p>
      </div>
      <span id="birthday-points" class="ml-auto text-2xl font-black text-neon-pink">+0</span>
    </div>
  </div>
</section>

<script>
  async function initPointsHistory() {
    const balanceEl = document.getElementById('points-balance');
    const lifetimeEl = document.getElementById('lifetime-points');
    const discountEl = document.getElementById('member-discount');
    const tierBadge = document.getElementById('tier-badge');
    const historyList = document.getElementById('points-history-list');
    const progressFill = document.getElementById('tier-progress-fill');
    const progressText = document.getElementById('tier-progress-text');
    const nextTierName = document.getElementById('next-tier-name');
    const progressBar = document.getElementById('tier-progress-bar');
    const birthdaySection = document.getElementById('birthday-section');
    const birthdayMessage = document.getElementById('birthday-message');
    const birthdayPoints = document.getElementById('birthday-points');

    async function fetchPoints() {
      try {
        const resp = await fetch('/api/user/points');
        if (!resp.ok) return;
        const data = await resp.json();

        if (balanceEl) balanceEl.textContent = (data.points_balance || 0).toLocaleString('id-ID');
        if (lifetimeEl) lifetimeEl.textContent = (data.lifetime_points || 0).toLocaleString('id-ID');
        if (discountEl) discountEl.textContent = (data.tier_discount || 0) + '%';

        // Tier badge
        const tier = (data.tier_level || 'bronze').toUpperCase();
        const badges = { BRONZE: '🥉', SILVER: '🥈', GOLD: '🥇', PLATINUM: '💎' };
        const badge = badges[tier] || '🥉';
        if (tierBadge) tierBadge.textContent = badge + ' ' + tier;

        // Tier progress
        const nextTier = data.next_tier || null;
        const pointsNeeded = data.points_needed || 0;
        const lifetime = data.lifetime_points || 0;

        if (progressFill && progressBar) {
          if (nextTier === null) {
            // Already max tier
            progressFill.style.width = '100%';
            progressFill.classList.remove('bg-neon-green');
            progressFill.classList.add('bg-neon-pink');
            if (progressText) progressText.textContent = '🏆 Kamu sudah mencapai tier tertinggi!';
          } else {
            const totalNeeded = data.next_tier_min || pointsNeeded + lifetime;
            const percentage = totalNeeded > 0 ? Math.min(100, Math.round((lifetime / totalNeeded) * 100)) : 0;
            progressFill.style.width = percentage + '%';
            progressBar.setAttribute('aria-valuenow', String(percentage));
            if (progressText) progressText.textContent = `Butuh ${pointsNeeded.toLocaleString('id-ID')} points untuk naik ke ${nextTier}`;
          }
        }
        if (nextTierName && nextTier) {
          const tierBadges = { bronze: '🥉', silver: '🥈', gold: '🥇', platinum: '💎' };
          nextTierName.textContent = (tierBadges[nextTier.toLowerCase()] || '') + ' ' + nextTier.toUpperCase();
        }

        // Birthday bonus check
        if (data.birthday_bonus && data.birthday_bonus.eligible && birthdaySection) {
          birthdaySection.classList.remove('hidden');
          if (birthdayMessage) birthdayMessage.textContent = data.birthday_bonus.message || 'Happy Birthday!';
          if (birthdayPoints) birthdayPoints.textContent = '+' + (data.birthday_bonus.amount || 0);
        }

        // Points history
        if (data.history && historyList) {
          if (data.history.length === 0) {
            historyList.innerHTML = '<p class="text-sm text-gray-500 dark:text-gray-400 p-3 border-2 border-dashed border-gray-300 dark:border-gray-600">Belum ada riwayat points.</p>';
          } else {
            historyList.innerHTML = data.history.map(h => {
              const isPositive = h.points > 0;
              const date = new Date(h.created_at).toLocaleDateString('id-ID');
              return `
                <div class="flex items-center justify-between p-3 border-2 border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900">
                  <div class="flex-1 min-w-0">
                    <p class="font-bold text-sm">${h.description || h.reason || '-'}</p>
                    <p class="text-xs text-gray-500 dark:text-gray-400">${date}</p>
                  </div>
                  <span class="font-black ml-2 ${isPositive ? 'text-neon-green' : 'text-neon-pink'}">${isPositive ? '+' : ''}${h.points.toLocaleString('id-ID')}</span>
                </div>
              `;
            }).join('');
          }
        }
      } catch (e) {
        console.warn('[PointsHistory] Error fetching:', e);
        if (historyList) {
          historyList.innerHTML = '<p class="text-sm text-red-500 font-bold">Gagal memuat riwayat points.</p>';
        }
      }
    }

    // Initial load
    fetchPoints();

    // Refresh button
    document.getElementById('refresh-points-btn')?.addEventListener('click', fetchPoints);
  }

  document.addEventListener('astro:page-load', initPointsHistory);
  initPointsHistory();
</script>