<!-- src/components/ThemeToggle.astro -->
<button
  id="theme-toggle"
  class="w-10 h-10 border-2 border-black bg-white dark:bg-gray-800 dark:text-white shadow-[2px_2px_0px_0px_#000] hover:-translate-y-[1px] hover:shadow-[3px_3px_0px_0px_#000] transition-all flex items-center justify-center"
  aria-label="Toggle dark mode"
>
  <!-- Sun icon (shown in dark mode) -->
  <svg id="theme-sun" class="hidden w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
    <circle cx="12" cy="12" r="5" /><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
  </svg>
  <!-- Moon icon (shown in light mode) -->
  <svg id="theme-moon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
</button>

<script>
  import { currentTheme, toggleTheme, applyThemeToDocument } from '../stores/theme';

  const btn = document.getElementById('theme-toggle')!;
  const sun = document.getElementById('theme-sun')!;
  const moon = document.getElementById('theme-moon')!;

  function updateIcons(t: string) {
    const show = t === 'dark';
    sun.classList.toggle('hidden', !show);
    moon.classList.toggle('hidden', show);
  }

  applyThemeToDocument(currentTheme.get());
  updateIcons(currentTheme.get());

  btn.addEventListener('click', () => {
    toggleTheme();
    setTimeout(() => {
      applyThemeToDocument(currentTheme.get());
      updateIcons(currentTheme.get());
    }, 0);
  });

  currentTheme.subscribe((t) => {
    applyThemeToDocument(t);
    updateIcons(t);
  });
</script>
