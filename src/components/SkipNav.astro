---
// SkipNav.astro
// Skip navigation component: appears on keyboard focus for screen reader users
---

<a
  href="#main-content"
  id="skip-nav"
  class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[9999]
         px-6 py-3 border-4 border-black bg-neon-yellow text-black
         font-black text-sm uppercase tracking-wider shadow-[4px_4px_0px_0px_#000]"
  aria-label="Lompat ke konten utama"
>
  ⬇ Lompat ke konten utama
</a>

<script>
  // Ensure skip link works with Astro's view transitions
  function initSkipNav() {
    const skipLink = document.getElementById('skip-nav');
    if (!skipLink) return;

    skipLink.addEventListener('click', (e) => {
      e.preventDefault();
      const main = document.getElementById('main-content');
      if (main) {
        main.setAttribute('tabindex', '-1');
        main.focus();
        // Remove tabindex after focus to avoid breaking DOM semantics
        setTimeout(() => main.removeAttribute('tabindex'), 100);
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });
  }

  document.addEventListener('astro:page-load', initSkipNav);
  initSkipNav();
</script>
