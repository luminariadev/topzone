---
// src/components/Skeleton.astro
// Skeleton loading component for async content placeholders

interface Props {
  variant?: 'card' | 'text' | 'image' | 'list';
  lines?: number;
  width?: string;
  height?: string;
  count?: number;
}

const { variant = 'text', lines = 1, width = '100%', height = '1rem', count = 1 } = Astro.props;

const skeletons = Array.from({ length: count });
---

{skeletons.map((_, i) => {
  switch (variant) {
    case 'card':
      return (
        <div class="border-4 border-black dark:border-gray-600 bg-white dark:bg-[#1a1a1a] p-0 overflow-hidden animate-pulse">
          <div class="bg-gray-200 dark:bg-gray-700 h-52 w-full" style="aspect-ratio: 4/3"></div>
          <div class="p-5 space-y-3">
            <div class="bg-gray-200 dark:bg-gray-700 h-6 w-3/4 rounded"></div>
            <div class="bg-gray-200 dark:bg-gray-700 h-4 w-1/2 rounded"></div>
          </div>
        </div>
      );
    case 'image':
      return (
        <div class="bg-gray-200 dark:bg-gray-700 animate-pulse rounded" style={{ width, height, aspectRatio: '4/3' }}></div>
      );
    case 'list':
      return (
        <div class="space-y-3">
          {Array.from({ length: lines }).map((_, j) => (
            <div
              class="bg-gray-200 dark:bg-gray-700 h-4 animate-pulse rounded"
              style={{ width: j === lines - 1 ? '60%' : '100%' }}
            ></div>
          ))}
        </div>
      );
    default:
      return (
        <div class="bg-gray-200 dark:bg-gray-700 animate-pulse rounded" style={{ width, height }}></div>
      );
  }
})}