<div class="border-4 border-black p-6 bg-white dark:bg-gray-800 shadow-[4px_4px_0px_0px_#000]">
  <h2 class="text-2xl font-black mb-6 text-black dark:text-white">🤝 Program Referral</h2>

  <div id="referral-loading" class="text-center py-10">
    <p class="font-bold text-gray-500">Memuat data referral...</p>
  </div>

  <div id="referral-content" class="hidden">
    <div class="mb-6">
      <p class="text-sm font-black uppercase tracking-wider mb-2 text-black dark:text-white">Kode Referralmu</p>
      <div class="flex items-center gap-2">
        <input type="text" id="referral-code-display" readonly class="flex-1 px-4 py-3 border-3 border-black font-bold text-lg shadow-[3px_3px_0px_0px_#000] bg-gray-100 dark:bg-gray-700 dark:text-white" />
        <button id="copy-referral-code" class="px-4 py-3 font-black uppercase border-2 border-black bg-neon-green shadow-[3px_3px_0px_0px_#000] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">Salin</button>
      </div>
      <p class="text-xs font-bold text-gray-500 dark:text-gray-400 mt-2">Bagikan kode ini ke temanmu dan dapatkan bonus!</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
      <div class="border-2 border-black p-4 bg-gray-50 dark:bg-gray-700 shadow-[2px_2px_0px_0px_#000] text-center">
        <p class="text-xs font-black uppercase tracking-wider text-gray-500 dark:text-gray-300">Total Referral</p>
        <p class="text-2xl font-black text-black dark:text-white" id="total-referrals">0</p>
      </div>
      <div class="border-2 border-black p-4 bg-gray-50 dark:bg-gray-700 shadow-[2px_2px_0px_0px_#000] text-center">
        <p class="text-xs font-black uppercase tracking-wider text-gray-500 dark:text-gray-300">Referral Selesai</p>
        <p class="text-2xl font-black text-neon-green" id="completed-referrals">0</p>
      </div>
      <div class="border-2 border-black p-4 bg-gray-50 dark:bg-gray-700 shadow-[2px_2px_0px_0px_#000] text-center">
        <p class="text-xs font-black uppercase tracking-wider text-gray-500 dark:text-gray-300">Total Hadiah</p>
        <p class="text-2xl font-black text-neon-pink" id="total-reward">Rp 0</p>
      </div>
    </div>

    <button id="regenerate-referral-code" class="px-6 py-3 font-black uppercase border-2 border-black bg-red-400 text-white shadow-[3px_3px_0px_0px_#000] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">
      Regenerate Code
    </button>
    <p class="text-xs font-bold text-gray-500 dark:text-gray-400 mt-2">Hanya lakukan ini jika kodemu bocor atau butuh kode baru.</p>
  </div>
</div>

<script>
  import { user } from '../stores/auth';

  const referralLoading = document.getElementById('referral-loading');
  const referralContent = document.getElementById('referral-content');
  const referralCodeDisplay = document.getElementById('referral-code-display');
  const totalReferrals = document.getElementById('total-referrals');
  const completedReferrals = document.getElementById('completed-referrals');
  const totalReward = document.getElementById('total-reward');
  const copyReferralCodeBtn = document.getElementById('copy-referral-code');
  const regenerateReferralCodeBtn = document.getElementById('regenerate-referral-code');

  function formatRp(n) {
    return 'Rp ' + Number(n).toLocaleString('id-ID');
  }

  async function fetchReferralData() {
    const currentUser = user.get();
    if (!currentUser || !currentUser.isLoggedIn) {
      referralLoading.textContent = 'Login diperlukan untuk melihat data referral.';
      return;
    }

    try {
      const response = await fetch('/api/auth/referral-code');
      const data = await response.json();

      if (response.ok) {
        referralCodeDisplay.value = data.code;
        totalReferrals.textContent = data.total_referrals;
        completedReferrals.textContent = data.completed_referrals;
        totalReward.textContent = formatRp(data.total_reward);
        referralContent?.classList.remove('hidden');
      } else {
        throw new Error(data.error || 'Failed to fetch referral data');
      }
    } catch (error) {
      console.error('Error fetching referral data:', error);
      referralLoading.textContent = 'Gagal memuat data referral: ' + error.message;
    } finally {
      referralLoading?.classList.add('hidden');
    }
  }

  copyReferralCodeBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(referralCodeDisplay.value);
      alert('Kode referral disalin!');
    } catch (err) {
      console.error('Failed to copy: ', err);
      alert('Gagal menyalin kode.');
    }
  });

  regenerateReferralCodeBtn?.addEventListener('click', async () => {
    if (!confirm('Apakah kamu yakin ingin me-regenerate kode referral? Kode lama akan tidak berlaku.')) {
      return;
    }
    regenerateReferralCodeBtn.disabled = true;
    regenerateReferralCodeBtn.textContent = 'Regenerating...';
    try {
      const response = await fetch('/api/auth/referral-code', {
        method: 'POST',
      });
      const data = await response.json();

      if (response.ok) {
        alert('Kode referral berhasil di-regenerate!');
        fetchReferralData(); // Reload data
      } else {
        throw new Error(data.error || 'Failed to regenerate referral code');
      }
    } catch (error) {
      console.error('Error regenerating referral code:', error);
      alert('Gagal me-regenerate kode referral: ' + error.message);
    } finally {
      regenerateReferralCodeBtn.disabled = false;
      regenerateReferralCodeBtn.textContent = 'Regenerate Code';
    }
  });

  user.subscribe(fetchReferralData);
  fetchReferralData();
</script>