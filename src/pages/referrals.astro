---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Referral - TopZone" description="Ajak teman dan dapatkan bonus!" canonical="https://topzone.id/referrals" robots="noindex, nofollow">
  <Navbar />

  <section class="py-16 min-h-screen bg-white dark:bg-gray-900" aria-label="Referral Program">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-5xl font-black mb-2">Referral <span style="color:#39FF14; -webkit-text-stroke:1px #000;">Program</span></h1>
      <p class="text-gray-500 font-medium mb-10">Ajak teman, dapatkan bonus point!</p>

      <!-- Login Required -->
      <div id="ref-login-required" class="hidden text-center py-24 border-4 border-dashed border-black">
        <div class="text-6xl mb-4">🔒</div>
        <p class="text-2xl font-black mb-2">Login Diperlukan</p>
        <p class="text-gray-500 font-bold mb-6">Login dulu untuk lihat kode referral kamu.</p>
        <a href="/login?redirect=/referrals" class="inline-block px-8 py-3 font-black uppercase border-2 border-black bg-neon-green shadow-[3px_3px_0px_0px_#000] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">Masuk Sekarang</a>
      </div>

      <!-- Referral Content -->
      <div id="ref-content" class="hidden">
        <!-- Referral Code Box -->
        <div class="border-4 border-black p-6 bg-neon-yellow shadow-[4px_4px_0px_0px_#000] mb-6">
          <h2 class="text-2xl font-black mb-2">Kode Referral Kamu</h2>
          <div class="flex items-center gap-3 mt-4">
            <code id="ref-code" class="flex-1 px-4 py-3 bg-white border-3 border-black font-black text-2xl text-center tracking-widest">-</code>
            <button id="copy-ref" class="px-4 py-3 font-black border-2 border-black bg-white hover:bg-neon-green transition-all">Copy</button>
          </div>
          <p class="text-sm font-bold text-gray-600 mt-3">Share link ini: <span id="ref-link" class="text-neon-green underline text-xs break-all"></span></p>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
          <div class="border-2 border-black p-4 bg-white shadow-[3px_3px_0px_0px_#000] text-center">
            <div class="text-3xl font-black" style="color:#39FF14;" id="ref-total">0</div>
            <div class="text-sm font-bold">Total Referral</div>
          </div>
          <div class="border-2 border-black p-4 bg-white shadow-[3px_3px_0px_0px_#000] text-center">
            <div class="text-3xl font-black text-neon-yellow" id="ref-pending">0</div>
            <div class="text-sm font-bold">Pending</div>
          </div>
          <div class="border-2 border-black p-4 bg-white shadow-[3px_3px_0px_0px_#000] text-center">
            <div class="text-3xl font-black text-neon-pink" id="ref-earned">0</div>
            <div class="text-sm font-bold">Points Diterima</div>
          </div>
        </div>

        <!-- Referral History -->
        <div id="ref-history" class="space-y-3"></div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const loginRequired = document.getElementById('ref-login-required');
  const contentEl = document.getElementById('ref-content');
  const codeEl = document.getElementById('ref-code');
  const linkEl = document.getElementById('ref-link');
  const copyBtn = document.getElementById('copy-ref');
  const totalEl = document.getElementById('ref-total');
  const pendingEl = document.getElementById('ref-pending');
  const earnedEl = document.getElementById('ref-earned');
  const historyEl = document.getElementById('ref-history');

  async function loadReferral() {
    try {
      // Get referral code
      const codeResp = await fetch('/api/auth/referral-code');
      if (codeResp.status === 401) {
        loginRequired?.classList.remove('hidden');
        return;
      }
      const codeData = await codeResp.json();
      const code = codeData.code || 'ERROR';
      codeEl.textContent = code;
      linkEl.textContent = window.location.origin + '/register?ref=' + code;

      // Get referral stats
      const trackResp = await fetch('/api/auth/referral-track');
      const trackData = await trackResp.json();
      const refs = trackData.referrals || [];

      totalEl.textContent = refs.length;
      pendingEl.textContent = refs.filter(r => r.status === 'pending').length;
      earnedEl.textContent = refs.reduce((sum, r) => sum + (r.reward_points || 0), 0);

      if (refs.length > 0) {
        historyEl.innerHTML = '<h3 class="text-xl font-black mb-3 mt-6">Riwayat Referral</h3>' +
          refs.map(r => `
            <div class="border-2 border-black p-4 bg-white flex justify-between items-center">
              <div>
                <p class="font-bold">${r.referred_email || r.referred_id || 'Teman'}</p>
                <p class="text-sm text-gray-500">${new Date(r.created_at).toLocaleDateString('id-ID')}</p>
              </div>
              <span class="px-3 py-1 font-black text-xs uppercase border-2 border-black ${r.status === 'completed' ? 'bg-neon-green' : r.status === 'registered' ? 'bg-neon-yellow' : 'bg-gray-200'}">
                ${r.status === 'completed' ? '✅ Selesai' : r.status === 'registered' ? '📝 Daftar' : '⏳ Pending'}
              </span>
            </div>
          `).join('');
      } else {
        historyEl.innerHTML = '<p class="text-center py-8 font-bold text-gray-500">Belum ada referral. Ajak teman sekarang!</p>';
      }

      contentEl?.classList.remove('hidden');
    } catch (err) {
      contentEl?.classList.remove('hidden');
      codeEl.textContent = 'Gagal memuat';
    }
  }

  copyBtn?.addEventListener('click', () => {
    const code = codeEl.textContent;
    if (code && code !== 'Gagal memuat') {
      navigator.clipboard.writeText(code).then(() => {
        copyBtn.textContent = 'Copied!';
        setTimeout(() => { copyBtn.textContent = 'Copy'; }, 2000);
      });
    }
  });

  loadReferral();
</script>
