---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Lupa Password - TopZone" description="Reset password akun TopZone kamu dengan mudah." canonical="https://topzone.id/forgot-password" robots="noindex, nofollow">
  <Navbar />

  <section class="min-h-screen flex items-center justify-center bg-neon-yellow dark:bg-gray-900 py-16 px-4">
    <div class="w-full max-w-md">
      <div class="border-4 border-black bg-white dark:bg-gray-800 p-8 shadow-[8px_8px_0px_0px_#000]">
        <div class="text-center mb-8">
          <h1 class="text-4xl font-black mb-2 text-black dark:text-white">🔑 Lupa <span style="color:#39FF14; -webkit-text-stroke:1px #000;">Password</span></h1>
          <p class="font-bold text-gray-600 dark:text-gray-300">Masukkan email, kami kirim link reset.</p>
        </div>

        <!-- Forgot Password Form -->
        <form id="forgot-form" class="space-y-5">
          <div id="form-error" class="hidden bg-red-500 text-white font-black px-4 py-3 border-2 border-black text-sm"></div>
          <div id="form-success" class="hidden bg-neon-green text-black font-black px-4 py-3 border-2 border-black text-sm"></div>

          <div>
            <label for="email" class="block text-sm font-black uppercase tracking-wider mb-2 text-black dark:text-gray-200">
              Email
            </label>
            <input
              type="email"
              id="email"
              required
              placeholder="nama@email.com"
              class="w-full px-4 py-3 border-3 border-black font-bold text-lg shadow-[3px_3px_0px_0px_#000] focus:shadow-none focus:translate-x-[2px] focus:translate-y-[2px] outline-none transition-all"
              autocomplete="email"
            />
          </div>

          <button
            type="submit"
            id="send-btn"
            class="w-full py-4 font-black uppercase tracking-wider text-lg bg-black text-neon-green border-4 border-black shadow-[4px_4px_0px_0px_#39FF14] hover:-translate-y-1 hover:shadow-[6px_6px_0px_0px_#39FF14] active:translate-y-0 active:shadow-[2px_2px_0px_0px_#39FF14] transition-all"
          >
            Kirim Link Reset
          </button>
        </form>

        <p class="text-center mt-6 font-bold text-sm text-gray-500">
          <a href="/login" class="underline hover:text-neon-green">← Kembali ke Login</a>
        </p>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('forgot-form');
  const emailInput = document.getElementById('email');
  const sendBtn = document.getElementById('send-btn');
  const errorEl = document.getElementById('form-error');
  const successEl = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl?.classList.add('hidden');
    successEl?.classList.add('hidden');
    sendBtn.disabled = true;
    sendBtn.textContent = 'Mengirim...';

    try {
      const resp = await fetch('/api/email/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          to: emailInput.value,
          subject: 'Reset Password - TopZone',
          template: 'password-reset',
          data: {
            customer_name: emailInput.value.split('@')[0],
            token: 'demo-token-' + Date.now(),
            reset_link: window.location.origin + '/auth/reset-password?token=' + Date.now(),
          },
        }),
      });

      const result = await resp.json();

      if (resp.ok && result.success) {
        successEl.textContent = '✅ Link reset password telah dikirim ke email kamu. Cek inbox/spam!';
        successEl?.classList.remove('hidden');
        emailInput.value = '';
      } else {
        errorEl.textContent = '❌ ' + (result.error || 'Gagal mengirim email. Coba lagi.');
        errorEl?.classList.remove('hidden');
      }
    } catch (err) {
      errorEl.textContent = '❌ Terjadi kesalahan jaringan. Coba lagi.';
      errorEl?.classList.remove('hidden');
    } finally {
      sendBtn.disabled = false;
      sendBtn.textContent = 'Kirim Link Reset';
    }
  });
</script>
