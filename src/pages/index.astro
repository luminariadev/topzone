---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
---

<Layout>
  <div class="min-h-screen bg-white text-black flex flex-col">
    <!-- Header -->
    <header class="border-b-4 border-black bg-white sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
        <a href="/" class="text-2xl md:text-3xl font-black tracking-tight hover:skew-x-2 transition-transform inline-block">
          🎮 TOP<span class="bg-neon-yellow px-2 border-2 border-black shadow-[2px_2px_0px_0px_#000000]">ZONE</span>
        </a>
        <nav class="hidden md:flex space-x-6 items-center">
          <a href="#games" class="font-bold hover:text-neon-pink transition-colors">Games</a>
          <a href="#gear" class="font-bold hover:text-neon-pink transition-colors">Gears</a>
          <a href="#about" class="font-bold hover:text-neon-pink transition-colors">About</a>
        </nav>
        <div class="flex items-center space-x-3">
          <Button variant="white" size="sm" class="hidden sm:inline-flex">Sign In</Button>
          <Button variant="green" size="sm">Get Started</Button>
        </div>
      </div>
    </header>

    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center flex-grow">
      <div class="lg:col-span-7 space-y-6">
        <div class="inline-block bg-neon-pink text-white text-xs md:text-sm font-bold uppercase tracking-widest px-3 py-1 border-2 border-black shadow-[2px_2px_0px_0px_#000000]">
          PRO GAMING STOREFRONT
        </div>
        <h1 class="text-4xl sm:text-6xl md:text-7xl font-black tracking-tight leading-none">
          LEVEL UP YOUR <br/>
          <span class="bg-neon-green px-2 border-4 border-black inline-block my-2 shadow-[6px_6px_0px_0px_#000000]">GAMING GEAR</span><br/>
          & TOP-UP INSTANTLY
        </h1>
        <p class="text-base sm:text-lg md:text-xl font-medium max-w-xl text-neutral-700">
          The ultimate high-octane hub for direct-to-player game currencies, premium top-ups, and state-of-the-art physical mechanical keyboards, mice, and accessories.
        </p>
        <div class="flex flex-wrap gap-4 pt-4">
          <Button variant="pink" size="lg" href="#games">Top-Up Now</Button>
          <Button variant="yellow" size="lg" href="#gear">Browse Gears</Button>
        </div>
      </div>
      <div class="lg:col-span-5 flex justify-center">
        <!-- Interactive Showcase Card -->
        <Card variant="yellow" class="w-full max-w-md relative overflow-hidden" interactive>
          <div class="absolute top-2 right-2 bg-black text-neon-green text-xs font-bold px-2 py-1 uppercase border border-white">
            Live Promo
          </div>
          <h3 class="text-2xl font-black uppercase mb-2">⚡ WEEKEND DEAL!</h3>
          <p class="font-bold text-neutral-800 mb-6">
            Get up to <span class="bg-black text-neon-green px-1">20% Cashback</span> on all Mobile Legends diamond packages.
          </p>
          <div class="border-t-4 border-black pt-4 flex justify-between items-center bg-white p-4 border-2">
            <div>
              <p class="text-xs font-bold text-neutral-500 uppercase">Use Promo Code</p>
              <p class="text-lg font-black tracking-wider text-black">TOPZONE20</p>
            </div>
            <Button variant="black" size="sm">Claim</Button>
          </div>
        </Card>
      </div>
    </section>

    <!-- Component Demo Grid -->
    <section id="games" class="bg-neutral-50 border-t-4 border-b-4 border-black py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center space-y-4 mb-12">
          <h2 class="text-3xl md:text-5xl font-black uppercase tracking-tight">
            🎮 Popular Gaming Top-Ups
          </h2>
          <p class="text-sm md:text-base font-bold text-neutral-600 max-w-lg mx-auto">
            Choose your game, enter your player ID, and get direct top-ups delivered in seconds.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Game Card 1 -->
          <Card variant="white" interactive class="flex flex-col justify-between">
            <div>
              <div class="w-full h-40 bg-neon-green border-4 border-black flex items-center justify-center mb-4 relative overflow-hidden">
                <span class="text-6xl select-none">🔥</span>
              </div>
              <h3 class="text-xl font-black uppercase mb-1">Mobile Legends</h3>
              <p class="text-xs font-bold text-neutral-500 uppercase mb-4">Diamonds & Starlight</p>
              <p class="text-sm font-medium text-neutral-700 mb-6">
                Fast, secure top-ups with instant processing directly to your MLBB account.
              </p>
            </div>
            <Button variant="green" class="w-full">Top Up</Button>
          </Card>

          <!-- Game Card 2 -->
          <Card variant="white" interactive class="flex flex-col justify-between">
            <div>
              <div class="w-full h-40 bg-neon-pink border-4 border-black flex items-center justify-center mb-4 relative overflow-hidden">
                <span class="text-6xl select-none">🔫</span>
              </div>
              <h3 class="text-xl font-black uppercase mb-1">Valorant</h3>
              <p class="text-xs font-bold text-neutral-500 uppercase mb-4">Valorant Points</p>
              <p class="text-sm font-medium text-neutral-700 mb-6">
                Buy Valorant Points (VP) instantly to unlock skins, battle passes, and agents.
              </p>
            </div>
            <Button variant="pink" class="w-full">Top Up</Button>
          </Card>

          <!-- Game Card 3 -->
          <Card variant="white" interactive class="flex flex-col justify-between">
            <div>
              <div class="w-full h-40 bg-neon-yellow border-4 border-black flex items-center justify-center mb-4 relative overflow-hidden">
                <span class="text-6xl select-none">🏆</span>
              </div>
              <h3 class="text-xl font-black uppercase mb-1">Free Fire</h3>
              <p class="text-xs font-bold text-neutral-500 uppercase mb-4">Diamonds & Membership</p>
              <p class="text-sm font-medium text-neutral-700 mb-6">
                Top up FF Diamonds easily. Enter UID, select quantity, and check out instantly.
              </p>
            </div>
            <Button variant="yellow" class="w-full">Top Up</Button>
          </Card>
        </div>
      </div>
    </section>

    <!-- Physical Gear Section -->
    <section id="gear" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="text-center space-y-4 mb-12">
        <h2 class="text-3xl md:text-5xl font-black uppercase tracking-tight">
          ⚙️ Premium Gaming Gears
        </h2>
        <p class="text-sm md:text-base font-bold text-neutral-600 max-w-lg mx-auto">
          Equip yourself with the best hardware built to withstand intense gaming sessions.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Gear 1 -->
        <Card variant="white" interactive class="flex flex-col md:flex-row gap-6 items-center">
          <div class="w-full md:w-1/2 h-48 bg-black border-4 border-black text-white flex items-center justify-center">
            <span class="text-7xl select-none">⌨️</span>
          </div>
          <div class="w-full md:w-1/2 space-y-3">
            <span class="bg-black text-neon-yellow text-xs font-black uppercase px-2 py-0.5 border border-white">
              Hot Item
            </span>
            <h3 class="text-2xl font-black uppercase">CyberKey TKL</h3>
            <p class="text-xs font-bold text-neutral-500 uppercase">Mechanical Keyboard</p>
            <p class="text-sm font-medium text-neutral-700">
              Gateron Yellow Switches, PBT Neubrutalist Keycaps, Hotswappable PCB.
            </p>
            <div class="flex items-center justify-between pt-2">
              <span class="text-xl font-black">$129.99</span>
              <Button variant="yellow" size="sm">Add to Cart</Button>
            </div>
          </div>
        </Card>

        <!-- Gear 2 -->
        <Card variant="white" interactive class="flex flex-col md:flex-row gap-6 items-center">
          <div class="w-full md:w-1/2 h-48 bg-neon-green border-4 border-black flex items-center justify-center">
            <span class="text-7xl select-none">🖱️</span>
          </div>
          <div class="w-full md:w-1/2 space-y-3">
            <span class="bg-black text-neon-green text-xs font-black uppercase px-2 py-0.5 border border-white">
              Wireless
            </span>
            <h3 class="text-2xl font-black uppercase">ApexGlide Pro</h3>
            <p class="text-xs font-bold text-neutral-500 uppercase">Gaming Mouse</p>
            <p class="text-sm font-medium text-neutral-700">
              26K DPI Optical Sensor, Ultra-lightweight 54g design, Snappy switches.
            </p>
            <div class="flex items-center justify-between pt-2">
              <span class="text-xl font-black">$79.99</span>
              <Button variant="green" size="sm">Add to Cart</Button>
            </div>
          </div>
        </Card>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t-4 border-black bg-black text-white py-12 mt-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="text-xl font-black">
          🎮 TOP<span class="bg-neon-yellow text-black px-2 border-2 border-white ml-1">ZONE</span>
        </div>
        <p class="text-sm text-neutral-400 font-medium">
          &copy; 2026 TopZone Platform. All rights reserved.
        </p>
        <div class="flex space-x-4">
          <a href="#" class="text-sm font-bold hover:text-neon-pink transition-colors">Privacy Policy</a>
          <a href="#" class="text-sm font-bold hover:text-neon-pink transition-colors">Terms of Service</a>
        </div>
      </div>
    </footer>
  </div>
</Layout>
