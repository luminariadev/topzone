---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Voucher Saya - TopZone" description="Lihat dan gunakan voucher kamu" canonical="https://topzone.id/vouchers" robots="noindex, nofollow">
  <Navbar />

  <section class="py-16 min-h-screen bg-white dark:bg-gray-900" aria-label="Voucher Saya">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-5xl font-black mb-2">Voucher <span style="color:#39FF14; -webkit-text-stroke:1px #000;">Saya</span></h1>
      <p class="text-gray-500 font-medium mb-10">Voucher dan promo eksklusif untuk kamu.</p>

      <!-- Login Required -->
      <div id="voucher-login-required" class="hidden text-center py-24 border-4 border-dashed border-black">
        <div class="text-6xl mb-4">🔒</div>
        <p class="text-2xl font-black mb-2">Login Diperlukan</p>
        <p class="text-gray-500 font-bold mb-6">Login dulu untuk lihat voucher kamu.</p>
        <a href="/login?redirect=/vouchers" class="inline-block px-8 py-3 font-black uppercase border-2 border-black bg-neon-green shadow-[3px_3px_0px_0px_#000] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">Masuk Sekarang</a>
      </div>

      <!-- Empty State -->
      <div id="voucher-empty" class="hidden text-center py-24 border-4 border-dashed border-black">
        <div class="text-6xl mb-4">🎟️</div>
        <p class="text-2xl font-black mb-2">Belum Ada Voucher</p>
        <p class="text-gray-500 font-bold mb-6">Kamu belum memiliki voucher. Ajak teman pakai kode referral dapat voucher!</p>
        <a href="/" class="inline-block px-8 py-3 font-black uppercase border-2 border-black bg-neon-yellow shadow-[3px_3px_0px_0px_#000] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">Mulai Belanja</a>
      </div>

      <!-- Voucher Grid -->
      <div id="voucher-list" class="hidden grid gap-4">
        <!-- Template card, populated by JS -->
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const loginRequired = document.getElementById('voucher-login-required');
  const emptyEl = document.getElementById('voucher-empty');
  const listEl = document.getElementById('voucher-list');

  async function loadVouchers() {
    try {
      const resp = await fetch('/api/user/vouchers');
      if (resp.status === 401) {
        loginRequired?.classList.remove('hidden');
        return;
      }
      const data = await resp.json();
      const vouchers = data.vouchers || [];

      if (vouchers.length === 0) {
        emptyEl?.classList.remove('hidden');
        return;
      }

      listEl?.classList.remove('hidden');
      listEl.innerHTML = vouchers.map((v, i) => {
        const expired = v.expires_at && new Date(v.expires_at) < new Date();
        const used = v.status === 'used';
        return `
          <div class="border-4 border-black p-5 bg-white shadow-[4px_4px_0px_0px_#000] ${expired || used ? 'opacity-50' : ''}" data-index="${i}">
            <div class="flex justify-between items-start">
              <div>
                <h3 class="text-2xl font-black mb-1">${v.vouchers?.code || v.code || 'VOUCHER'}</h3>
                <p class="text-sm font-bold text-gray-500">${v.vouchers?.description || v.description || 'Diskon spesial untuk kamu!'}</p>
              </div>
              <span class="px-3 py-1 font-black text-sm uppercase border-2 border-black ${expired ? 'bg-gray-200 text-gray-500' : used ? 'bg-red-200 text-red-700' : 'bg-neon-green text-black'}">
                ${used ? 'Terpakai' : expired ? 'Kadaluarsa' : 'Aktif'}
              </span>
            </div>
            <div class="mt-3 flex gap-4 text-sm font-bold text-gray-500">
              ${v.vouchers?.discount_percent ? `<span>Diskon: ${v.vouchers.discount_percent}%</span>` : ''}
              ${v.vouchers?.min_purchase ? `<span>Min. Belanja: Rp ${Number(v.vouchers.min_purchase).toLocaleString('id-ID')}</span>` : ''}
              ${v.expires_at ? `<span>Berlaku sampai: ${new Date(v.expires_at).toLocaleDateString('id-ID')}</span>` : ''}
            </div>
          </div>
        `;
      }).join('');
    } catch (err) {
      emptyEl?.classList.remove('hidden');
      emptyEl.querySelector('p:last-child') && (emptyEl.querySelector('p:last-child').textContent = 'Gagal memuat voucher.');
    }
  }

  loadVouchers();
</script>
