---
// src/pages/games/[slug].astro
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/Button.astro';
import { fetchGames } from '../../lib/products';
import type { Game } from '../../data/games';
export async function getStaticPaths() {
  const games = await fetchGames();
  return games.map((game) => ({
    params: { slug: game.slug },
    props: { game },
  }));
}

interface Props { game: Game; }
const { game } = Astro.props;
---

<Layout>
  <Navbar />

  <!-- Hero Banner -->
  <section class="relative h-64 md:h-80 flex items-end bg-black overflow-hidden border-b-4 border-black">
    <img src={game.img} alt={game.name} class="absolute inset-0 w-full h-full object-cover opacity-50" />
    <div class="absolute inset-0 bg-gradient-to-t from-black/90 to-transparent"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-8 w-full">
      <span class="inline-block px-3 py-1 text-xs font-black uppercase tracking-widest border-2 border-black shadow-[2px_2px_0px_0px_#000] mb-3" style={`background:${game.color}; color:#000;`}>
        {game.badge}
      </span>
      <h1 class="text-4xl md:text-6xl font-black text-white mb-2">{game.name}</h1>
      <p class="text-gray-300 font-medium max-w-xl">{game.description}</p>
    </div>
  </section>

  <!-- Package Grid -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-black mb-2">Pilih Paket <span style={`color:${game.color}; -webkit-text-stroke:1px #000;`}>{game.currency}</span></h2>
      <p class="text-gray-500 font-medium mb-8">Klik paket untuk menambahkan ke keranjang belanja.</p>

      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4" id="package-grid">
        {game.packages.map((pkg) => (
          <button
            class="package-btn border-4 border-black p-4 bg-white text-left shadow-[4px_4px_0px_0px_#000] hover:-translate-y-1 hover:shadow-[6px_6px_0px_0px_#000] active:translate-y-0 active:shadow-[2px_2px_0px_0px_#000] transition-all cursor-pointer"
            data-id={pkg.id}
            data-name={`${game.name} — ${pkg.label}`}
            data-price={pkg.price}
            data-img={game.img}
          >
            <div class="text-lg font-black mb-1">{pkg.label}</div>
            <div class="text-2xl font-black" style={`color:${game.color}; -webkit-text-stroke:1px #000;`}>
              Rp {pkg.price.toLocaleString('id-ID')}
            </div>
          </button>
        ))}
      </div>

      <!-- Toast notification -->
      <div id="add-toast" class="hidden fixed bottom-6 right-6 z-50 bg-black text-neon-green font-black px-5 py-3 border-4 border-neon-green shadow-[4px_4px_0px_0px_#39FF14]">
        ✓ Ditambahkan ke keranjang!
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ -->
  <!-- REVIEWS & RATINGS -->
  <!-- ═══════════════════════════════════════════════════ -->
  <section class="py-12 bg-gray-50 border-t-4 border-black">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-black mb-2">⭐ Ulasan & Rating</h2>
      <p class="text-gray-500 font-medium mb-6">Kata para pembeli tentang game ini.</p>

      <!-- Average Rating -->
      <div class="border-4 border-black bg-white p-5 shadow-[4px_4px_0px_0px_#000] mb-6">
        <div class="flex items-center gap-6">
          <div class="text-center">
            <span class="text-5xl font-black" id="avg-rating">0</span>
            <span class="text-2xl">/5</span>
            <div class="text-lg" id="avg-stars">☆☆☆☆☆</div>
            <span class="text-sm font-bold text-gray-500" id="review-count">0 ulasan</span>
          </div>
          <div class="flex-1">
            <div id="rating-bars" class="space-y-1"></div>
          </div>
        </div>
      </div>

      <!-- Review Form -->
      <div id="review-form-section" class="hidden border-4 border-black bg-neon-yellow p-5 shadow-[4px_4px_0px_0px_#000] mb-6">
        <h3 class="font-black text-lg mb-3">✍️ Tulis Ulasan</h3>
        <div class="flex gap-1 text-3xl mb-3" id="star-rating">
          <span class="star cursor-pointer hover:scale-110 transition-transform" data-val="1">☆</span>
          <span class="star cursor-pointer hover:scale-110 transition-transform" data-val="2">☆</span>
          <span class="star cursor-pointer hover:scale-110 transition-transform" data-val="3">☆</span>
          <span class="star cursor-pointer hover:scale-110 transition-transform" data-val="4">☆</span>
          <span class="star cursor-pointer hover:scale-110 transition-transform" data-val="5">☆</span>
        </div>
        <textarea id="review-text" rows="3" class="w-full px-4 py-3 border-3 border-black font-bold text-sm shadow-[3px_3px_0px_0px_#000] focus:shadow-none focus:translate-x-[1px] focus:translate-y-[1px] outline-none transition-all" placeholder="Bagikan pengalamanmu..."></textarea>
        <button id="submit-review" class="mt-3 px-6 py-3 font-black border-2 border-black bg-black text-white shadow-[3px_3px_0px_0px_#000] hover:shadow-none hover:translate-x-[1px] hover:translate-y-[1px] transition-all">Kirim Ulasan</button>
        <p id="review-status" class="mt-2 text-sm font-bold hidden"></p>
      </div>

      <!-- Login Prompt -->
      <div id="review-login-prompt" class="hidden border-4 border-dashed border-black p-6 text-center mb-6">
        <p class="font-black text-lg mb-2">🔒 Login untuk memberi ulasan</p>
        <a href="/login" class="inline-block px-6 py-2 font-black border-2 border-black bg-neon-green shadow-[2px_2px_0px_0px_#000]">Masuk</a>
      </div>

      <!-- Purchase Required -->
      <div id="review-purchase-prompt" class="hidden border-4 border-dashed border-black p-6 text-center mb-6">
        <p class="font-black text-lg mb-2">🎮 Beli game ini dulu untuk memberi ulasan!</p>
      </div>

      <!-- Reviews List -->
      <div id="reviews-list" class="space-y-4"></div>
      <div id="reviews-empty" class="text-center py-8 border-4 border-dashed border-black">
        <p class="text-lg font-black text-gray-400">Belum ada ulasan. Jadilah yang pertama!</p>
      </div>
    </div>
  </section>
  <Footer />
<script>
  const productSlug = window.location.pathname.split('/').pop();
  const STORAGE_REVIEWS = 'topzone_reviews';

  function getReviews() {
    try { return JSON.parse(localStorage.getItem(STORAGE_REVIEWS) || '[]'); } catch { return []; }
  }

  function getProductReviews() {
    return getReviews().filter(function(r) { return r.productSlug === productSlug; });
  }

  function getAvgRating() {
    var revs = getProductReviews();
    if (revs.length === 0) return { avg: 0, count: 0, distribution: {} };
    var sum = revs.reduce(function(s, r) { return s + (r.rating||0); }, 0);
    var dist = {};
    for (var i = 1; i <= 5; i++) dist[i] = revs.filter(function(r) { return r.rating === i; }).length;
    return { avg: (sum / revs.length).toFixed(1), count: revs.length, distribution: dist };
  }

  function renderStars(n) {
    var s = '';
    for (var i = 1; i <= 5; i++) s += i <= Math.round(n) ? '★' : '☆';
    return s;
  }

  function renderReviews() {
    var revs = getProductReviews();
    var avg = getAvgRating();
    document.getElementById('avg-rating').textContent = avg.avg;
    document.getElementById('avg-stars').textContent = renderStars(avg.avg);
    document.getElementById('review-count').textContent = avg.count + ' ulasan';

    // Distribution bars
    var barsEl = document.getElementById('rating-bars');
    barsEl.innerHTML = '';
    for (var i = 5; i >= 1; i--) {
      var count = avg.distribution[i] || 0;
      var pct = avg.count > 0 ? (count / avg.count * 100) : 0;
      barsEl.innerHTML += '<div class=\"flex items-center gap-2 text-sm\"><span class=\"w-4 font-bold\">' + i + '</span><div class=\"flex-1 h-3 bg-gray-200 border border-black\"><div class=\"h-full bg-neon-yellow\" style=\"width:' + pct + '%\"></div></div><span class=\"w-8 text-right text-xs font-bold\">' + count + '</span></div>';
    }

    // Reviews list
    var list = document.getElementById('reviews-list');
    var empty = document.getElementById('reviews-empty');
    if (revs.length === 0) {
      list.innerHTML = '';
      empty.classList.remove('hidden');
      return;
    }
    empty.classList.add('hidden');
    list.innerHTML = revs.sort(function(a, b) { return new Date(b.createdAt) - new Date(a.createdAt); }).map(function(r) {
      return '<div class=\"border-4 border-black bg-white p-5 shadow-[2px_2px_0px_0px_#000]\">' +
        '<div class=\"flex justify-between items-start mb-2\">' +
          '<div><span class=\"font-black\">' + (r.userName || 'Anonymous') + '</span>' +
          ' <span class=\"text-yellow-500\">' + renderStars(r.rating) + '</span></div>' +
          '<span class=\"text-xs text-gray-400 font-bold\">' + new Date(r.createdAt).toLocaleDateString('id-ID') + '</span>' +
        '</div>' +
        '<p class=\"font-medium text-gray-700\">' + (r.comment || '') + '</p></div>';
    }).join('');
  }

  // Check if current user can review (logged in + purchased)
  function canReview() {
    try {
      var userData = JSON.parse(localStorage.getItem('topzone_current_user'));
      if (!userData || !userData.isLoggedIn) return { can: false, reason: 'login' };

      var email = userData.email.replace(/[^a-zA-Z0-9]/g, '_');
      // Check user's orders
      var ordersKey = 'topzone_orders_' + email;
      var orders = JSON.parse(localStorage.getItem(ordersKey) || '[]');
      var hasPurchased = orders.some(function(o) {
        return o.items && o.items.some(function(i) { return i.type === 'game'; });
      });

      if (!hasPurchased) {
        // Also check anonymous key
        var anonOrders = JSON.parse(localStorage.getItem('topzone_orders') || '[]');
        hasPurchased = anonOrders.some(function(o) {
          return o.items && o.items.some(function(i) { return i.type === 'game'; });
        });
      }

      return { can: hasPurchased, reason: hasPurchased ? 'ok' : 'purchase' };
    } catch(e) { return { can: false, reason: 'login' }; }
  }

  // Init review UI
  var check = canReview();
  var formSection = document.getElementById('review-form-section');
  var loginPrompt = document.getElementById('review-login-prompt');
  var purchasePrompt = document.getElementById('review-purchase-prompt');

  if (check.can) {
    formSection.classList.remove('hidden');
  } else if (check.reason === 'login') {
    loginPrompt.classList.remove('hidden');
  } else {
    purchasePrompt.classList.remove('hidden');
  }

  // Star rating interaction
  var selectedRating = 0;
  document.querySelectorAll('.star').forEach(function(s) {
    s.addEventListener('click', function() {
      selectedRating = parseInt(this.dataset.val);
      document.querySelectorAll('.star').forEach(function(st) {
        st.textContent = parseInt(st.dataset.val) <= selectedRating ? '★' : '☆';
      });
    });
  });

  // Submit review
  document.getElementById('submit-review').addEventListener('click', function() {
    var status = document.getElementById('review-status');
    if (selectedRating === 0) {
      status.className = 'mt-2 text-sm font-bold text-red-500';
      status.textContent = 'Pilih rating dulu!';
      status.classList.remove('hidden');
      return;
    }
    var comment = document.getElementById('review-text').value.trim();
    if (!comment) {
      status.className = 'mt-2 text-sm font-bold text-red-500';
      status.textContent = 'Tulis ulasan dulu!';
      status.classList.remove('hidden');
      return;
    }

    var revs = getReviews();
    var userData = JSON.parse(localStorage.getItem('topzone_current_user') || '{}');
    revs.push({
      id: Date.now().toString(36),
      productSlug: productSlug,
      rating: selectedRating,
      comment: comment,
      userName: userData.full_name || userData.email?.split('@')[0] || 'User',
      userEmail: userData.email || '',
      createdAt: new Date().toISOString(),
    });
    localStorage.setItem(STORAGE_REVIEWS, JSON.stringify(revs));

    status.className = 'mt-2 text-sm font-bold text-black bg-neon-green px-3 py-2 border-2 border-black';
    status.textContent = '✅ Ulasan berhasil dikirim!';
    status.classList.remove('hidden');
    document.getElementById('review-text').value = '';
    renderReviews();
  });

  renderReviews();
</script>
</Layout>

<script>
  import { addToCart } from '../../stores/cart';

  const buttons = document.querySelectorAll<HTMLButtonElement>('.package-btn');
  const toast = document.getElementById('add-toast');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      addToCart({
        id: btn.dataset.id!,
        name: btn.dataset.name!,
        price: Number(btn.dataset.price),
        img: btn.dataset.img!,
        type: 'game',
      });
      // Show toast
      toast?.classList.remove('hidden');
      setTimeout(() => toast?.classList.add('hidden'), 2000);
    });
  });
</script>
