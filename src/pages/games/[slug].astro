---
// src/pages/games/[slug].astro
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/Button.astro';
import { fetchGames } from '../../lib/products';
import { supabase } from '../../lib/supabase';
import { formatCurrency } from '../../utils/format';
import type { Game } from '../../data/games';
import ImageGallery from '../../components/products/ImageGallery.astro';
import type { ProductImage } from '../../types/product';
export const prerender = true;
export async function getStaticPaths() {
  const games = await fetchGames();
  const imageResults = await Promise.all(
    games.map(async (game) => {
      if (!supabase) return [];
      const { data: product } = await supabase
        .from('products')
        .select('id')
        .eq('slug', game.slug)
        .eq('type', 'game')
        .single();
      if (!product) return [];
      const { data: images } = await supabase
        .from('product_images')
        .select('id, image_url, alt_text, caption, is_primary, sort_order')
        .eq('product_id', product.id)
        .order('sort_order', { ascending: true });
      return (images || []) as ProductImage[];
    })
  );
  return games.map((game, index) => ({
    params: { slug: game.slug },
    props: { game, images: imageResults[index] || [] },
  }));
}

interface Props { game: Game; images: ProductImage[]; }
const { game, images } = Astro.props;
---

<Layout>
  <Navbar />

  <!-- Hero Banner -->
  <section class="relative h-64 md:h-80 flex items-end bg-black overflow-hidden border-b-4 border-black">
    <ImageGallery images={images} productName={game.name} />
    <div class="absolute inset-0 bg-gradient-to-t from-black/90 to-transparent"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-8 w-full">
      <span class="inline-block px-3 py-1 text-xs font-black uppercase tracking-widest border-2 border-black shadow-[2px_2px_0px_0px_#000] mb-3" style={`background:${game.color}; color:#000;`}>
        {game.badge}
      </span>
      <h1 class="text-4xl md:text-6xl font-black text-white mb-2">{game.name}</h1>
      <p class="text-gray-300 font-medium max-w-xl">{game.description}</p>
    </div>
  </section>

  <!-- Package Grid -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-black mb-2">Pilih Paket <span style={`color:${game.color}; -webkit-text-stroke:1px #000;`}>{game.currency}</span></h2>
      <p class="text-gray-500 font-medium mb-8">Klik paket untuk menambahkan ke keranjang belanja.</p>

      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4" id="package-grid">
        {game.packages.map((pkg) => {
          return (
            <button
              class={`package-btn border-4 border-black p-4 bg-white text-left shadow-[4px_4px_0px_0px_#000] hover:-translate-y-1 hover:shadow-[6px_6px_0px_0px_#000] active:translate-y-0 active:shadow-[2px_2px_0px_0px_#000] transition-all cursor-pointer ${pkg.stock === 0 ? 'opacity-50 cursor-not-allowed hover:translate-y-0 hover:shadow-[4px_4px_0px_0px_#000]' : ''}`}
              data-id={pkg.id}
              data-name={`${game.name} — ${pkg.label}`}
              data-price={pkg.price}
              data-img={game.img}
              disabled={pkg.stock === 0}
            >
              <div class="text-lg font-black mb-1">{pkg.label}</div>
              <div class="text-2xl font-black" style={`color:${game.color}; -webkit-text-stroke:1px #000;`}>
                {formatCurrency(pkg.price)}
              </div>
              {pkg.stock === 0 && (
                <div class="text-xs font-black text-red-500 mt-1 uppercase">Stok Habis</div>
              )}
            </button>
          );
        })}
      </div>

      <!-- Toast notification -->
      <div id="add-toast" class="hidden fixed bottom-6 right-6 z-50 bg-black text-neon-green font-black px-5 py-3 border-4 border-neon-green shadow-[4px_4px_0px_0px_#39FF14]">
        ✓ Ditambahkan ke keranjang!
      </div>
    </div>
  </section>

  <!-- Share Buttons -->
  <section class="py-6 bg-white border-b-4 border-black">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center gap-3">
        <span class="text-sm font-black uppercase tracking-wider text-black dark:text-white">Bagikan:</span>
        <button data-social-share="whatsapp" data-text={"Beli " + game.name + " di TopZone"} class="share-btn px-4 py-2 text-sm font-black border-2 border-black bg-green-400 shadow-[2px_2px_0px_0px_#000] hover:shadow-none hover:translate-x-[1px] hover:translate-y-[1px] transition-all">WhatsApp</button>
        <button data-social-share="twitter" data-text={game.name} class="share-btn px-4 py-2 text-sm font-black border-2 border-black bg-blue-400 shadow-[2px_2px_0px_0px_#000] hover:shadow-none hover:translate-x-[1px] hover:translate-y-[1px] transition-all">Twitter</button>
        <button data-social-share="telegram" data-text={"Beli " + game.name + " di TopZone"} class="share-btn px-4 py-2 text-sm font-black border-2 border-black bg-blue-500 text-white shadow-[2px_2px_0px_0px_#000] hover:shadow-none hover:translate-x-[1px] hover:translate-y-[1px] transition-all">Telegram</button>
        <button data-social-share="copy" class="share-btn px-4 py-2 text-sm font-black border-2 border-black bg-white shadow-[2px_2px_0px_0px_#000] hover:shadow-none hover:translate-x-[1px] hover:translate-y-[1px] transition-all">Copy Link</button>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ -->
  <!-- REVIEWS & RATINGS -->
  <!-- ═══════════════════════════════════════════════════ -->
  <section class="py-12 bg-gray-50 border-t-4 border-black">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-black mb-2">⭐ Ulasan & Rating</h2>
      <p class="text-gray-500 font-medium mb-6">Kata para pembeli tentang game ini.</p>

      <!-- Average Rating -->
      <div class="border-4 border-black bg-white p-5 shadow-[4px_4px_0px_0px_#000] mb-6">
        <div class="flex items-center gap-6">
          <div class="text-center">
            <span class="text-5xl font-black" id="avg-rating">0</span>
            <span class="text-2xl">/5</span>
            <div class="text-lg" id="avg-stars">☆☆☆☆☆</div>
            <span class="text-sm font-bold text-gray-500" id="review-count">0 ulasan</span>
          </div>
          <div class="flex-1">
            <div id="rating-bars" class="space-y-1"></div>
          </div>
        </div>
      </div>

      <!-- Review Form -->
      <div id="review-form-section" class="hidden border-4 border-black bg-neon-yellow p-5 shadow-[4px_4px_0px_0px_#000] mb-6">
        <h3 class="font-black text-lg mb-3">✍️ Tulis Ulasan</h3>
        <div class="flex gap-1 text-3xl mb-3" id="star-rating">
          <span class="star cursor-pointer hover:scale-110 transition-transform" data-val="1">☆</span>
          <span class="star cursor-pointer hover:scale-110 transition-transform" data-val="2">☆</span>
          <span class="star cursor-pointer hover:scale-110 transition-transform" data-val="3">☆</span>
          <span class="star cursor-pointer hover:scale-110 transition-transform" data-val="4">☆</span>
          <span class="star cursor-pointer hover:scale-110 transition-transform" data-val="5">☆</span>
        </div>
        <textarea id="review-text" rows="3" class="w-full px-4 py-3 border-3 border-black font-bold text-sm shadow-[3px_3px_0px_0px_#000] focus:shadow-none focus:translate-x-[1px] focus:translate-y-[1px] outline-none transition-all" placeholder="Bagikan pengalamanmu..."></textarea>
        <button id="submit-review" class="mt-3 px-6 py-3 font-black border-2 border-black bg-black text-white shadow-[3px_3px_0px_0px_#000] hover:shadow-none hover:translate-x-[1px] hover:translate-y-[1px] transition-all">Kirim Ulasan</button>
        <p id="review-status" class="mt-2 text-sm font-bold hidden"></p>
      </div>

      <!-- Login Prompt -->
      <div id="review-login-prompt" class="hidden border-4 border-dashed border-black p-6 text-center mb-6">
        <p class="font-black text-lg mb-2">🔒 Login untuk memberi ulasan</p>
        <a href="/login" class="inline-block px-6 py-2 font-black border-2 border-black bg-neon-green shadow-[2px_2px_0px_0px_#000]">Masuk</a>
      </div>

      <!-- Purchase Required -->
      <div id="review-purchase-prompt" class="hidden border-4 border-dashed border-black p-6 text-center mb-6">
        <p class="font-black text-lg mb-2">🎮 Beli game ini dulu untuk memberi ulasan!</p>
      </div>

      <!-- Sort Controls -->
      <div class="flex justify-end mb-4">
        <select id="review-sort" class="px-3 py-2 border-4 border-black font-bold text-sm bg-white dark:bg-gray-700 dark:text-white shadow-[2px_2px_0px_0px_#000] focus:shadow-none focus:translate-x-[1px] focus:translate-y-[1px] transition-all">
          <option value="newest">Terbaru</option>
          <option value="highest">Rating Tertinggi</option>
          <option value="lowest">Rating Terendah</option>
        </select>
      </div>

      <!-- Reviews List -->
      <div id="reviews-list" class="space-y-4"></div>
      <div id="reviews-empty" class="text-center py-8 border-4 border-dashed border-black">
        <p class="text-lg font-black text-gray-400">Belum ada ulasan. Jadilah yang pertama!</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ -->
  <!-- Q&A SECTION -->
  <!-- ═══════════════════════════════════════════════════ -->
  <section class="py-12 bg-white border-t-4 border-black">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-black mb-2">❓ Tanya Jawab</h2>
      <p class="text-gray-500 font-medium mb-6">Pertanyaan seputar game ini dari para gamer.</p>

      <!-- Q&A Form -->
      <div id="qa-form-section" class="border-4 border-black bg-neon-yellow p-5 shadow-[4px_4px_0px_0px_#000] mb-6">
        <h3 class="font-black text-lg mb-3">💬 Ajukan Pertanyaan</h3>
        <textarea id="qa-question" rows="3" class="w-full px-4 py-3 border-3 border-black font-bold text-sm shadow-[3px_3px_0px_0px_#000] focus:shadow-none focus:translate-x-[1px] focus:translate-y-[1px] outline-none transition-all" placeholder="Tulis pertanyaanmu tentang game ini..."></textarea>
        <button id="submit-question" class="mt-3 px-6 py-3 font-black border-2 border-black bg-black text-white shadow-[3px_3px_0px_0px_#000] hover:shadow-none hover:translate-x-[1px] hover:translate-y-[1px] transition-all">Kirim Pertanyaan</button>
        <p id="qa-status" class="mt-2 text-sm font-bold hidden"></p>
      </div>

      <!-- Login Prompt for Q&A -->
      <div id="qa-login-prompt" class="hidden border-4 border-dashed border-black p-6 text-center mb-6">
        <p class="font-black text-lg mb-2">🔒 Login untuk bertanya</p>
        <a href="/login" class="inline-block px-6 py-2 font-black border-2 border-black bg-neon-green shadow-[2px_2px_0px_0px_#000]">Masuk</a>
      </div>

      <!-- Q&A List -->
      <div id="qa-list" class="space-y-4"></div>
      <div id="qa-empty" class="text-center py-8 border-4 border-dashed border-black">
        <p class="text-lg font-black text-gray-400">Belum ada pertanyaan. Ajukan yang pertama!</p>
      </div>
    </div>
  </section>

  <Footer />
<script>
  const productSlug = window.location.pathname.split('/').pop();
  const STORAGE_REVIEWS = 'topzone_reviews';

  function getReviews() {
    try { return JSON.parse(localStorage.getItem(STORAGE_REVIEWS) || '[]'); } catch { return []; }
  }

  function getProductReviews() {
    return getReviews().filter(function(r) { return r.productSlug === productSlug; });
  }

  function getAvgRating() {
    var revs = getProductReviews();
    if (revs.length === 0) return { avg: 0, count: 0, distribution: {} };
    var sum = revs.reduce(function(s, r) { return s + (r.rating||0); }, 0);
    var dist = {};
    for (var i = 1; i <= 5; i++) dist[i] = revs.filter(function(r) { return r.rating === i; }).length;
    return { avg: (sum / revs.length).toFixed(1), count: revs.length, distribution: dist };
  }

  var reviewSort = 'newest';

  function renderStars(n) {
    var s = '';
    for (var i = 1; i <= 5; i++) s += i <= Math.round(n) ? '★' : '☆';
    return s;
  }

  function sortReviews(reviews, sortBy) {
    var sorted = reviews.slice();
    if (sortBy === 'newest') return sorted.sort(function(a, b) { return new Date(b.createdAt) - new Date(a.createdAt); });
    else if (sortBy === 'highest') return sorted.sort(function(a, b) { return b.rating - a.rating; });
    else if (sortBy === 'lowest') return sorted.sort(function(a, b) { return a.rating - b.rating; });
    return sorted;
  }

  function renderReviews() {
    var revs = getProductReviews();
    var avg = getAvgRating();
    document.getElementById('avg-rating').textContent = avg.avg;
    document.getElementById('avg-stars').textContent = renderStars(avg.avg);
    document.getElementById('review-count').textContent = avg.count + ' ulasan';

    var barsEl = document.getElementById('rating-bars');
    barsEl.innerHTML = '';
    for (var i = 5; i >= 1; i--) {
      var count = avg.distribution[i] || 0;
      var pct = avg.count > 0 ? (count / avg.count * 100) : 0;
      barsEl.innerHTML += '<div class=\"flex items-center gap-2 text-sm\"><span class=\"w-4 font-bold\">' + i + '</span><div class=\"flex-1 h-3 bg-gray-200 border border-black\"><div class=\"h-full bg-neon-yellow\" style=\"width:' + pct + '%\"></div></div><span class=\"w-8 text-right text-xs font-bold\">' + count + '</span></div>';
    }

    // Sort controls
    var sortEl = document.getElementById('review-sort');
    if (sortEl) {
      sortEl.value = reviewSort;
      sortEl.onchange = function() { reviewSort = this.value; renderReviews(); };
    }

    var list = document.getElementById('reviews-list');
    var empty = document.getElementById('reviews-empty');
    if (revs.length === 0) {
      list.innerHTML = '';
      empty.classList.remove('hidden');
      return;
    }
    empty.classList.add('hidden');
    list.innerHTML = sortReviews(revs, reviewSort).map(function(r) {
      return '<div class=\"border-4 border-black bg-white p-5 shadow-[2px_2px_0px_0px_#000]\">' +
        '<div class=\"flex justify-between items-start mb-2\">' +
          '<div><span class=\"font-black\">' + (r.userName || 'Anonymous') + '</span>' +
          ' <span class=\"text-yellow-500\">' + renderStars(r.rating) + '</span>' +
          (r.verifiedPurchase ? '<span class=\"ml-2 px-2 py-1 text-xs font-black bg-blue-400 text-white border-2 border-black\">✓ Verified</span>' : '') +
          '</div>' +
          '<span class=\"text-xs text-gray-400 font-bold\">' + new Date(r.createdAt).toLocaleDateString('id-ID') + '</span>' +
        '</div>' +
        '<p class=\"font-medium text-gray-700\">' + (r.comment || '') + '</p>' +
        '<div class=\"flex items-center gap-3 mt-3 pt-3 border-t border-gray-200\">' +
          '<span class=\"text-xs font-bold text-gray-500\">Apakah ulasan ini membantu?</span>' +
          '<button class=\"helpful-btn text-sm font-bold px-3 py-1 border-2 border-black bg-white hover:bg-neon-green transition-colors\" data-id=\"' + r.id + '\" data-type=\"up\">👍 ' + (r.helpful || 0) + '</button>' +
          '<button class=\"helpful-btn text-sm font-bold px-3 py-1 border-2 border-black bg-white hover:bg-red-400 transition-colors\" data-id=\"' + r.id + '\" data-type=\"down\">👎 ' + (r.unhelpful || 0) + '</button>' +
        '</div></div>';
    }).join('');
  }

  // Check if current user can review (logged in + purchased)
  function canReview() {
    try {
      var userData = JSON.parse(localStorage.getItem('topzone_current_user'));
      if (!userData || !userData.isLoggedIn) return { can: false, reason: 'login' };

      var email = userData.email.replace(/[^a-zA-Z0-9]/g, '_');
      // Check user's orders
      var ordersKey = 'topzone_orders_' + email;
      var orders = JSON.parse(localStorage.getItem(ordersKey) || '[]');
      var hasPurchased = orders.some(function(o) {
        return o.items && o.items.some(function(i) { return i.type === 'game'; });
      });

      if (!hasPurchased) {
        // Also check anonymous key
        var anonOrders = JSON.parse(localStorage.getItem('topzone_orders') || '[]');
        hasPurchased = anonOrders.some(function(o) {
          return o.items && o.items.some(function(i) { return i.type === 'game'; });
        });
      }

      return { can: hasPurchased, reason: hasPurchased ? 'ok' : 'purchase' };
    } catch(e) { return { can: false, reason: 'login' }; }
  }

  // Init review UI
  var check = canReview();
  var formSection = document.getElementById('review-form-section');
  var loginPrompt = document.getElementById('review-login-prompt');
  var purchasePrompt = document.getElementById('review-purchase-prompt');

  if (check.can) {
    formSection.classList.remove('hidden');
  } else if (check.reason === 'login') {
    loginPrompt.classList.remove('hidden');
  } else {
    purchasePrompt.classList.remove('hidden');
  }

  // Star rating interaction
  var selectedRating = 0;
  document.querySelectorAll('.star').forEach(function(s) {
    s.addEventListener('click', function() {
      selectedRating = parseInt(this.dataset.val);
      document.querySelectorAll('.star').forEach(function(st) {
        st.textContent = parseInt(st.dataset.val) <= selectedRating ? '★' : '☆';
      });
    });
  });

  // Submit review
  document.getElementById('submit-review').addEventListener('click', function() {
    var status = document.getElementById('review-status');
    if (selectedRating === 0) {
      status.className = 'mt-2 text-sm font-bold text-red-500';
      status.textContent = 'Pilih rating dulu!';
      status.classList.remove('hidden');
      return;
    }
    var comment = document.getElementById('review-text').value.trim();
    if (!comment) {
      status.className = 'mt-2 text-sm font-bold text-red-500';
      status.textContent = 'Tulis ulasan dulu!';
      status.classList.remove('hidden');
      return;
    }

    var revs = getReviews();
    var userData = JSON.parse(localStorage.getItem('topzone_current_user') || '{}');
    var isVerified = check.can && check.reason === 'ok';
    revs.push({
      id: Date.now().toString(36),
      productSlug: productSlug,
      rating: selectedRating,
      comment: comment,
      userName: userData.full_name || userData.email?.split('@')[0] || 'User',
      userEmail: userData.email || '',
      verifiedPurchase: isVerified,
      createdAt: new Date().toISOString(),
    });
    localStorage.setItem(STORAGE_REVIEWS, JSON.stringify(revs));

    status.className = 'mt-2 text-sm font-bold text-black bg-neon-green px-3 py-2 border-2 border-black';
    status.textContent = '✅ Ulasan berhasil dikirim!';
    status.classList.remove('hidden');
    document.getElementById('review-text').value = '';
    renderReviews();
  });

  // Helpful vote buttons
  document.addEventListener('click', function(e) {
    var target = e.target as HTMLElement;
    if (!target.classList.contains('helpful-btn')) return;

    var reviewId = target.dataset.id;
    var voteType = target.dataset.type;
    if (!reviewId || !voteType) return;

    var revs = getReviews();
    var rev = revs.find(function(r) { return r.id === reviewId; });
    if (!rev) return;

    if (voteType === 'up') rev.helpful = (rev.helpful || 0) + 1;
    else rev.unhelpful = (rev.unhelpful || 0) + 1;

    localStorage.setItem(STORAGE_REVIEWS, JSON.stringify(revs));
    renderReviews();
  });

  renderReviews();

  // ═══════════════════════════════════════════════════════
  // Q&A System
  // ═══════════════════════════════════════════════════════
  var QA_KEY = 'topzone_qa_' + productSlug;

  function getQAs() {
    try { return JSON.parse(localStorage.getItem(QA_KEY) || '[]'); } catch { return []; }
  }

  function saveQAs(qas) {
    localStorage.setItem(QA_KEY, JSON.stringify(qas));
  }

  function renderQAs() {
    var qas = getQAs();
    var list = document.getElementById('qa-list');
    var empty = document.getElementById('qa-empty');
    if (!list) return;

    if (qas.length === 0) {
      list.innerHTML = '';
      if (empty) empty.classList.remove('hidden');
      return;
    }
    if (empty) empty.classList.add('hidden');

    list.innerHTML = qas.sort(function(a, b) { return new Date(b.createdAt) - new Date(a.createdAt); }).map(function(q) {
      var html = '<div class="border-4 border-black bg-white p-5 shadow-[2px_2px_0px_0px_#000]">' +
        '<div class="flex justify-between items-start mb-2">' +
          '<div><span class="font-black">❓ ' + (q.userName || 'Anonymous') + '</span>' +
          '<span class="text-xs text-gray-400 font-bold ml-2">' + new Date(q.createdAt).toLocaleDateString('id-ID') + '</span></div>' +
        '</div>' +
        '<p class="font-medium text-gray-700 mb-3">' + q.question + '</p>';

      if (q.answer) {
        html += '<div class="border-l-4 border-neon-green pl-4 ml-4 mt-3">' +
          '<p class="text-sm font-black text-neon-green">Admin:</p>' +
          '<p class="text-sm font-medium text-gray-600">' + q.answer + '</p>' +
          '<p class="text-xs text-gray-400 mt-1">Dijawab ' + new Date(q.answeredAt).toLocaleDateString('id-ID') + '</p>' +
        '</div>';
      } else {
        html += '<p class="text-xs font-bold text-gray-400 ml-4 mt-2">Menunggu jawaban admin...</p>';
      }

      html += '</div>';
      return html;
    }).join('');
  }

  // Show Q&A login prompt
  try {
    var userData = JSON.parse(localStorage.getItem('topzone_current_user'));
    if (userData && userData.isLoggedIn) {
      document.getElementById('qa-form-section').classList.remove('hidden');
      document.getElementById('qa-login-prompt').classList.add('hidden');
    }
  } catch(e) {}

  // Submit question
  document.getElementById('submit-question')?.addEventListener('click', function() {
    var input = document.getElementById('qa-question');
    var status = document.getElementById('qa-status');
    if (!input || !status) return;

    var question = input.value.trim();
    if (!question) {
      status.className = 'mt-2 text-sm font-bold text-red-500';
      status.textContent = 'Tulis pertanyaan dulu!';
      status.classList.remove('hidden');
      return;
    }

    var qas = getQAs();
    var userData = JSON.parse(localStorage.getItem('topzone_current_user') || '{}');
    qas.push({
      id: Date.now().toString(36),
      question: question,
      answer: null,
      answeredAt: null,
      userName: userData.full_name || userData.email?.split('@')[0] || 'User',
      createdAt: new Date().toISOString(),
    });
    saveQAs(qas);

    status.className = 'mt-2 text-sm font-bold text-black bg-neon-green px-3 py-2 border-2 border-black';
    status.textContent = '✅ Pertanyaan berhasil dikirim! Admin akan menjawab segera.';
    status.classList.remove('hidden');
    input.value = '';
    renderQAs();
  });

  renderQAs();
</script>
</Layout>

<script>
  // Social share functionality
  document.querySelectorAll('.share-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var platform = this.dataset.socialShare;
      var url = encodeURIComponent(window.location.href);
      var text = encodeURIComponent(this.dataset.text || document.title);
      var href = '';
      if (platform === 'whatsapp') href = 'https://wa.me/?text=' + text + '%20' + url;
      else if (platform === 'twitter') href = 'https://twitter.com/intent/tweet?text=' + text + '&url=' + url;
      else if (platform === 'telegram') href = 'https://t.me/share/url?url=' + url + '&text=' + text;
      else if (platform === 'copy') {
        navigator.clipboard.writeText(window.location.href);
        this.textContent = 'Copied!';
        var self = this;
        setTimeout(function() { self.textContent = 'Copy Link'; }, 1500);
        return;
      }
      if (href) window.open(href, '_blank', 'width=600,height=400');
    });
  });
</script>

<script>
  import { addToCart } from '../../stores/cart';

  const buttons = document.querySelectorAll('.package-btn');
  const toast = document.getElementById('add-toast');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      addToCart({
        id: btn.dataset.id!,
        name: btn.dataset.name!,
        price: Number(btn.dataset.price),
        img: btn.dataset.img!,
        type: 'game',
      });
      // Show toast
      toast?.classList.remove('hidden');
      setTimeout(() => toast?.classList.add('hidden'), 2000);
    });
  });
</script>
