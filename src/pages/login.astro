---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
---

<Layout>
  <Navbar />

  <section class="min-h-screen flex items-center justify-center bg-neon-green dark:bg-gray-900 py-16 px-4">
    <div class="w-full max-w-md">
      <!-- Login Card -->
      <div class="border-4 border-black bg-white dark:bg-gray-800 p-8 shadow-[8px_8px_0px_0px_#000]">
        <div class="text-center mb-8">
          <h1 class="text-4xl font-black mb-2 text-black dark:text-white">Masuk <span style="color:#39FF14; -webkit-text-stroke:1px #000;">TopZone</span></h1>
          <p class="font-bold text-gray-600 dark:text-gray-300">Login untuk mulai top up dan belanja gear!</p>
        </div>

        <!-- Login Form -->
        <form id="login-form" class="space-y-5">
          <div>
            <label for="email" class="block text-sm font-black uppercase tracking-wider mb-2 text-black dark:text-white">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="you@example.com"
              class="w-full px-4 py-3 border-3 border-black font-bold text-lg shadow-[3px_3px_0px_0px_#000] focus:shadow-[1px_1px_0px_0px_#000] focus:translate-x-[2px] focus:translate-y-[2px] outline-none transition-all dark:bg-gray-700 dark:text-white"
            />
          </div>

          <div>
            <label for="password" class="block text-sm font-black uppercase tracking-wider mb-2 text-black dark:text-white">Password</label>
            <input
              type="password"
              id="password"
              name="password"
              required
              minlength="6"
              placeholder="Min 6 karakter"
              class="w-full px-4 py-3 border-3 border-black font-bold text-lg shadow-[3px_3px_0px_0px_#000] focus:shadow-[1px_1px_0px_0px_#000] focus:translate-x-[2px] focus:translate-y-[2px] outline-none transition-all dark:bg-gray-700 dark:text-white"
            />
          </div>

          <div id="error-msg" class="hidden bg-red-500 text-white font-black px-4 py-3 border-2 border-black text-sm"></div>
          <div id="unverified-msg" class="hidden bg-yellow-500 text-white font-black px-4 py-3 border-2 border-black text-sm text-center">
            Email belum diverifikasi! Cek inbox/spam.
            <button id="resend-verify-btn" class="ml-2 underline hover:text-neon-pink transition-colors">Kirim ulang</button>
          </div>

          <button
            type="submit"
            id="login-btn"
            class="w-full py-4 font-black uppercase tracking-wider text-lg bg-black text-neon-green border-4 border-black shadow-[4px_4px_0px_0px_#39FF14] hover:-translate-y-1 hover:shadow-[6px_6px_0px_0px_#39FF14] active:translate-y-0 active:shadow-[2px_2px_0px_0px_#39FF14] transition-all"
          >
            Masuk
          </button>
        </form>

        <!-- OAuth Divider -->
        <div class="mt-6 mb-4 flex items-center gap-3">
          <span class="flex-1 border-t-2 border-black/20 dark:border-gray-600"></span>
          <span class="text-sm font-black text-gray-500 dark:text-gray-400">ATAU</span>
          <span class="flex-1 border-t-2 border-black/20 dark:border-gray-600"></span>
        </div>

        <!-- OAuth Buttons -->
        <div class="space-y-3">
          <button id="google-login-btn"
            class="w-full py-3 font-bold text-sm flex items-center justify-center gap-3 bg-white text-black border-3 border-black shadow-[3px_3px_0px_0px_#000] hover:shadow-[1px_1px_0px_0px_#000] hover:translate-x-[2px] hover:translate-y-[2px] transition-all"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            Lanjutkan dengan Google
          </button>
          <button id="discord-login-btn"
            class="w-full py-3 font-bold text-sm flex items-center justify-center gap-3 bg-[#5865F2] text-white border-3 border-black shadow-[3px_3px_0px_0px_#000] hover:shadow-[1px_1px_0px_0px_#000] hover:translate-x-[2px] hover:translate-y-[2px] transition-all"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028 14.09 14.09 0 001.226-1.994.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
            Lanjutkan dengan Discord
          </button>
        </div>

        <div class="mt-4 text-center">
          <a href="/auth/forgot-password" class="text-sm font-bold text-neon-pink hover:underline transition-colors">Lupa password?</a>
        </div>

        <div class="mt-6 text-center">
          <p class="font-bold text-gray-600 dark:text-gray-300">
            Belum punya akun?
            <a href="/register" class="font-black underline hover:text-neon-green transition-colors text-black dark:text-white">Daftar sekarang</a>
          </p>
        </div>
      </div>

      <!-- Back to home -->
      <div class="text-center mt-6">
        <a href="/" class="inline-flex items-center gap-2 font-black text-sm hover:underline text-black dark:text-white">
          &#8592; Kembali ke Beranda
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  import { setLocalUser, setUser } from '../stores/auth';
  import { supabase, signInWithPassword, onAuthStateChange, supabaseQuery } from '../lib/supabase';
  import { mergeCartOnLogin } from '../stores/cart';

  // --- OAuth Login Buttons ---
  async function loginOAuth(provider: 'google' | 'discord') {
    if (!supabase) {
      alert('Supabase OAuth tidak dikonfigurasi. Login dengan email/password.');
      return;
    }
    const { error } = await supabase.auth.signInWithOAuth({ provider });
    if (error) {
      alert('Gagal login dengan ' + provider + ': ' + error.message);
    }
  }

  const form = document.getElementById('login-form') as HTMLFormElement;
  const errorMsg = document.getElementById('error-msg');
  const unverifiedMsg = document.getElementById('unverified-msg');
  const resendBtn = document.getElementById('resend-verify-btn') as HTMLButtonElement;
  const loginBtn = document.getElementById('login-btn') as HTMLButtonElement;

  // Subscribe to Supabase auth state changes
  let authUnsubscribe: (() => void) | undefined;
  if (supabase) {
    authUnsubscribe = onAuthStateChange((event, session) => {
      if (event === 'SIGNED_IN' && session?.user) {
        setUser({
          email: session.user.email ?? '',
          full_name: session.user.user_metadata?.full_name || session.user.email?.split('@')[0] || '',
          isLoggedIn: true,
        });
      } else if (event === 'SIGNED_OUT') {
        setUser(null);
      }
    });
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg?.classList.add('hidden');
    unverifiedMsg?.classList.add('hidden');

    const email = (document.getElementById('email') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;

    loginBtn.textContent = 'Masuk...';
    loginBtn.disabled = true;

    // Try Supabase Auth first
    const { data, error } = await signInWithPassword(email, password);

    if (error) {
      // localStorage fallback when Supabase not configured
      if (!supabase && password.length >= 3) {
        setLocalUser(email);
        var redirectUrl = new URLSearchParams(window.location.search).get('redirect') || '/';
        window.location.href = redirectUrl;
        return;
      }

      // Check if error is "email not confirmed"
      const isUnverified = error.message?.toLowerCase().includes('not confirmed') ||
        error.message?.toLowerCase().includes('email not verified');
      if (isUnverified) {
        unverifiedMsg?.classList.remove('hidden');
      } else {
        errorMsg.textContent = error.message;
        errorMsg?.classList.remove('hidden');
      }
      loginBtn.textContent = 'Masuk';
      loginBtn.disabled = false;
      return;
    }

    // Supabase success — session synced via onAuthStateChange
    if (!supabase) {
      setLocalUser(email, data.user?.user_metadata?.full_name);
    }

    // Merge guest cart with server-side cart after login
    await mergeCartOnLogin();

    var redirectUrl = new URLSearchParams(window.location.search).get('redirect') || '/';
    window.location.href = redirectUrl;
  });

  // Cleanup on unload
  window.addEventListener('beforeunload', () => authUnsubscribe?.());

  // Resend verification email
  resendBtn?.addEventListener('click', async () => {
    const email = (document.getElementById('email') as HTMLInputElement).value;
    if (!email) {
      alert('Masukkan email dulu!');
      return;
    }
    resendBtn.textContent = 'Mengirim...';
    resendBtn.disabled = true;
    if (supabase) {
      const { error } = await supabase.auth.resend({ type: 'signup', email });
      if (error) {
        errorMsg.textContent = 'Gagal kirim ulang: ' + error.message;
        errorMsg?.classList.remove('hidden');
      } else {
        alert('Link verifikasi sudah dikirim ulang ke email kamu!');
      }
    } else {
      alert('Supabase tidak dikonfigurasi. Gunakan mode development.');
    }
    resendBtn.textContent = 'Kirim ulang';
    resendBtn.disabled = false;
  });

  // OAuth button listeners
  document.getElementById('google-login-btn')?.addEventListener('click', () => loginOAuth('google'));
  document.getElementById('discord-login-btn')?.addEventListener('click', () => loginOAuth('discord'));
</script>
