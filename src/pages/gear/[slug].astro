---
// src/pages/gear/[slug].astro
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ReviewPhotoUpload from '../../components/ReviewPhotoUpload.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { fetchGears } from '../../lib/products';
import { supabase } from '../../lib/supabase';
import { formatCurrency } from '../../utils/format';
import type { Gear } from '../../data/gears';
import ImageGallery from '../../components/products/ImageGallery.astro';
import Schema from '../../components/seo/Schema.astro';
import type { ProductImage } from '../../types/product';
export const prerender = true;
export async function getStaticPaths() {
  const gears = await fetchGears();
  const imageResults = await Promise.all(
    gears.map(async (gear) => {
      if (!supabase) return [];
      // First find the product_id from products table by slug
      const { data: product } = await supabase
        .from('products')
        .select('id')
        .eq('slug', gear.slug)
        .eq('type', 'gear')
        .single();
      if (!product) return [];
      const { data: images } = await supabase
        .from('product_images')
        .select('id, image_url, alt_text, caption, is_primary, sort_order')
        .eq('product_id', product.id)
        .order('sort_order', { ascending: true });
      return (images || []) as ProductImage[];
    })
  );
  return gears.map((gear, index) => ({
    params: { slug: gear.slug },
    props: { gear, images: imageResults[index] || [] },
  }));
}

interface Props { gear: Gear; images: ProductImage[]; }
const { gear, images } = Astro.props;

const formatted = formatCurrency(gear.price);
const canonicalUrl = `https://topzone.id/gear/${gear.slug}`;
---

<Layout
  title={`${gear.name} - Beli ${gear.name} Termurah | TopZone`}
  description={`Beli ${gear.name} dengan harga termurah di TopZone. Garansi resmi, pengiriman cepat, ${gear.brand || 'gaming gear'} berkualitas. ${gear.description}`}
  canonical={canonicalUrl}
  image={gear.img ? `https://topzone.id${gear.img}` : undefined}
>
  <!-- JSON-LD: Product Schema -->
  <Schema schema={{
    "@context": "https://schema.org",
    "@type": "Product",
    name: gear.name,
    description: gear.description,
    image: images.length > 0 ? images.map(img => `https://topzone.id${img.image_url}`) : (gear.img ? `https://topzone.id${gear.img}` : undefined),
    brand: { "@type": "Brand", name: "TopZone" },
    offers: {
      "@type": "Offer",
      url: Astro.url.href,
      priceCurrency: "IDR",
      price: gear.price,
      availability: "https://schema.org/InStock",
    },
    category: gear.category || "Gaming Gear",
  }} />
  <!-- JSON-LD: AggregateRating -->
  <Schema schema={{
    "@context": "https://schema.org",
    "@type": "AggregateRating",
    itemReviewed: {
      "@type": "Product",
      name: gear.name,
      url: Astro.url.href,
    },
    ratingValue: "4.5",
    reviewCount: "64",
    bestRating: "5",
    worstRating: "1",
    ratingCount: "64",
  }} />
  <!-- JSON-LD: BreadcrumbList -->
  <Schema schema={{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: "https://topzone.id/" },
      { "@type": "ListItem", position: 2, name: "Gear", item: "https://topzone.id/gear" },
      { "@type": "ListItem", position: 3, name: gear.name, item: Astro.url.href },
    ],
  }} />
    <Navbar />

    <!-- Breadcrumb Navigation -->
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
      <Breadcrumbs items={[
        { label: 'Home', href: '/' },
        { label: 'Gear', href: '/gear' },
        { label: gear.name },
      ]} />
    </div>

    <!-- Hero + Gallery Section -->
    <section class="py-16 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
        <div class="border-4 border-black shadow-[8px_8px_0px_0px_#000] overflow-hidden">
          <ImageGallery images={images} productName={gear.name} />
          <div class="bg-neon-yellow border-t-4 border-black px-4 py-2">
            <span class="font-black text-sm uppercase tracking-wider">{gear.tag}</span>
          </div>
        </div>

        <!-- Product Info -->
        <div>
          <a href="/#gear" class="inline-flex items-center gap-1 text-sm font-bold text-gray-500 hover:text-black transition-colors mb-4">
            ← Kembali ke Gear
          </a>
          <h1 class="text-4xl md:text-5xl font-black mb-3">{gear.name}</h1>
          <p class="text-gray-600 font-medium mb-6 leading-relaxed">{gear.description}</p>

          <div class="text-4xl font-black mb-6" style="color:#FF007F; -webkit-text-stroke:1px #000;">
            {formatted}
          </div>

          <!-- Specs Table -->
          <div class="border-4 border-black mb-8">
            <div class="bg-black text-neon-yellow px-4 py-2 font-black uppercase tracking-wider text-sm">Spesifikasi</div>
            {gear.specs.map((spec, i) => (
              <div class={`flex justify-between px-4 py-3 font-medium ${i % 2 === 0 ? 'bg-white' : 'bg-gray-50'} border-t-2 border-black/10`}>
                <span class="font-bold text-gray-600">{spec.label}</span>
                <span class="font-black">{spec.value}</span>
              </div>
            ))}
          </div>

          <!-- Add to Cart -->
          <button
            id="add-gear-btn"
            class="w-full py-4 font-black uppercase tracking-wider text-lg bg-neon-pink text-white border-4 border-black shadow-[4px_4px_0px_0px_#000] hover:-translate-y-1 hover:shadow-[6px_6px_0px_0px_#000] active:translate-y-0 active:shadow-[2px_2px_0px_0px_#000] transition-all"
            data-id={`gear-${gear.slug}`}
            data-name={gear.name}
            data-price={gear.price}
            data-img={gear.img}
          >
            🛒 Tambah ke Keranjang
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Toast -->
  <div id="gear-toast" class="hidden fixed bottom-6 right-6 z-50 bg-black text-neon-green font-black px-5 py-3 border-4 border-neon-green shadow-[4px_4px_0px_0px_#39FF14]">
    ✓ Ditambahkan ke keranjang!
  </div>

  <!-- ═══════════════════════════════════════════════════ -->
  <!-- REVIEWS & RATINGS -->
  <!-- ═══════════════════════════════════════════════════ -->
  <section class="py-12 bg-gray-50 border-t-4 border-black">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-black mb-2">⭐ Ulasan & Rating</h2>
      <p class="text-gray-500 font-medium mb-6">Kata para pembeli tentang produk ini.</p>
      <div class="border-4 border-black bg-white p-5 shadow-[4px_4px_0px_0px_#000] mb-6">
        <div class="flex items-center gap-6">
          <div class="text-center">
            <span class="text-5xl font-black" id="avg-rating">0</span>
            <span class="text-2xl">/5</span>
            <div class="text-lg" id="avg-stars">☆☆☆☆☆</div>
            <span class="text-sm font-bold text-gray-500" id="review-count">0 ulasan</span>
          </div>
          <div class="flex-1"><div id="rating-bars" class="space-y-1"></div></div>
        </div>
      </div>
      <div id="review-form-section" class="hidden border-4 border-black bg-neon-yellow p-5 shadow-[4px_4px_0px_0px_#000] mb-6">
        <h3 class="font-black text-lg mb-3">✍️ Tulis Ulasan</h3>
        <div class="flex gap-1 text-3xl mb-3" id="star-rating" role="radiogroup" aria-label="Rating bintang">
          <span class="star cursor-pointer hover:scale-110 transition-transform" data-val="1" role="radio" aria-checked="false" tabindex="0">☆</span>
          <span class="star cursor-pointer hover:scale-110 transition-transform" data-val="2" role="radio" aria-checked="false" tabindex="0">☆</span>
          <span class="star cursor-pointer hover:scale-110 transition-transform" data-val="3" role="radio" aria-checked="false" tabindex="0">☆</span>
          <span class="star cursor-pointer hover:scale-110 transition-transform" data-val="4" role="radio" aria-checked="false" tabindex="0">☆</span>
          <span class="star cursor-pointer hover:scale-110 transition-transform" data-val="5" role="radio" aria-checked="false" tabindex="0">☆</span>
        </div>
        <textarea id="review-text" rows="3" aria-label="Tulis ulasan kamu" class="w-full px-4 py-3 border-3 border-black font-bold text-sm shadow-[3px_3px_0px_0px_#000] focus:shadow-none focus:translate-x-[1px] focus:translate-y-[1px] outline-none transition-all resize-none" placeholder="Bagikan pengalamanmu..."></textarea>
        <ReviewPhotoUpload />
        <button id="submit-review" class="mt-3 px-6 py-3 font-black border-2 border-black bg-black text-white shadow-[3px_3px_0px_0px_#000] hover:shadow-none hover:translate-x-[1px] hover:translate-y-[1px] transition-all" aria-label="Kirim ulasan">Kirim Ulasan</button>
        <p id="review-status" class="mt-2 text-sm font-bold hidden" aria-live="polite"></p>
      </div>

      <div id="review-login-prompt" class="hidden border-4 border-dashed border-black p-6 text-center mb-6">
        <p class="font-black text-lg mb-2">🔒 Login untuk memberi ulasan</p>
        <a href="/login" class="inline-block px-6 py-2 font-black border-2 border-black bg-neon-green">Masuk</a>
      </div>
      <div id="review-purchase-prompt" class="hidden border-4 border-dashed border-black p-6 text-center mb-6">
        <p class="font-black text-lg mb-2">🛒 Beli produk ini dulu untuk memberi ulasan!</p>
      </div>
      <div id="reviews-list" class="space-y-4"></div>
      <div id="reviews-empty" class="text-center py-8 border-4 border-dashed border-black">
        <p class="text-lg font-black text-gray-400">Belum ada ulasan. Jadilah yang pertama!</p>
      </div>
    </div>
  </section>
  <Footer />

  <!-- Related Navigation / Internal Linking -->
  <section class="py-10 bg-gray-100 border-t-4 border-black">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-black mb-4">Jelajahi Koleksi Gear</h2>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/gear" class="px-6 py-3 font-black border-2 border-black bg-neon-yellow shadow-[3px_3px_0px_0px_#000] hover:-translate-y-1 hover:shadow-[5px_5px_0px_0px_#000] transition-all">Semua Gear</a>
        <a href="/#games" class="px-6 py-3 font-black border-2 border-black bg-white shadow-[3px_3px_0px_0px_#000] hover:-translate-y-1 hover:shadow-[5px_5px_0px_0px_#000] transition-all">Top Up Game</a>
      </div>
    </div>
  </section>

<script>
  const productSlug = window.location.pathname.split('/').pop();
  const STORAGE_REVIEWS = 'topzone_reviews';

  function getReviews() { try { return JSON.parse(localStorage.getItem(STORAGE_REVIEWS) || '[]'); } catch { return []; } }
  function getProductReviews() { return getReviews().filter(function(r) { return r.productSlug === productSlug; }); }

  function getAvgRating() {
    var revs = getProductReviews();
    if (revs.length === 0) return { avg: 0, count: 0, distribution: {} };
    var sum = revs.reduce(function(s, r) { return s + (r.rating||0); }, 0);
    var dist = {};
    for (var i = 1; i <= 5; i++) dist[i] = revs.filter(function(r) { return r.rating === i; }).length;
    return { avg: (sum / revs.length).toFixed(1), count: revs.length, distribution: dist };
  }

  function renderStars(n) { var s = ''; for (var i = 1; i <= 5; i++) s += i <= Math.round(n) ? '★' : '☆'; return s; }

  function renderReviews() {
    var revs = getProductReviews();
    var avg = getAvgRating();
    document.getElementById('avg-rating').textContent = avg.avg;
    document.getElementById('avg-stars').textContent = renderStars(avg.avg);
    document.getElementById('review-count').textContent = avg.count + ' ulasan';
    var barsEl = document.getElementById('rating-bars'); barsEl.innerHTML = '';
    for (var i = 5; i >= 1; i--) {
      var count = avg.distribution[i] || 0;
      var pct = avg.count > 0 ? (count / avg.count * 100) : 0;
      barsEl.innerHTML += '<div class=\"flex items-center gap-2 text-sm\"><span class=\"w-4 font-bold\">' + i + '</span><div class=\"flex-1 h-3 bg-gray-200 border border-black\"><div class=\"h-full bg-neon-yellow\" style=\"width:' + pct + '%\"></div></div><span class=\"w-8 text-right text-xs font-bold\">' + count + '</span></div>';
    }
    var list = document.getElementById('reviews-list');
    var empty = document.getElementById('reviews-empty');
    if (revs.length === 0) { list.innerHTML = ''; empty.classList.remove('hidden'); return; }
    empty.classList.add('hidden');
    list.innerHTML = revs.sort(function(a, b) { return new Date(b.createdAt) - new Date(a.createdAt); }).map(function(r) {
      return '<div class=\"border-4 border-black bg-white p-5 shadow-[2px_2px_0px_0px_#000]\"><div class=\"flex justify-between items-start mb-2\"><div><span class=\"font-black\">' + (r.userName || 'Anonymous') + '</span> <span class=\"text-yellow-500\">' + renderStars(r.rating) + '</span></div><span class=\"text-xs text-gray-400 font-bold\">' + new Date(r.createdAt).toLocaleDateString('id-ID') + '</span></div><p class=\"font-medium text-gray-700\">' + (r.comment || '') + '</p></div>';
    }).join('');
  }

  function canReview() {
    try {
      var userData = JSON.parse(localStorage.getItem('topzone_current_user'));
      if (!userData || !userData.isLoggedIn) return { can: false, reason: 'login' };
      var email = userData.email.replace(/[^a-zA-Z0-9]/g, '_');
      var ordersKey = 'topzone_orders_' + email;
      var orders = JSON.parse(localStorage.getItem(ordersKey) || '[]');
      var hasPurchased = orders.some(function(o) {
        return o.items && o.items.some(function(i) { return i.type === 'gear'; });
      });
      if (!hasPurchased) {
        var anonOrders = JSON.parse(localStorage.getItem('topzone_orders') || '[]');
        hasPurchased = anonOrders.some(function(o) {
          return o.items && o.items.some(function(i) { return i.type === 'gear'; });
        });
      }
      return { can: hasPurchased, reason: hasPurchased ? 'ok' : 'purchase' };
    } catch(e) { return { can: false, reason: 'login' }; }
  }

  var check = canReview();
  var formSection = document.getElementById('review-form-section');
  var loginPrompt = document.getElementById('review-login-prompt');
  var purchasePrompt = document.getElementById('review-purchase-prompt');
  if (check.can) { formSection.classList.remove('hidden'); }
  else if (check.reason === 'login') { loginPrompt.classList.remove('hidden'); }
  else { purchasePrompt.classList.remove('hidden'); }

  var selectedRating = 0;
  document.querySelectorAll('.star').forEach(function(s) {
    s.addEventListener('click', function() {
      selectedRating = parseInt(this.dataset.val);
      document.querySelectorAll('.star').forEach(function(st) { st.textContent = parseInt(st.dataset.val) <= selectedRating ? '★' : '☆'; });
    });
  });

  document.getElementById('submit-review').addEventListener('click', function() {
    var status = document.getElementById('review-status');
    if (selectedRating === 0) { status.className = 'mt-2 text-sm font-bold text-red-500'; status.textContent = 'Pilih rating dulu!'; status.classList.remove('hidden'); return; }
    var comment = document.getElementById('review-text').value.trim();
    if (!comment) { status.className = 'mt-2 text-sm font-bold text-red-500'; status.textContent = 'Tulis ulasan dulu!'; status.classList.remove('hidden'); return; }
    var revs = getReviews();
    var userData = JSON.parse(localStorage.getItem('topzone_current_user') || '{}');
    revs.push({ id: Date.now().toString(36), productSlug: productSlug, rating: selectedRating, comment: comment, userName: userData.full_name || userData.email?.split('@')[0] || 'User', userEmail: userData.email || '', createdAt: new Date().toISOString() });
    localStorage.setItem(STORAGE_REVIEWS, JSON.stringify(revs));
    status.className = 'mt-2 text-sm font-bold text-black bg-neon-green px-3 py-2 border-2 border-black';
    status.textContent = '✅ Ulasan berhasil dikirim!';
    status.classList.remove('hidden');
    document.getElementById('review-text').value = '';
    renderReviews();
  });

  renderReviews();
</script>
</Layout>

<script>
  import { addToCart } from '../../stores/cart';

  const btn = document.getElementById('add-gear-btn') as HTMLButtonElement | null;
  const toast = document.getElementById('gear-toast');

  btn?.addEventListener('click', () => {
    addToCart({
      id: btn.dataset.id!,
      name: btn.dataset.name!,
      price: Number(btn.dataset.price),
      img: btn.dataset.img!,
      type: 'gear',
    });
    toast?.classList.remove('hidden');
    setTimeout(() => toast?.classList.add('hidden'), 2000);
  });
</script>
