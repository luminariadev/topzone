---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { formatCurrency } from '../../../utils/format';
import { paginate } from '../../../utils/helpers';
import { applyProductFilters } from '../../../utils/filters';
import { getUniqueBrands } from '../../../utils/filters';

// Import gear data directly
import { gears } from '../../../data/gears';
import type { Gear } from '../../../types';

// Get filtered and sorted products based on URL params
const { searchParams } = new URL(Astro.request.url);
const category = searchParams.get('category') || 'all';
const brand = searchParams.get('brand') || 'all';
const sort = searchParams.get('sort') || 'Terbaru';
const page = Number(searchParams.get('page')) || 1;

// Map human-readable sort values to ProductFilters sortBy values
const sortMap = {
  'Termurah': 'price-asc',
  'Termahal': 'price-desc',
  'A-Z': 'name-asc',
  'Z-A': 'name-desc',
  'Terbaru': 'newest',
};

// Prepare filters object
const filters = {
  category,
  brand,
  sortBy: sortMap[sort as keyof typeof sortMap] || 'newest',
  status: 'published',
};

// Apply filters to gear products
const filteredProducts = applyProductFilters(gears as any, filters);

// Get unique brands for the brand filter dropdown
const uniqueBrands = getUniqueBrands(gears);

// Paginate products (9 items per page)
const itemsPerPage = 9;
const { items: paginatedProducts, total, totalPages } = paginate(filteredProducts, page, itemsPerPage);

// Previous and Next page URLs
const prevPage = page > 1 ? `/gear?${new URLSearchParams({
  ...(category && category !== 'all' ? { category } : {}),
  ...(brand && brand !== 'all' ? { brand } : {}),
  ...(sort && sort !== 'Terbaru' ? { sort } : {}),
  page: (page - 1).toString()
}).toString()}` : null;

const nextPage = page < totalPages ? `/gear?${new URLSearchParams({
  ...(category && category !== 'all' ? { category } : {}),
  ...(brand && brand !== 'all' ? { brand } : {}),
  ...(sort && sort !== 'Terbaru' ? { sort } : {}),
  page: (page + 1).toString()
}).toString() : null;

// Get sort options
const sortOptions = [
  { value: 'Termurah', label: 'Termurah' },
  { value: 'Termahal', label: 'Termahal' },
  { value: 'A-Z', label: 'A-Z' },
  { value: 'Z-A', label: 'Z-A' },
  { value: 'Terbaru', label: 'Terbaru' },
];

const gearCategories = {
  all: 'Semua',
  'keyboard': 'Keyboard',
  'mouse': 'Mouse',
  'headset': 'Headset',
  'chair': 'Chair',
  'controller': 'Controller',
  'webcam': 'Webcam',
  'microphone': 'Microphone',
  'monitor': 'Monitor',
  'mousepad': 'Mousepad',
  'speaker': 'Speaker',
  'streaming': 'Streaming',
};
---

<Layout>
  <Navbar />

  <main class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-10">
        <h1 class="text-5xl font-black uppercase tracking-tight mb-2">Gear Catalog</h1>
        <p class="text-gray-600 font-medium text-lg">All your gaming peripherals in one place.</p>
      </div>

      <!-- Filters Section -->
      <div class="bg-gray-50 border-4 border-black p-6 mb-8 shadow-[6px_6px_0px_0px_#000]">
        <div class="flex flex-col lg:flex-row gap-6">
          <!-- Category Filter Tabs -->
          <div class="flex-1">
            <label class="block text-sm font-black text-gray-700 mb-3 uppercase tracking-wider">Category</label>
            <div class="flex flex-wrap gap-2">
              {Object.entries(gearCategories).map(([key, label]) => (
                <a
                  href={`/gear?${new URLSearchParams({
                    ...(category !== key ? { category: key } : {}),
                    ...(brand !== 'all' ? { brand } : {}),
                    ...(sort !== 'Terbaru' ? { sort } : {}),
                    page: '1'
                  }).toString()}`
                  class={`px-4 py-2 font-black text-sm uppercase tracking-wider border-2 border-black transition-all
                    ${category === key
                      ? 'bg-black text-neon-green shadow-[3px_3px_0px_0px_#39FF14]'
                      : 'bg-white hover:bg-neon-pink hover:text-white'}
                  `}
                >
                  {label}
                </a>
              ))}
            </div>
          </div>

          <!-- Brand Filter -->
          <div class="w-full lg:w-48">
            <label for="brand-select" class="block text-sm font-black text-gray-700 mb-3 uppercase tracking-wider">Brand</label>
            <select
              id="brand-select"
              name="brand"
              onchange="location.href = this.value || '/gear'"
              class="w-full px-3 py-2 border-4 border-black font-bold bg-white shadow-[2px_2px_0px_0px_#000] focus:shadow-none focus:translate-x-[1px] focus:translate-y-[1px] transition-all"
            >
              <option value="/gear" selected={brand === 'all'}>Semua Brand</option>
              {uniqueBrands.map((b) => (
                <option
                  value={`/gear?${new URLSearchParams({
                    ...(category !== 'all' ? { category } : {}),
                    ...(brand !== b ? { brand: b } : {}),
                    ...(sort !== 'Terbaru' ? { sort } : {}),
                    page: '1'
                  }).toString()}`
                  selected={brand === b}
                >
                  {b}
                </option>
              ))}
            </select>
          </div>

          <!-- Sort Options -->
          <div class="w-full lg:w-48">
            <label for="sort-select" class="block text-sm font-black text-gray-700 mb-3 uppercase tracking-wider">Urutkan</label>
            <select
              id="sort-select"
              name="sort"
              onchange="location.href = this.value || '/gear'"
              class="w-full px-3 py-2 border-4 border-black font-bold bg-white shadow-[2px_2px_0px_0px_#000] focus:shadow-none focus:translate-x-[1px] focus:translate-y-[1px] transition-all"
            >
              {sortOptions.map((opt) => (
                <option
                  value={`/gear?${new URLSearchParams({
                    ...(category !== 'all' ? { category } : {}),
                    ...(brand !== 'all' ? { brand } : {}),
                    sort: opt.value,
                    page: '1'
                  }).toString()}`
                  selected={sort === opt.value}
                >
                  {opt.label}
                </option>
              ))}
            </select>
          </div>
        </div>
      </div>

      <!-- Results Count -->
      <div class="mb-6">
        <p class="text-gray-700 font-bold">
          Menampilkan {paginatedProducts.length} dari {total} produk
        </p>
      </div>

      <!-- Product Grid -->
      {paginatedProducts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
          {paginatedProducts.map((gear) => (
            <article class="group border-4 border-black bg-white shadow-[6px_6px_0px_0px_#000] hover:-translate-y-1 hover:shadow-[8px_8px_0px_0px_#000] transition-all duration-150">
              <a href={`/gear/${gear.slug}`} class="block">
                <div class="relative">
                  <img
                    src={gear.img}
                    alt={gear.name}
                    loading="lazy"
                    class="w-full h-48 object-cover border-b-4 border-black"
                  />
                  <span class="absolute top-3 right-3 px-2 py-1 text-xs font-black uppercase tracking-wider border-2 border-black bg-black text-neon-yellow shadow-[2px_2px_0px_0px_#FFE600]">
                    {gear.tag}
                  </span>
                  {gear.brand && (
                    <span class="absolute top-3 left-3 px-2 py-1 text-xs font-black uppercase tracking-wider border border-black bg-white/90">
                      {gear.brand}
                    </span>
                  )}
                </div>
                <div class="p-5">
                  <h3 class="text-xl font-black mb-2 line-clamp-2">{gear.name}</h3>
                  <p class="font-bold text-lg mb-4" style="color:#FF007F;">{formatCurrency(gear.price)}</p>
                  <div class="w-full py-2 font-black uppercase tracking-wider text-center bg-neon-pink text-white border-2 border-black shadow-[3px_3px_0px_0px_#000] group-hover:translate-x-[2px] group-hover:translate-y-[2px] group-hover:shadow-[1px_1px_0px_0px_#000] transition-all">
                    Lihat Detail →
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="border-4 border-dashed border-black bg-gray-50 p-12 text-center mb-12">
          <p class="text-xl font-black text-gray-400 mb-2">Tidak ada gear yang cocok dengan filter yang dipilih.</p>
          <p class="text-gray-600 font-medium">Coba ubah filter atau pilih kategori yang berbeda.</p>
        </div>
      )}

      <!-- Pagination -->
      {totalPages > 1 && (
        <div class="flex justify-center items-center gap-3">
          {prevPage && (
            <a
              href={prevPage}
              class="px-4 py-2 font-black border-2 border-black bg-white shadow-[3px_3px_0px_0px_#000] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all"
            >
              Sebelumnya
            </a>
          )}
          <div class="flex gap-2">
            {Array.from({ length: Math.min(totalPages, 5) }, (_, i) => {
              const pageNum = i + 1;
              const isActive = pageNum === page;
              const query = new URLSearchParams({
                ...(category !== 'all' ? { category } : {}),
                ...(brand !== 'all' ? { brand } : {}),
                ...(sort !== 'Terbaru' ? { sort } : {}),
                page: pageNum.toString()
              });
              return (
                <a
                  href={`/gear?${query.toString()}`}
                  class={`w-10 h-10 flex items-center justify-center font-black border-2 border-black
                    ${isActive
                      ? 'bg-neon-green text-black shadow-[2px_2px_0px_0px_#000]'
                      : 'bg-white hover:bg-black hover:text-white transition-all'}
                  `}
                >
                  {pageNum}
                </a>
              );
            })}
          </div>
          {nextPage && (
            <a
              href={nextPage}
              class="px-4 py-2 font-black border-2 border-black bg-white shadow-[3px_3px_0px_0px_#000] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all"
            >
              Berikutnya
            </a>
          )}
        </div>
      )}
    </div>
  </main>

  <Footer />
</Layout>