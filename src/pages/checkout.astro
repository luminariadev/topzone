---
// src/pages/checkout.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Checkout - TopZone" description="Selesaikan pembayaran top up game dan gear gaming di TopZone dengan aman dan cepat." canonical="https://topzone.id/checkout" robots="noindex, nofollow">
  <Navbar />

  <section class="py-16 min-h-screen bg-white dark:bg-gray-900" aria-label="Halaman Checkout">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-5xl font-black mb-2">Checkout <span style="color:#39FF14; -webkit-text-stroke:1px #000;">Pesanan</span></h1>
      <p class="text-gray-500 font-medium mb-10">Isi data pesanan dan pilih metode pembayaran.</p>

      <!-- Empty state -->
        <!-- Login Required -->
  <div id="checkout-login-required" class="hidden text-center py-24 border-4 border-dashed border-black">
    <div class="text-6xl mb-4">🔒</div>
    <p class="text-2xl font-black mb-2">Login Diperlukan</p>
    <p class="text-gray-500 font-bold mb-6">Kamu harus login dulu untuk checkout.</p>
    <a href="/login?redirect=/checkout" class="inline-block px-8 py-3 font-black uppercase border-2 border-black bg-neon-green shadow-[3px_3px_0px_0px_#000] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">Masuk Sekarang</a>
  </div>
      <div id="checkout-empty" class="hidden text-center py-24 border-4 border-dashed border-black">
        <p class="text-2xl font-black mb-6">Keranjangmu masih kosong!</p>
        <a href="/" class="inline-block px-8 py-3 font-black uppercase border-2 border-black bg-neon-green shadow-[3px_3px_0px_0px_#000] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">Mulai Belanja</a>
      </div>

      <!-- Content -->
      <div id="checkout-content" class="hidden">
        <!-- Order Summary -->
        <div class="border-4 border-black p-6 mb-8 bg-white shadow-[4px_4px_0px_0px_#000]">
          <h2 class="text-2xl font-black mb-4">Ringkasan Pesanan</h2>
          <div id="checkout-items" class="flex flex-col gap-3 pb-4"></div>
          <div class="border-t-2 border-black pt-4 space-y-2">
            <div class="flex justify-between items-center text-sm font-bold text-gray-500">
              <span>Subtotal</span>
              <span id="checkout-subtotal">Rp 0</span>
            </div>
            <div id="checkout-discount-row" class="hidden flex justify-between items-center text-sm font-bold text-neon-green">
              <span>Diskon</span>
              <span id="checkout-discount-amount">- Rp 0</span>
            </div>
            <div id="checkout-voucher-row" class="hidden flex justify-between items-center text-sm font-bold text-neon-pink">
              <span>Voucher</span>
              <span id="checkout-voucher-label">-</span>
            </div>
            <div class="border-t border-gray-200 pt-2 flex justify-between items-center">
              <span class="text-xl font-black">Total</span>
              <span class="text-3xl font-black" id="checkout-total">Rp 0</span>
            </div>
          </div>
          <p class="text-xs font-bold text-gray-400 mt-3">* Pesanan akan diproses setelah pembayaran dikonfirmasi</p>
        </div>

        // Points usage UI
    <div class="border-2 border-black p-4 bg-white dark:bg-gray-800 mb-4">
      <label class="block text-sm font-black uppercase tracking-wider mb-2">Gunakan Poin (1 poin = Rp 1000)</label>
      <div class="flex items-center gap-2">
        <input type="number" id="points-use" min="0" value="0" class="w-20 px-2 py-1 border-3 border-black font-bold" />
        <span id="points-available" class="text-sm font-bold text-gray-600">0 pts</span>
        <button type="button" id="apply-points" class="px-3 py-1 font-black border-2 border-black bg-neon-green text-black">Gunakan</button>
      </div>
      <p id="points-msg" class="mt-2 text-xs font-bold text-gray-500 hidden"></p>
    </div>

        <div class="border-4 border-black p-6 bg-neon-yellow shadow-[4px_4px_0px_0px_#000]">
          <h2 class="text-2xl font-black mb-4">Data Pembayar</h2>
          <form id="checkout-form" class="space-y-5">
            <div>
              <label class="block text-sm font-black uppercase tracking-wider mb-2">Nama Lengkap</label>
              <input type="text" id="name" required placeholder="Budi Gamer" class="w-full px-4 py-3 border-3 border-black font-bold text-lg shadow-[3px_3px_0px_0px_#000] focus:shadow-none focus:translate-x-[2px] focus:translate-y-[2px] outline-none transition-all" />
            </div>
            <div>
              <label class="block text-sm font-black uppercase tracking-wider mb-2">No. Telepon</label>
              <input type="tel" id="phone" required placeholder="081-23456789" class="w-full px-4 py-3 border-3 border-black font-bold text-lg shadow-[3px_3px_0px_0px_#000] focus:shadow-none focus:translate-x-[2px] focus:translate-y-[2px] outline-none transition-all" />
            </div>
            <div>
              <label class="block text-sm font-black uppercase tracking-wider mb-2">Catatan Pesanan (Opsional)</label>
              <textarea id="order-notes" rows="2" placeholder="Contoh: Mohon kirim dengan kemasan aman" class="w-full px-4 py-3 border-3 border-black font-bold text-sm shadow-[3px_3px_0px_0px_#000] focus:shadow-none focus:translate-x-[2px] focus:translate-y-[2px] outline-none transition-all resize-none"></textarea>
            </div>
            <div>
              <label class="block text-sm font-black uppercase tracking-wider mb-2">Metode Pembayaran</label>
              <select id="payment" required class="w-full px-4 py-3 border-3 border-black font-bold text-lg shadow-[3px_3px_0px_0px_#000] focus:shadow-none focus:translate-x-[2px] focus:translate-y-[2px] outline-none transition-all bg-white">
                <option value="bank">Transfer Bank</option>
                <option value="ewallet">E-Wallet</option>
                <option value="gopay">GoPay</option>
              </select>
            </div>

            <!-- Shipping Address (for gear purchases) -->
            <div id="shipping-section" class="hidden">
              <div class="border-2 border-dashed border-black p-4 bg-gray-50 dark:bg-gray-700">
                <label class="block text-sm font-black uppercase tracking-wider mb-2">📦 Alamat Pengiriman</label>
                <select id="shipping-address-select" class="w-full px-3 py-2 border-2 border-black font-bold text-sm bg-white">
                  <option value="">-- Pilih Alamat --</option>
                </select>
                <div id="shipping-address-detail" class="mt-2 p-3 border-2 border-black bg-white text-sm font-bold hidden"></div>

                <!-- Courier Selection -->
                <div id="courier-section" class="hidden mt-3">
                  <label class="block text-sm font-black uppercase tracking-wider mb-2">🚚 Pilih Kurir</label>
                  <select id="courier-select" class="w-full px-3 py-2 border-2 border-black font-bold text-sm bg-white">
                    <option value="">-- Pilih Kurir --</option>
                    <option value="jne">JNE (2-3 hari)</option>
                    <option value="jnt">J&T Express (2-3 hari)</option>
                    <option value="sicepat">SiCepat (1-2 hari)</option>
                    <option value="gosend">GoSend (Same Day)</option>
                  </select>
                  <div id="shipping-cost-display" class="mt-2 p-3 border-2 border-black bg-neon-yellow text-sm font-black text-center hidden">
                    Ongkos Kirim: <span id="shipping-cost-amount">Rp 0</span>
                  </div>
                </div>
                <p class="text-xs text-gray-500 mt-1 font-bold">Alamat ini akan digunakan untuk pengiriman gear. Untuk top-up digital, alamat tidak diperlukan.</p>
              </div>
            </div>

                        <div class="border-2 border-dashed border-black p-4 bg-gray-50">
              <label class="block text-sm font-black uppercase tracking-wider mb-2">🎟 Punya Voucher?</label>
              <div class="flex gap-2">
                <input type="text" id="voucher-input" class="flex-1 px-3 py-2 border-2 border-black font-bold text-sm" placeholder="Masukkan kode voucher" />
                <button type="button" id="apply-voucher" class="px-4 py-2 font-black text-sm border-2 border-black bg-neon-yellow hover:shadow-none hover:translate-x-[1px] hover:translate-y-[1px] transition-all">Pakai</button>
              </div>
              <div id="voucher-status" class="hidden mt-2 px-3 py-2 text-sm font-black border-2 border-black"></div>
              <div id="voucher-saved" class="hidden mt-2 px-3 py-2 text-sm font-black border-2 border-black bg-neon-green text-black"></div>
            </div>
            <div id="checkout-error" class="hidden bg-red-500 text-white font-black px-4 py-3 border-2 border-black text-sm"></div>

            <button type="submit" id="checkout-btn" class="w-full py-4 font-black uppercase tracking-wider text-lg bg-black text-neon-green border-4 border-black shadow-[4px_4px_0px_0px_#39FF14] hover:-translate-y-1 hover:shadow-[6px_6px_0px_0px_#39FF14] active:translate-y-0 active:shadow-[2px_2px_0px_0px_#39FF14] transition-all">
              Buat Pesanan
            </button>

            <!-- Buy Now (Quick Checkout) -->
            <div class="mt-4">
              <button type="button" id="buy-now-btn" class="w-full py-4 font-black uppercase tracking-wider text-lg bg-neon-pink text-white border-4 border-black shadow-[4px_4px_0px_0px_#FF007F] hover:-translate-y-1 hover:shadow-[6px_6px_0px_0px_#FF007F] active:translate-y-0 active:shadow-[2px_2px_0px_0px_#FF007F] transition-all">
                ⚡ Beli Sekarang (Quick Checkout)
              </button>
              <p class="text-xs font-bold text-gray-500 text-center mt-2">Langsung ke pembayaran tanpa form lengkap</p>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  import { user, getOrdersKey, getCurrentEmail } from '../stores/auth';
  import { cartItems, cartTotal, clearCart } from '../stores/cart';

  const emptyEl = document.getElementById('checkout-empty');
  const contentEl = document.getElementById('checkout-content');
  const itemsEl = document.getElementById('checkout-items');
  const totalEl = document.getElementById('checkout-total');
  const errorEl = document.getElementById('checkout-error');
  const form = document.getElementById('checkout-form');
  const btn = document.getElementById('checkout-btn');

  function formatRp(n) {
    return 'Rp ' + n.toLocaleString('id-ID');
  }

  // Check login
  var currentUser = user.get();
  var loginRequired = document.getElementById('checkout-login-required');
  var checkoutEmpty = document.getElementById('checkout-empty');
  var checkoutContent = document.getElementById('checkout-content');

  if (!currentUser || !currentUser.isLoggedIn) {
    // Show login prompt instead of checkout
    loginRequired?.classList.remove('hidden');
    checkoutEmpty?.classList.add('hidden');
    checkoutContent?.classList.add('hidden');
  } else {
    // Only show checkout content if logged in
    loginRequired?.classList.add('hidden');
    cartItems.subscribe(renderSummary);
    renderSummary();
  }

  function renderSummary() {
    const items = cartItems.get();
    const total = cartTotal.get();

    if (items.length === 0) {
      emptyEl?.classList.remove('hidden');
      contentEl?.classList.add('hidden');
      return;
    }

    emptyEl?.classList.add('hidden');
    contentEl?.classList.remove('hidden');

    // Calculate subtotal (before discount)
    const subtotal = items.reduce((sum, item) => sum + item.price * item.qty, 0);
    document.getElementById('checkout-subtotal').textContent = formatRp(subtotal);

    // Update discount/voucher rows
    var discountRow = document.getElementById('checkout-discount-row');
    var voucherRow = document.getElementById('checkout-voucher-row');
    var discountAmountEl = document.getElementById('checkout-discount-amount');
    var voucherLabelEl = document.getElementById('checkout-voucher-label');

    if (appliedDiscount > 0) {
      var discountAmount = Math.round(subtotal * appliedDiscount / 100);
      discountAmountEl.textContent = '- ' + formatRp(discountAmount);
      discountRow?.classList.remove('hidden');
      voucherLabelEl.textContent = appliedCode + ' (' + appliedDiscount + '%)';
      voucherRow?.classList.remove('hidden');
      totalEl.textContent = formatRp(subtotal - discountAmount);
    } else {
      discountRow?.classList.add('hidden');
      voucherRow?.classList.add('hidden');
      totalEl.textContent = formatRp(total);
    }

    if (itemsEl) {
      itemsEl.innerHTML = items.map((item) => `
        <div class="flex items-center gap-4">
          <img src="${item.img}" alt="${item.name}" loading="lazy" class="w-14 h-14 object-cover border-2 border-black flex-shrink-0" />
          <div class="flex-1 min-w-0">
            <p class="font-black leading-tight">${item.name}</p>
            <p class="text-xs font-bold text-gray-500">Qty: ${item.qty}</p>
          </div>
          <p class="font-black text-neon-pink">${formatRp(item.price * item.qty)}</p>
        </div>
      `).join('');
    }
  }


  // ═══════════════════════════════════════════════════════
  // SHIPPING ADDRESS
  // ═══════════════════════════════════════════════════════
  function detectShippingNeeded() {
    var items = cartItems.get();
    var hasGear = items.some(function(i) { return i.type === 'gear'; });
    var shippingSection = document.getElementById('shipping-section');
    if (shippingSection) {
      if (hasGear) { shippingSection.classList.remove('hidden'); }
      else { shippingSection.classList.add('hidden'); }
    }
  }
  cartItems.subscribe(detectShippingNeeded);
  setTimeout(detectShippingNeeded, 100);

  function loadShippingAddresses() {
    var currentUser = user.get();
    if (!currentUser || !currentUser.isLoggedIn) return;
    var email = currentUser.email;
    var addressesKey = 'topzone_addresses_' + email.replace(/[^a-zA-Z0-9]/g, '_');
    var select = document.getElementById('shipping-address-select');
    var detail = document.getElementById('shipping-address-detail');
    if (!select) return;

    try {
      var addrs = JSON.parse(localStorage.getItem(addressesKey) || '[]');
      if (addrs.length === 0) {
        select.innerHTML = '<option value="">-- Belum ada alamat --</option>';
        select.disabled = true;
        return;
      }
      select.disabled = false;
      var options = '<option value="">-- Pilih Alamat --</option>';
      addrs.forEach(function(addr, idx) {
        options += '<option value="' + idx + '"' + (addr.isDefault ? ' selected' : '') + '>' + addr.label + ' - ' + addr.city + (addr.isDefault ? ' (Utama)' : '') + '</option>';
      });
      select.innerHTML = options;
      if (addrs.some(function(a) { return a.isDefault; })) {
        select.dispatchEvent(new Event('change'));
      }
    } catch(e) {}
  }

  document.getElementById('shipping-address-select')?.addEventListener('change', function() {
    var currentUser = user.get();
    if (!currentUser) return;
    var email = currentUser.email;
    var addressesKey = 'topzone_addresses_' + email.replace(/[^a-zA-Z0-9]/g, '_');
    var detail = document.getElementById('shipping-address-detail');
    var courierSection = document.getElementById('courier-section');
    try {
      var addrs = JSON.parse(localStorage.getItem(addressesKey) || '[]');
      var idx = parseInt(this.value);
      if (!isNaN(idx) && addrs[idx]) {
        var a = addrs[idx];
        detail.innerHTML = '<strong>' + a.recipient + '</strong><br>' + a.phone + '<br>' + a.address + ', ' + a.city + ' ' + (a.postalCode || '');
        detail.classList.remove('hidden');
      } else {
        detail.classList.add('hidden');
      }
    } catch(e) {}
  });

  // Courier selection with shipping cost estimation
  document.getElementById('courier-select')?.addEventListener('change', function() {
    var costDisplay = document.getElementById('shipping-cost-display');
    var costAmount = document.getElementById('shipping-cost-amount');
    var courier = this.value;
    if (!courier) {
      costDisplay?.classList.add('hidden');
      return;
    }
    // Estimate shipping costs (mock — in production this would call RajaOngkir or similar API)
    var costs = { jne: 15000, jnt: 13000, sicepat: 20000, gosend: 25000 };
    var cost = costs[courier] || 15000;
    if (costAmount) costAmount.textContent = 'Rp ' + cost.toLocaleString('id-ID');
    if (costDisplay) costDisplay.classList.remove('hidden');

    // Update total with shipping
    var subtotalText = document.getElementById('checkout-subtotal')?.textContent?.replace(/[^0-9]/g, '') || '0';
    var subtotal = parseInt(subtotalText);
    var currentTotalText = document.getElementById('checkout-total')?.textContent?.replace(/[^0-9]/g, '') || '0';
    var currentTotal = parseInt(currentTotalText);
    // Show estimated total with shipping
    if (document.getElementById('checkout-total')) {
      document.getElementById('checkout-total').textContent = 'Rp ' + (subtotal + cost).toLocaleString('id-ID');
    }
  });

  setTimeout(loadShippingAddresses, 200);

  // ═══════════════════════════════════════════════════════
  // POINTS SYSTEM — integrate with spend-points API
  // ═══════════════════════════════════════════════════════
  var availablePoints = 0;
  var appliedPoints = 0;

  async function fetchAvailablePoints() {
    try {
      var resp = await fetch('/api/user/points');
      var data = await resp.json();
      if (resp.ok) {
        availablePoints = data.total_points || 0;
        document.getElementById('points-available').textContent = availablePoints.toLocaleString('id-ID') + ' pts';
      }
    } catch(e) { console.warn('Failed to fetch points:', e); }
  }

  document.getElementById('apply-points')?.addEventListener('click', async function() {
    var input = document.getElementById('points-use');
    var points = parseInt(input.value) || 0;
    var msg = document.getElementById('points-msg');

    if (points <= 0) {
      msg.textContent = 'Masukkan jumlah poin yang valid!';
      msg.className = 'mt-2 text-xs font-bold text-red-500';
      msg.classList.remove('hidden');
      return;
    }

    if (points > availablePoints) {
      msg.textContent = 'Poin tidak mencukupi! Maksimal ' + availablePoints.toLocaleString('id-ID') + ' pts.';
      msg.className = 'mt-2 text-xs font-bold text-red-500';
      msg.classList.remove('hidden');
      return;
    }

    // Call API to spend points
    try {
      var resp = await fetch('/api/user/spend-points', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ points, action: 'reserve' })
      });
      var result = await resp.json();
      if (!resp.ok) {
        msg.textContent = '❌ ' + (result.error || 'Gagal menggunakan poin');
        msg.className = 'mt-2 text-xs font-bold text-red-500';
        msg.classList.remove('hidden');
        return;
      }
    } catch(e) {
      msg.textContent = '❌ Gagal terhubung ke server. Coba lagi.';
      msg.className = 'mt-2 text-xs font-bold text-red-500';
      msg.classList.remove('hidden');
      return;
    }

    appliedPoints = points;
    msg.textContent = '✅ ' + points.toLocaleString('id-ID') + ' poin digunakan: Rp ' + (points * 1000).toLocaleString('id-ID');
    msg.className = 'mt-2 text-xs font-bold text-neon-green';
    msg.classList.remove('hidden');
    input.value = points;
    updateTotalWithPoints();
  });

  function updateTotalWithPoints() {
    var subtotalEl = document.getElementById('checkout-subtotal');
    var totalEl = document.getElementById('checkout-total');
    var subtotalText = subtotalEl.textContent.replace(/[^0-9]/g, '');
    var subtotal = parseInt(subtotalText) || 0;
    totalEl.textContent = formatRp(subtotal - (appliedPoints * 1000));
  }

  fetchAvailablePoints();

  // ═══════════════════════════════════════════════════════
  // VOUCHER SYSTEM
  // ═══════════════════════════════════════════════════════
  var appliedDiscount = 0;
  var appliedCode = '';

  function checkSavedVoucher() {
    try {
      var v = JSON.parse(localStorage.getItem('topzone_voucher'));
      if (v && !v.used) {
        document.getElementById('voucher-saved').textContent = '🎟 Voucher ' + v.code + ' tersedia! Diskon ' + v.discount + '% (klik Pakai untuk menggunakannya)';
        document.getElementById('voucher-saved').classList.remove('hidden');
        document.getElementById('voucher-input').value = v.code;
      }
    } catch(e) {
      console.warn('Failed to parse saved voucher:', e);
    }
  }
  checkSavedVoucher();

  document.getElementById('apply-voucher').addEventListener('click', function() {
    var code = document.getElementById('voucher-input').value.trim().toUpperCase();
    var statusEl = document.getElementById('voucher-status');
    var savedEl = document.getElementById('voucher-saved');

    if (!code) {
      statusEl.className = 'mt-2 px-3 py-2 text-sm font-black border-2 border-black bg-red-400 text-white';
      statusEl.textContent = 'Masukkan kode voucher!';
      statusEl.classList.remove('hidden');
      return;
    }

    // Check if code matches saved voucher
    try {
      var v = JSON.parse(localStorage.getItem('topzone_voucher'));
      if (v && v.code === code && !v.used) {
        appliedDiscount = v.discount || 10;
        appliedCode = code;
        statusEl.className = 'mt-2 px-3 py-2 text-sm font-black border-2 border-black bg-neon-green text-black';
        statusEl.textContent = '✅ Voucher dipakai! Diskon ' + appliedDiscount + '%';
        statusEl.classList.remove('hidden');
        savedEl.classList.add('hidden');
        updateTotalWithDiscount();
        return;
      }
    } catch(e) {}

    statusEl.className = 'mt-2 px-3 py-2 text-sm font-black border-2 border-black bg-red-400 text-white';
    statusEl.textContent = 'Kode voucher tidak valid atau sudah digunakan!';
    statusEl.classList.remove('hidden');
  });

  function updateTotalWithDiscount() {
    // Re-render summary with discount applied
    renderSummary();
  }

  // Real-time form validation
  function setupValidation() {
    var nameInput = document.getElementById('name');
    var phoneInput = document.getElementById('phone');

    if (nameInput) {
      nameInput.addEventListener('input', function() {
        if (this.value.trim().length < 2) {
          this.style.borderColor = '#FF4444';
          this.setAttribute('aria-invalid', 'true');
        } else {
          this.style.borderColor = '';
          this.setAttribute('aria-invalid', 'false');
        }
      });
    }

    if (phoneInput) {
      phoneInput.addEventListener('input', function() {
        var cleaned = this.value.replace(/[^0-9+\-\s()]/g, '');
        if (cleaned !== this.value) this.value = cleaned;
        if (this.value.length < 8) {
          this.style.borderColor = '#FF4444';
          this.setAttribute('aria-invalid', 'true');
        } else {
          this.style.borderColor = '';
          this.setAttribute('aria-invalid', 'false');
        }
      });
    }
  }
  setupValidation();

  // Buy Now (Quick Checkout)
  document.getElementById('buy-now-btn')?.addEventListener('click', function() {
    var currentUser = user.get();
    if (!currentUser || !currentUser.isLoggedIn) {
      window.location.href = '/login?redirect=/checkout';
      return;
    }

    var items = cartItems.get();
    if (items.length === 0) {
      alert('Keranjang masih kosong!');
      return;
    }

    // Auto-fill from user profile data if available
    var nameInput = document.getElementById('name');
    var phoneInput = document.getElementById('phone');
    if (nameInput && !nameInput.value && currentUser.full_name) {
      nameInput.value = currentUser.full_name;
    }
    if (phoneInput && !phoneInput.value) {
      try {
        var email = currentUser.email.replace(/[^a-zA-Z0-9]/g, '_');
        var userData = JSON.parse(localStorage.getItem('topzone_user_data_' + email) || '{}');
        if (userData.phone) phoneInput.value = userData.phone;
      } catch(e) {}
    }

    // Submit the form automatically
    form?.requestSubmit();
  });


  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl?.classList.add('hidden');
    btn.disabled = true;
    btn.textContent = 'Membuat Pesanan...';

    const name = document.getElementById('name').value;
    const phone = document.getElementById('phone').value;
    const payment = document.getElementById('payment').value;
    const items = cartItems.get();

    const orderId = 'ORD-' + Date.now() + '-' + Math.random().toString(36).substr(2, 5).toUpperCase();

        // Apply voucher discount
      var finalTotal = cartTotal.get();
      if (appliedDiscount > 0) {
        finalTotal = Math.round(finalTotal * (100 - appliedDiscount) / 100);
        try { var v = JSON.parse(localStorage.getItem('topzone_voucher')); if (v) { v.used = true; localStorage.setItem('topzone_voucher', JSON.stringify(v)); } } catch(e) {}
      }
      // Apply points discount
      if (appliedPoints > 0) {
        finalTotal = Math.max(0, finalTotal - (appliedPoints * 1000));
      }

    const order = {
      id: orderId,
      createdAt: new Date().toISOString(),
      userEmail: getCurrentEmail() || '',
      name,
      phone,
      notes: document.getElementById('order-notes')?.value?.trim() || '',
      payment,
      status: 'pending',
      total: (typeof finalTotal !== 'undefined' ? finalTotal : cartTotal.get()),
      items: items.map((i) => ({ id: i.id, name: i.name, price: i.price, qty: i.qty, type: i.type })),
    };

    let orders = JSON.parse(localStorage.getItem(getOrdersKey()) || '[]');
    orders.unshift(order);
    localStorage.setItem(getOrdersKey(), JSON.stringify(orders));

    clearCart();
    window.location.href = '/orders';

    // Attempt to complete referral (non-blocking)
    if (currentUser && currentUser.email) {
      try {
        await fetch('/api/auth/referral-complete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            referred_email: currentUser.email,
            order_id: orderId,
            order_total: order.total,
          }),
        });
      } catch (refCompleteErr) {
        console.warn('Referral completion failed (non-blocking):', refCompleteErr);
      }
    }

    // Deduct points (non-blocking)
    if (appliedPoints > 0 && currentUser && currentUser.email) {
      try {
        await fetch('/api/user/spend-points', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ points: appliedPoints, order_id: orderId }),
        });
      } catch (pointsErr) {
        console.warn('Points deduction failed (non-blocking):', pointsErr);
      }
    }
  });
</script>

